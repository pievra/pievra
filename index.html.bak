          <div class="protocol-title-row">
            <span class="protocol-icon">🤝</span>
            <div>
              <div class="protocol-name">A2A</div>
              <div style="display:flex;gap:8px;align-items:center;margin-top:4px">
                <span class="protocol-ver">v1.5</span>
                <span class="badge-live">Live</span>
                <span class="badge-new">New</span>
              </div>
            </div>
          </div>
          <p class="protocol-desc">Agent-to-Agent Protocol - Google's peer-to-peer communication standard enabling direct, authenticated exchanges between AI agents without central brokers.</p>
          <div class="protocol-tags">
            <span class="ptag">peer-to-peer</span><span class="ptag">direct</span><span class="ptag">Google</span>
          </div>
          <p class="protocol-steward"><strong>Steward:</strong> Google</p>
        </div>
        <div class="protocol-foot">View Implementation <span>›</span></div>
      </div>
    </div>
  </div>
</section>

