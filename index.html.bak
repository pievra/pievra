<!-- SEO structured data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Pievra",
  "url": "https://pievra.com",
  "description": "Protocol-neutral orchestration platform for programmatic AI campaigns across AdCP, UCP, ARTF, MCP and A2A.",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
}
</script>

<script>
// Toggle button groups
function toggleBtn(el, group) {
  const parent = el.closest('.btn-grid, .btn-grid-5, .btn-grid-3, .form-step');
  if (parent) {
    parent.querySelectorAll('.toggle-btn[onclick*="'+group+'"]').forEach(b => b.classList.remove('active'));
  }
  el.classList.add('active');
}

// Modal
function openModal() {
  document.getElementById('gateModal').classList.add('active');
  gtag && gtag('event', 'modal_open', { event_category: 'conversion', event_label: 'signup_gate' });
}
function closeModal() {
  document.getElementById('gateModal').classList.remove('active');
}
document.getElementById('gateModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// Gate submission
function submitGate() {
  const email = document.getElementById('gateEmail').value;
  if (!email || !email.includes('@')) {
    document.getElementById('gateEmail').style.borderColor = '#dc2626';
    return;
  }
  gtag && gtag('event', 'sign_up', { event_category: 'conversion', event_label: email });
  closeModal();
  alert('Welcome to Pievra! Check your email to activate your account.');
}

// Track generate button
function trackEvent(name) {
  gtag && gtag('event', name, { event_category: 'engagement' });
}

// Protocol filter
function filterProto(btn, cat) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.protocol-card').forEach(card => {
    if (cat === 'all') {
      card.style.display = '';
    } else {
      const cats = card.dataset.cat || '';
      card.style.display = cats.includes(cat) ? '' : 'none';
    }
  });
}

// Sort agents - featured always stays pinned at top, standard list reorders
function sortAgents(val) {
  gtag && gtag('event', 'marketplace_sort', { event_category: 'engagement', event_label: val });
  // In production this would trigger an API call - for now show feedback
  const count = document.querySelector('.marketplace-count strong');
  if (count) count.textContent = '53 agents';
}

// Nav scroll effect
window.addEventListener('scroll', () => {
  const nav = document.querySelector('nav');
  nav.style.boxShadow = window.scrollY > 20 ? '0 2px 20px rgba(10,14,26,0.08)' : 'none';
});
</script>
</body>
</html>
