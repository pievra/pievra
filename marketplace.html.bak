var currentCat = 'all';
var currentProto = 'all';
var currentStatus = 'all';

function filterCat(cat, el) {
  currentCat = cat;
  document.querySelectorAll('.filter-btn').forEach(function(b){ if(b.getAttribute('onclick') && b.getAttribute('onclick').includes('filterCat')) b.classList.remove('active'); });
  el.classList.add('active');
  applyFilters();
}
function filterProto(proto, el) {
  currentProto = proto;
  document.querySelectorAll('.filter-btn').forEach(function(b){ if(b.getAttribute('onclick') && b.getAttribute('onclick').includes('filterProto')) b.classList.remove('active'); });
  el.classList.add('active');
  applyFilters();
}
function filterStatus(status, el) {
  currentStatus = status;
  document.querySelectorAll('.filter-btn').forEach(function(b){ if(b.getAttribute('onclick') && b.getAttribute('onclick').includes('filterStatus')) b.classList.remove('active'); });
  el.classList.add('active');
  applyFilters();
}
function clearFilters() {
  currentCat = 'all'; currentProto = 'all'; currentStatus = 'all';
  document.getElementById('search').value = '';
  document.querySelectorAll('.filter-btn').forEach(function(b){ b.classList.remove('active'); });
  document.querySelector('[onclick="filterCat(\'all\',this)"]').classList.add('active');
  applyFilters();
}

function applyFilters() {
  var q = document.getElementById('search').value.toLowerCase();
  var sort = document.querySelector('.sort-wrap select').value;
  var filtered = AGENTS.filter(function(a) {
    var catOk = currentCat === 'all' || a.cat === currentCat;
    var protoOk = currentProto === 'all' || a.protocols.includes(currentProto);
    var statusOk = currentStatus === 'all' || a.status === currentStatus;
    var searchOk = !q || a.name.toLowerCase().includes(q) || a.desc.toLowerCase().includes(q) || a.tags.some(function(t){ return t.includes(q); }) || a.steward.toLowerCase().includes(q);
    return catOk && protoOk && statusOk && searchOk;
  });
  if(sort === 'score') filtered.sort(function(a,b){ return b.score - a.score; });
  else if(sort === 'name') filtered.sort(function(a,b){ return a.name.localeCompare(b.name); });
  else if(sort === 'new') filtered.sort(function(a,b){ return b.id - a.id; });
  document.getElementById('count').textContent = filtered.length;
  renderGrid(filtered);
}

var STATUS_ICON = {live:'🟢',beta:'🟡',new:'✨'};
var STATUS_LABEL = {live:'Live',beta:'Beta',new:'New'};
var PROTO_CLASS = {AdCP:'pb-adcp',MCP:'pb-mcp',UCP:'pb-ucp',ARTF:'pb-artf',A2A:'pb-a2a'};
var CAT_LABELS = {media:'Media Trading',data:'Data & Identity',creative:'Creative',infra:'Infrastructure',measurement:'Measurement',retail:'Retail Media'};

function renderGrid(agents) {
  var grid = document.getElementById('grid');
  var noRes = document.getElementById('no-results');
  if(!agents.length){ grid.innerHTML=''; noRes.style.display='block'; return; }
  noRes.style.display='none';
  grid.innerHTML = agents.map(function(a) {
    var protos = a.protocols.map(function(p){ return '<span class="proto-badge '+PROTO_CLASS[p]+'">'+p+'</span>'; }).join('');
    return '<div class="card'+(a.featured?' featured':'')+'">'+
      (a.featured?'<div class="feat-badge">FEATURED</div>':'')+
      '<div class="card-header">'+
        '<div class="card-icon">'+a.icon+'</div>'+
        '<div style="font-size:11px;font-weight:600;color:'+(a.status==='live'?'#166534':a.status==='beta'?'#854d0e':'#7a829e')+'">'+STATUS_ICON[a.status]+' '+STATUS_LABEL[a.status]+'</div>'+
      '</div>'+
      '<div class="card-name">'+a.name+'</div>'+
      '<div class="card-cat" style="margin-bottom:8px">'+CAT_LABELS[a.cat]+' · '+a.ver+'</div>'+
      '<div class="card-desc">'+a.desc+'</div>'+
      '<div class="card-protos">'+protos+'</div>'+
      '<div class="card-foot">'+
        '<div class="card-steward">'+a.steward+'</div>'+
        (a.link?'<a href="'+a.link+'" target="_blank" class="deploy-btn">View →</a>':'<span class="deploy-btn" style="opacity:.5">Coming soon</span>')+
      '</div>'+
    '</div>';
  }).join('');
}

// Init
applyFilters();

// Auto-deploy if arriving via ?deploy= param from homepage
(function(){
  var params = new URLSearchParams(window.location.search);
  var slug = params.get('deploy');
  if(!slug) return;
  var agent = AGENTS.find(function(a){ return a.name.toLowerCase().replace(/\s+/g,'') === slug.toLowerCase().replace(/-/g,''); });
  if(agent) deployAgent(agent.id);
  // Clean URL
  window.history.replaceState({}, '', '/marketplace');
})();

// ── AUTH CHECK ──────────────────────────────────────────────────────────────
var _mpUser = null;
var _mpTok = localStorage.getItem('pievra_token') || '';
(function(){
  if(!_mpTok) return;
  fetch('/auth/me', {credentials:'include', headers:{'Authorization':'Bearer '+_mpTok}})
  .then(function(r){ return r.ok ? r.json() : null; })
  .then(function(u){
    if(!u) return;
    _mpUser = u;
    document.getElementById('nav-guest').style.display = 'none';
    document.getElementById('nav-user').style.display = 'inline-flex';
    document.getElementById('hero-list-btn').style.display = 'block';
    document.getElementById('my-submissions-btn').style.display = 'inline-block';
  }).catch(function(){});
})();

// ── DEPLOY AGENT ────────────────────────────────────────────────────────────
function deployAgent(agentId){
  var agent = AGENTS.find(function(a){ return a.id === agentId; });
  if(!agent) return;

  // Store selected agent in localStorage for the planner to pick up
  var deployed = JSON.parse(localStorage.getItem('pievra_deploy_agents') || '[]');
  var already = deployed.some(function(d){ return d.id === agent.id; });
  if(!already){
    deployed.push({
      id: agent.id, name: agent.name, icon: agent.icon,
      protocols: agent.protocols, steward: agent.steward,
      score: agent.score, cat: agent.cat
    });
    localStorage.setItem('pievra_deploy_agents', JSON.stringify(deployed));
  }

  // Show confirmation toast
  var toast = document.createElement('div');
  toast.style.cssText = 'position:fixed;top:80px;left:50%;transform:translateX(-50%);background:#0a0e1a;color:white;padding:16px 28px;border-radius:12px;z-index:10000;font-size:14px;font-weight:600;box-shadow:0 8px 32px rgba(0,0,0,.3);display:flex;align-items:center;gap:12px';
  toast.innerHTML = '<span style="font-size:20px">'+agent.icon+'</span><div><div>'+agent.name+(already?' is already':' added to your')+ ' campaign stack</div><div style="font-size:12px;color:#00c4a7;margin-top:2px">'+(already?'':''+deployed.length+' agent'+(deployed.length>1?'s':'')+' selected · ')+'<a href="/dashboard" style="color:#00c4a7;text-decoration:underline">Open Campaign Planner →</a></div></div>';
  document.body.appendChild(toast);
  setTimeout(function(){ toast.remove(); }, 4000);
}

// ── SUBMIT FORM ─────────────────────────────────────────────────────────────
function openSubmitForm(){
  document.getElementById('agent-submit-modal').style.display = 'flex';
}
function closeSubmitForm(){
  document.getElementById('agent-submit-modal').style.display = 'none';
}

function submitAgent(){
  var name = document.getElementById('as-name').value.trim();
  var cat = document.getElementById('as-cat').value;
  var desc = document.getElementById('as-desc').value.trim();
  var steward = document.getElementById('as-steward').value.trim();
  var icon = document.getElementById('as-icon').value.trim() || '🤖';
  var version = document.getElementById('as-version').value.trim() || 'v1.0';
  var website = document.getElementById('as-website').value.trim();
  var featured = document.getElementById('as-featured').checked;

  var protos = [];
  document.querySelectorAll('.as-proto:checked').forEach(function(cb){ protos.push(cb.value); });

  // Validate
  var eb = document.getElementById('as-error');
  eb.style.display = 'none';
  if(!name || !cat || !desc){
    eb.textContent = 'Please fill in agent name, category, and description.';
    eb.style.display = 'block';
    return;
  }
  if(!protos.length){
    eb.textContent = 'Select at least one protocol.';
    eb.style.display = 'block';
    return;
  }

  var btn = document.getElementById('as-submit-btn');
  btn.textContent = 'Submitting...'; btn.disabled = true;

  fetch('/api/agent/submit', {
    method: 'POST', credentials: 'include',
    headers: {'Content-Type':'application/json', 'Authorization':'Bearer '+_mpTok},
    body: JSON.stringify({name:name, category:cat, description:desc, steward:steward, icon:icon, version:version, website:website, protocols:protos, featured_request:featured})
  })
  .then(function(r){ return r.json(); })
  .then(function(d){
    btn.textContent = 'Submit for Review'; btn.disabled = false;
    if(d.error){ eb.textContent = d.error; eb.style.display = 'block'; return; }
    closeSubmitForm();
    // Show success
    var toast = document.createElement('div');
    toast.style.cssText = 'position:fixed;top:80px;left:50%;transform:translateX(-50%);background:#0a0e1a;color:white;padding:16px 28px;border-radius:12px;z-index:10000;font-size:15px;font-weight:600;box-shadow:0 8px 32px rgba(0,0,0,.3)';
    toast.innerHTML = '&#x2705; Agent submitted for review! You will be notified once verified.';
    document.body.appendChild(toast);
    setTimeout(function(){ toast.remove(); }, 5000);
    // Reset form
    document.getElementById('as-name').value = '';
    document.getElementById('as-desc').value = '';
    document.getElementById('as-steward').value = '';
    document.getElementById('as-website').value = '';
    document.getElementById('as-featured').checked = false;
    document.querySelectorAll('.as-proto').forEach(function(cb){ cb.checked = false; });
  })
  .catch(function(){
    btn.textContent = 'Submit for Review'; btn.disabled = false;
    eb.textContent = 'Network error. Please try again.'; eb.style.display = 'block';
  });
}

// ── MY SUBMISSIONS ──────────────────────────────────────────────────────────
function openMySubmissions(){
  var panel = document.getElementById('my-submissions-panel');
  panel.style.display = 'flex';
  var body = document.getElementById('ms-body');
  body.innerHTML = '<div style="text-align:center;padding:32px;color:#7a829e">Loading...</div>';

  fetch('/api/agent/my-submissions', {
    credentials:'include',
    headers:{'Authorization':'Bearer '+_mpTok}
  })
  .then(function(r){ return r.json(); })
  .then(function(d){
    var subs = d.submissions || [];
    if(!subs.length){
      body.innerHTML = '<div style="text-align:center;padding:40px;color:#7a829e"><div style="font-size:32px;margin-bottom:10px">&#x1F4ED;</div><div style="font-weight:600;color:#0a0e1a;margin-bottom:6px">No submissions yet</div><div>List your first agent to get started</div></div>';
      return;
    }
    var STATUS_S = {pending:{bg:'#fef9c3',color:'#854d0e',label:'Pending Review'},approved:{bg:'#dcfce7',color:'#166534',label:'Approved'},rejected:{bg:'#fee2e2',color:'#dc2626',label:'Rejected'}};
    body.innerHTML = subs.map(function(s){
      var st = STATUS_S[s.status] || STATUS_S.pending;
      var protos = (s.protocols||[]).map(function(p){ return '<span class="proto-badge '+PROTO_CLASS[p]+'">'+p+'</span>'; }).join(' ');
      return '<div style="background:#f4f5f9;border-radius:12px;padding:16px;margin-bottom:10px">'
        +'<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">'
        +'<div style="display:flex;align-items:center;gap:10px"><span style="font-size:22px">'+(s.icon||'🤖')+'</span><div><div style="font-family:Manrope,sans-serif;font-weight:700;font-size:15px;color:#0a0e1a">'+s.name+'</div><div style="font-size:12px;color:#7a829e">'+CAT_LABELS[s.category]+' · '+s.version+(s.featured_request?' · ⭐ Featured requested':'')+'</div></div></div>'
        +'<span style="font-size:11px;font-weight:700;background:'+st.bg+';color:'+st.color+';padding:3px 10px;border-radius:20px">'+st.label+'</span>'
        +'</div>'
        +'<div style="font-size:13px;color:#3d4460;margin-bottom:8px">'+s.description+'</div>'
        +'<div>'+protos+'</div>'
        +(s.review_notes?'<div style="margin-top:8px;font-size:12px;color:#854d0e;background:#fef9c3;padding:8px 12px;border-radius:8px">Review note: '+s.review_notes+'</div>':'')
        +'</div>';
    }).join('');
  })
  .catch(function(){
    body.innerHTML = '<div style="text-align:center;padding:32px;color:#dc2626">Error loading submissions.</div>';
  });
}
function closeMySubmissions(){
  document.getElementById('my-submissions-panel').style.display = 'none';
}
</script>

<!-- AGENT SUBMIT MODAL -->
<div id="agent-submit-modal" style="display:none;position:fixed;inset:0;background:rgba(10,14,26,.6);z-index:9000;align-items:center;justify-content:center">
  <div style="background:white;border-radius:16px;padding:32px;max-width:640px;width:95%;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.25)">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
      <div style="font-family:Manrope,sans-serif;font-weight:800;font-size:20px;color:#0a0e1a">List Your Agent</div>
      <button onclick="closeSubmitForm()" style="background:none;border:none;font-size:24px;cursor:pointer;color:#7a829e">&times;</button>
    </div>
    <div style="background:#f4f5f9;border-radius:10px;padding:14px 16px;margin-bottom:20px;font-size:13px;color:#3d4460;line-height:1.6">
      &#x1F6C8; All agent submissions are <b>reviewed and verified</b> by the Pievra team before being listed publicly in the marketplace. You will be notified once your agent is approved.
    </div>
    <div id="as-error" style="display:none;background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:14px"></div>

    <div style="margin-bottom:16px">
      <label style="font-size:13px;font-weight:600;color:#0a0e1a;display:block;margin-bottom:6px">Agent Name <span style="color:#dc2626">*</span></label>
      <input id="as-name" type="text" placeholder="e.g. My Ad Agent" style="width:100%;padding:11px 14px;border:1.5px solid #e2e4ed;border-radius:8px;font-size:14px;font-family:Inter,sans-serif;color:#0a0e1a;outline:none"/>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px">
      <div>
        <label style="font-size:13px;font-weight:600;color:#0a0e1a;display:block;margin-bottom:6px">Category <span style="color:#dc2626">*</span></label>
        <select id="as-cat" style="width:100%;padding:11px 14px;border:1.5px solid #e2e4ed;border-radius:8px;font-size:14px;font-family:Inter,sans-serif;color:#0a0e1a;background:white;outline:none">
          <option value="">Select category...</option>
          <option value="media">Media Trading</option>
          <option value="data">Data & Identity</option>
          <option value="creative">Creative</option>
          <option value="infra">Infrastructure</option>
          <option value="measurement">Measurement</option>
          <option value="retail">Retail Media</option>
        </select>
      </div>
      <div>
        <label style="font-size:13px;font-weight:600;color:#0a0e1a;display:block;margin-bottom:6px">Icon (emoji)</label>
        <input id="as-icon" type="text" value="🤖" style="width:100%;padding:11px 14px;border:1.5px solid #e2e4ed;border-radius:8px;font-size:14px;font-family:Inter,sans-serif;color:#0a0e1a;outline:none"/>
      </div>
    </div>

    <div style="margin-bottom:16px">
      <label style="font-size:13px;font-weight:600;color:#0a0e1a;display:block;margin-bottom:6px">Description <span style="color:#dc2626">*</span></label>
      <textarea id="as-desc" rows="3" placeholder="Describe what your agent does, its key capabilities and differentiators..." style="width:100%;padding:11px 14px;border:1.5px solid #e2e4ed;border-radius:8px;font-size:14px;font-family:Inter,sans-serif;color:#0a0e1a;outline:none;resize:vertical"></textarea>
    </div>

    <div style="margin-bottom:16px">
      <label style="font-size:13px;font-weight:600;color:#0a0e1a;display:block;margin-bottom:8px">Supported Protocols <span style="color:#dc2626">*</span></label>
      <div style="display:flex;flex-wrap:wrap;gap:12px">
        <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#3d4460;cursor:pointer"><input type="checkbox" class="as-proto" value="AdCP" style="accent-color:#00c4a7"/> <span class="proto-badge pb-adcp">AdCP</span></label>
        <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#3d4460;cursor:pointer"><input type="checkbox" class="as-proto" value="MCP" style="accent-color:#00c4a7"/> <span class="proto-badge pb-mcp">MCP</span></label>
        <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#3d4460;cursor:pointer"><input type="checkbox" class="as-proto" value="UCP" style="accent-color:#00c4a7"/> <span class="proto-badge pb-ucp">UCP</span></label>
        <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#3d4460;cursor:pointer"><input type="checkbox" class="as-proto" value="ARTF" style="accent-color:#00c4a7"/> <span class="proto-badge pb-artf">ARTF</span></label>
        <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#3d4460;cursor:pointer"><input type="checkbox" class="as-proto" value="A2A" style="accent-color:#00c4a7"/> <span class="proto-badge pb-a2a">A2A</span></label>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px">
      <div>
        <label style="font-size:13px;font-weight:600;color:#0a0e1a;display:block;margin-bottom:6px">Steward / Company</label>
        <input id="as-steward" type="text" placeholder="e.g. Your company name" style="width:100%;padding:11px 14px;border:1.5px solid #e2e4ed;border-radius:8px;font-size:14px;font-family:Inter,sans-serif;color:#0a0e1a;outline:none"/>
      </div>
      <div>
        <label style="font-size:13px;font-weight:600;color:#0a0e1a;display:block;margin-bottom:6px">Version</label>
        <input id="as-version" type="text" value="v1.0" style="width:100%;padding:11px 14px;border:1.5px solid #e2e4ed;border-radius:8px;font-size:14px;font-family:Inter,sans-serif;color:#0a0e1a;outline:none"/>
      </div>
    </div>

    <div style="margin-bottom:20px">
      <label style="font-size:13px;font-weight:600;color:#0a0e1a;display:block;margin-bottom:6px">Website / Documentation URL</label>
      <input id="as-website" type="text" placeholder="https://..." style="width:100%;padding:11px 14px;border:1.5px solid #e2e4ed;border-radius:8px;font-size:14px;font-family:Inter,sans-serif;color:#0a0e1a;outline:none"/>
    </div>

    <!-- Featured option -->
    <div style="background:linear-gradient(135deg,#fff 0%,#e0faf6 100%);border:2px solid #00c4a7;border-radius:12px;padding:20px;margin-bottom:20px">
      <div style="display:flex;align-items:flex-start;gap:12px">
        <input id="as-featured" type="checkbox" style="accent-color:#00c4a7;width:18px;height:18px;margin-top:2px;flex-shrink:0"/>
        <div>
          <div style="font-family:Manrope,sans-serif;font-weight:700;font-size:15px;color:#0a0e1a;margin-bottom:4px">⭐ Request Featured Placement</div>
          <div style="font-size:13px;color:#3d4460;line-height:1.6;margin-bottom:8px">Get your agent highlighted at the top of the marketplace with a <b>FEATURED</b> badge and premium positioning. Featured agents receive <b>5x more visibility</b> and deployment clicks.</div>
          <div style="font-size:12px;color:#009e86;font-weight:600">Paid advertising service - our team will contact you with pricing after submission.</div>
        </div>
      </div>
    </div>

    <div style="display:flex;gap:10px">
      <button onclick="closeSubmitForm()" style="flex:1;padding:12px;border:1px solid #e2e4ed;background:none;color:#3d4460;font-weight:600;font-size:14px;border-radius:10px;cursor:pointer;font-family:Inter,sans-serif">Cancel</button>
      <button id="as-submit-btn" onclick="submitAgent()" style="flex:1;padding:12px;background:#0a0e1a;color:white;font-weight:700;font-size:14px;border:none;border-radius:10px;cursor:pointer;font-family:Inter,sans-serif">Submit for Review</button>
    </div>
  </div>
</div>

<!-- MY SUBMISSIONS PANEL -->
<div id="my-submissions-panel" style="display:none;position:fixed;inset:0;background:rgba(10,14,26,.6);z-index:9000;align-items:center;justify-content:center">
  <div style="background:white;border-radius:16px;padding:32px;max-width:640px;width:95%;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.25)">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
      <div style="font-family:Manrope,sans-serif;font-weight:800;font-size:20px;color:#0a0e1a">My Agent Submissions</div>
      <button onclick="closeMySubmissions()" style="background:none;border:none;font-size:24px;cursor:pointer;color:#7a829e">&times;</button>
    </div>
    <div id="ms-body"></div>
    <div style="margin-top:16px;display:flex;gap:10px">
      <button onclick="closeMySubmissions()" style="flex:1;padding:10px;border:1px solid #e2e4ed;background:none;color:#3d4460;font-weight:600;font-size:13px;border-radius:10px;cursor:pointer;font-family:Inter,sans-serif">Close</button>
      <button onclick="closeMySubmissions();openSubmitForm()" style="flex:1;padding:10px;background:#0a0e1a;color:white;font-weight:700;font-size:13px;border:none;border-radius:10px;cursor:pointer;font-family:Inter,sans-serif">+ Submit New Agent</button>
    </div>
  </div>
</div>

