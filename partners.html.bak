<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Partner Directory - Pievra</title>
<meta name="description" content="Find verified companies who can help you implement AI agents for programmatic advertising. Buyer agents, sales agents, creative, signals, data providers and consulting.">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--ink:#0a0e1a;--teal:#00c4a7;--teal-d:#009e86;--teal-l:#e0faf6;--surf:#f4f5f9;--border:#e2e4ed;--muted:#7a829e;--soft:#3d4460}
body{font-family:Inter,sans-serif;background:var(--surf);color:var(--ink)}
nav{background:var(--ink);height:60px;display:flex;align-items:center;justify-content:space-between;padding:0 40px;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.lm{width:30px;height:30px;background:var(--teal);border-radius:7px;display:flex;align-items:center;justify-content:center;font-family:Manrope;font-weight:800;font-size:14px;color:var(--ink)}
.ln{font-family:Manrope;font-weight:800;font-size:16px;color:#fff}
.nav-r{display:flex;gap:16px;align-items:center}
.nav-r a{color:rgba(255,255,255,.7);text-decoration:none;font-size:14px}
.nav-r a:hover{color:#fff}
.btn-teal{background:var(--teal);color:var(--ink);font-weight:700;font-size:13px;padding:8px 16px;border-radius:8px;text-decoration:none}

/* Hero */
.hero{background:var(--ink);padding:48px 40px 36px}
.hero-inner{max-width:1200px;margin:0 auto;display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:20px}
.hero h1{font-family:Manrope;font-weight:800;font-size:36px;color:#fff;margin-bottom:8px}
.hero h1 span{color:var(--teal)}
.hero p{font-size:15px;color:rgba(255,255,255,.6);max-width:520px}
.hero-stats{display:flex;gap:32px;flex-wrap:wrap}
.hs{text-align:center}
.hs-n{font-family:Manrope;font-weight:800;font-size:24px;color:var(--teal)}
.hs-l{font-size:12px;color:rgba(255,255,255,.4);margin-top:2px}

/* Layout */
.shell{max-width:1200px;margin:0 auto;padding:28px 24px}

/* Filters */
.filters-bar{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px;align-items:center}
.pf-btn{padding:8px 18px;border-radius:20px;font-size:13px;font-weight:600;font-family:Inter,sans-serif;cursor:pointer;border:1.5px solid var(--border);background:white;color:var(--soft);transition:all .15s}
.pf-btn:hover{border-color:var(--ink);color:var(--ink)}
.pf-btn.active{border-color:var(--ink);background:var(--ink);color:white}
.search-box{flex:1;min-width:200px;padding:8px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:13px;font-family:Inter,sans-serif;color:var(--ink);background:white;outline:none}
.search-box:focus{border-color:var(--teal)}

/* Grid */
.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.card{background:white;border:1.5px solid var(--border);border-radius:14px;padding:22px;transition:all .15s;cursor:pointer;position:relative}
.card:hover{border-color:var(--teal);box-shadow:0 4px 20px rgba(0,196,167,.1);transform:translateY(-2px)}
.card-icon{width:48px;height:48px;background:var(--surf);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0}
.tier{position:absolute;top:14px;right:14px;font-size:9px;font-weight:700;padding:3px 8px;border-radius:6px}
.tier-Gold{background:linear-gradient(135deg,#fef9c3,#fde68a);border:1px solid #f59e0b;color:#92400e}
.tier-Silver{background:linear-gradient(135deg,#f1f5f9,#e2e8f0);border:1px solid #94a3b8;color:#475569}
.tier-Bronze{background:linear-gradient(135deg,#fef3e2,#fed7aa);border:1px solid #f97316;color:#9a3412}
.proto{font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px;display:inline-block}
.p-AdCP{background:#dbeafe;color:#1e40af}.p-MCP{background:#f3e8ff;color:#7e22ce}.p-UCP{background:#dcfce7;color:#166534}.p-ARTF{background:#fef9c3;color:#854d0e}.p-A2A{background:#ffe4e6;color:#be123c}
.geo-tag{font-size:11px;background:var(--surf);color:var(--muted);padding:2px 8px;border-radius:6px;display:inline-block}

/* Detail view */
.detail-overlay{display:none;position:fixed;inset:0;background:rgba(10,14,26,.6);z-index:500;align-items:flex-start;justify-content:center;padding:40px 20px;overflow-y:auto}
.detail-overlay.open{display:flex}
.detail-box{background:white;border-radius:16px;max-width:800px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:hidden}
.detail-header{background:var(--ink);padding:32px;display:flex;align-items:center;gap:20px;position:relative}
.detail-icon{width:64px;height:64px;background:rgba(255,255,255,.1);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:32px;flex-shrink:0}
.detail-body{padding:32px}
.detail-section{margin-bottom:28px}
.detail-label{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.cap-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.cap-item{display:flex;align-items:flex-start;gap:8px;padding:10px 14px;background:var(--surf);border-radius:10px;font-size:13px;color:var(--soft);line-height:1.5}
.cap-item span{color:var(--teal-d);font-weight:700;flex-shrink:0}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.info-item{display:flex;flex-direction:column;gap:4px}
.info-item label{font-size:12px;font-weight:600;color:var(--muted)}
.info-item a,.info-item span{font-size:14px;color:var(--ink);text-decoration:none;word-break:break-all}
.info-item a:hover{color:var(--teal-d)}

.btn{padding:10px 20px;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;font-family:Inter,sans-serif;transition:all .15s;text-decoration:none;display:inline-flex;align-items:center;gap:8px}
.btn-dark{background:var(--ink);color:white}.btn-dark:hover{background:#1a2030}
.btn-green{background:var(--teal);color:var(--ink)}.btn-green:hover{background:var(--teal-d)}
.btn-outline{background:none;border:1.5px solid var(--border);color:var(--soft)}.btn-outline:hover{border-color:var(--ink);color:var(--ink)}

.empty{text-align:center;padding:60px 20px;color:var(--muted)}
.toast{position:fixed;top:80px;left:50%;transform:translateX(-50%);background:var(--ink);color:white;padding:16px 28px;border-radius:12px;z-index:10000;font-size:14px;font-weight:600;box-shadow:0 8px 32px rgba(0,0,0,.3);display:flex;align-items:center;gap:10px}

@media(max-width:900px){.grid{grid-template-columns:1fr}.hero{padding:32px 20px}nav{padding:0 20px}.cap-grid,.info-grid{grid-template-columns:1fr}.detail-header{flex-direction:column;text-align:center}}
</style></head><body>

<nav style="background:#0a0e1a;height:60px;display:flex;align-items:center;justify-content:space-between;padding:0 40px;position:sticky;top:0;z-index:100">
  <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none">
    <div style="width:30px;height:30px;background:#00c4a7;border-radius:7px;display:flex;align-items:center;justify-content:center;font-family:Manrope,sans-serif;font-weight:800;font-size:14px;color:#0a0e1a">P</div>
    <div style="font-family:Manrope,sans-serif;font-weight:800;font-size:16px;color:#fff">pievra</div>
  </a>
  <div style="display:flex;gap:20px;align-items:center">
    <a href="/marketplace" style="color:rgba(255,255,255,.7);text-decoration:none;font-size:14px;font-weight:500">Marketplace</a>
    <a href="/partners" style="color:rgba(255,255,255,.7);text-decoration:none;font-size:14px;font-weight:500">Partners</a>
    <a href="/news" style="color:rgba(255,255,255,.7);text-decoration:none;font-size:14px;font-weight:500">News</a>
    <a href="/careers" style="color:rgba(255,255,255,.7);text-decoration:none;font-size:14px;font-weight:500">Careers</a>
    <a href="/signin" style="color:rgba(255,255,255,.6);text-decoration:none;font-size:13px;font-weight:500">Sign In</a>
    <a href="/signup" style="background:#00c4a7;color:#0a0e1a;font-weight:700;font-size:13px;padding:8px 16px;border-radius:8px;text-decoration:none">Sign Up Free</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div>
      <h1>Partner Directory<br/><span>Implementation experts</span></h1>
      <p>Find companies who can help you implement AI agents for programmatic advertising. Every partner application is reviewed by the Pievra team.</p>
    </div>
    <div class="hero-stats">
      <div class="hs"><div class="hs-n">Open</div><div class="hs-l">Applications</div></div>
      <div class="hs"><div class="hs-n">7</div><div class="hs-l">Categories</div></div>
      <div class="hs"><div class="hs-n">5</div><div class="hs-l">Protocols</div></div>
      <div class="hs"><div class="hs-n">Free</div><div class="hs-l">Listing</div></div>
    </div>
  </div>
</div>

<div class="shell">
  <!-- Filters -->
  <div class="filters-bar">
    <button onclick="filterP('all',this)" class="pf-btn active">All</button>
    <button onclick="filterP('buyer',this)" class="pf-btn">Buyer Agents</button>
    <button onclick="filterP('sales',this)" class="pf-btn">Sales Agents</button>
    <button onclick="filterP('creative',this)" class="pf-btn">Creative Agents</button>
    <button onclick="filterP('signals',this)" class="pf-btn">Signals Agents</button>
    <button onclick="filterP('data',this)" class="pf-btn">Data Providers</button>
    <button onclick="filterP('consulting',this)" class="pf-btn">Consulting</button>
    <button onclick="filterP('retail',this)" class="pf-btn">Retail Media</button>
    <input type="text" id="p-search" class="search-box" placeholder="Search partners..." oninput="renderAll()"/>
  </div>

  <!-- Grid -->
  <div class="grid" id="p-grid"></div>
  <div class="empty" id="p-empty" style="display:none">
    <div style="font-size:32px;margin-bottom:10px">🚀</div>
    <strong style="color:var(--ink)">The partner directory is open for applications</strong>
    <p style="margin-top:8px;font-size:14px;max-width:400px;margin-left:auto;margin-right:auto">7 applications are currently under review. We are building a directory of companies in the agentic advertising space. Apply below to be listed when the directory launches.</p>
    <a href="#partner-apply" class="btn btn-dark" style="margin-top:16px;display:inline-flex">Apply now &#x2192;</a>
  </div>

  <!-- PARTNER APPLICATION FORM -->
  <div id="partner-apply" style="margin-top:40px;background:white;border:1.5px solid var(--border);border-radius:16px;overflow:hidden">
    <div style="background:var(--ink);padding:32px 36px">
      <div style="font-size:28px;margin-bottom:10px">🤝</div>
      <div style="font-family:Manrope;font-weight:800;font-size:22px;color:white;margin-bottom:6px">Want to be listed as a Pievra partner?</div>
      <p style="font-size:15px;color:rgba(255,255,255,.6);max-width:520px">Join the directory and get discovered by brands and agencies looking for agentic advertising implementation support.</p>
    </div>

    <div id="partner-form-container" style="padding:32px 36px">
      <div id="partner-success" style="display:none;text-align:center;padding:32px 0">
        <div style="font-size:48px;margin-bottom:16px">&#x2705;</div>
        <div style="font-family:Manrope;font-weight:800;font-size:20px;color:var(--ink);margin-bottom:8px">Application received</div>
        <p style="font-size:14px;color:var(--muted);max-width:400px;margin:0 auto">Our team will review your application and get back to you within 2 business days at the email provided.</p>
      </div>

      <form id="partner-form" onsubmit="submitPartnerForm(event)" style="display:grid;grid-template-columns:1fr 1fr;gap:18px">
        <div style="grid-column:span 2">
          <div id="partner-err" style="display:none;background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:12px 16px;border-radius:10px;font-size:13px;margin-bottom:8px"></div>
        </div>

        <div>
          <label style="display:block;font-size:12px;font-weight:600;color:var(--muted);margin-bottom:6px">Company / Agent name *</label>
          <input type="text" id="pf-company" placeholder="e.g. Your Company Name" required style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:Inter,sans-serif;color:var(--ink);background:var(--surf);outline:none"/>
        </div>

        <div>
          <label style="display:block;font-size:12px;font-weight:600;color:var(--muted);margin-bottom:6px">Contact name *</label>
          <input type="text" id="pf-name" placeholder="Full name" required style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:Inter,sans-serif;color:var(--ink);background:var(--surf);outline:none"/>
        </div>

        <div>
          <label style="display:block;font-size:12px;font-weight:600;color:var(--muted);margin-bottom:6px">Work email *</label>
          <input type="email" id="pf-email" placeholder="you@company.com" required style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:Inter,sans-serif;color:var(--ink);background:var(--surf);outline:none"/>
        </div>

        <div>
          <label style="display:block;font-size:12px;font-weight:600;color:var(--muted);margin-bottom:6px">Website</label>
          <input type="url" id="pf-url" placeholder="https://yourcompany.com" style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:Inter,sans-serif;color:var(--ink);background:var(--surf);outline:none"/>
        </div>

        <div>
          <label style="display:block;font-size:12px;font-weight:600;color:var(--muted);margin-bottom:6px">Category *</label>
          <select id="pf-cat" required style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:Inter,sans-serif;color:var(--ink);background:var(--surf);outline:none">
            <option value="">Select a category</option>
            <option value="buyer">Buyer Agents</option>
            <option value="sales">Sales Agents</option>
            <option value="creative">Creative Agents</option>
            <option value="signals">Signals Agents</option>
            <option value="data">Data Providers</option>
            <option value="consulting">Consulting</option>
            <option value="retail">Retail Media</option>
          </select>
        </div>

        <div>
          <label style="display:block;font-size:12px;font-weight:600;color:var(--muted);margin-bottom:6px">Protocols supported</label>
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:4px">
            <label style="display:flex;align-items:center;gap:4px;font-size:13px;color:var(--soft);cursor:pointer"><input type="checkbox" name="pf-proto" value="AdCP" style="accent-color:var(--teal)"/> AdCP</label>
            <label style="display:flex;align-items:center;gap:4px;font-size:13px;color:var(--soft);cursor:pointer"><input type="checkbox" name="pf-proto" value="MCP" style="accent-color:var(--teal)"/> MCP</label>
            <label style="display:flex;align-items:center;gap:4px;font-size:13px;color:var(--soft);cursor:pointer"><input type="checkbox" name="pf-proto" value="UCP" style="accent-color:var(--teal)"/> UCP</label>
            <label style="display:flex;align-items:center;gap:4px;font-size:13px;color:var(--soft);cursor:pointer"><input type="checkbox" name="pf-proto" value="ARTF" style="accent-color:var(--teal)"/> ARTF</label>
            <label style="display:flex;align-items:center;gap:4px;font-size:13px;color:var(--soft);cursor:pointer"><input type="checkbox" name="pf-proto" value="A2A" style="accent-color:var(--teal)"/> A2A</label>
          </div>
        </div>

        <div style="grid-column:span 2">
          <label style="display:block;font-size:12px;font-weight:600;color:var(--muted);margin-bottom:6px">Tell us about your company and what you do *</label>
          <textarea id="pf-desc" required placeholder="What does your company do? What protocols do you support? What value do you bring to brands and agencies?" rows="4" style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:Inter,sans-serif;color:var(--ink);background:var(--surf);outline:none;resize:vertical"></textarea>
        </div>

        <div style="grid-column:span 2">
          <label style="display:flex;align-items:flex-start;gap:8px;font-size:13px;color:var(--soft);cursor:pointer">
            <input type="checkbox" id="pf-agree" required style="accent-color:var(--teal);margin-top:2px"/>
            <span>I confirm the information provided is accurate. I agree to the <a href="/terms" target="_blank" style="color:var(--teal-d)">Terms of Service</a> and <a href="/privacy" target="_blank" style="color:var(--teal-d)">Privacy Policy</a>.</span>
          </label>
        </div>

        <div style="grid-column:span 2">
          <button type="submit" id="pf-submit" class="btn btn-dark" style="width:100%;justify-content:center;padding:14px;font-size:15px">Apply to become a Partner &#x2192;</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- DETAIL OVERLAY -->
<div class="detail-overlay" id="detail-overlay" onclick="if(event.target===this)closeDetail()">
  <div class="detail-box">
    <div class="detail-header">
      <button onclick="closeDetail()" style="position:absolute;top:16px;right:16px;background:none;border:none;color:rgba(255,255,255,.5);font-size:24px;cursor:pointer">&times;</button>
      <div class="detail-icon" id="d-icon"></div>
      <div>
        <div id="d-name" style="font-family:Manrope;font-weight:800;font-size:22px;color:white"></div>
        <div id="d-cat" style="font-size:14px;color:rgba(255,255,255,.6);margin-top:4px"></div>
        <div id="d-protos" style="margin-top:8px;display:flex;flex-wrap:wrap;gap:4px"></div>
      </div>
      <div id="d-tier" style="position:absolute;top:16px;right:56px"></div>
    </div>
    <div class="detail-body">
      <!-- About -->
      <div class="detail-section">
        <div class="detail-label">About</div>
        <p id="d-desc" style="font-size:14px;color:var(--soft);line-height:1.7"></p>
      </div>

      <!-- Core Capabilities -->
      <div class="detail-section">
        <div class="detail-label">Core Capabilities</div>
        <div class="cap-grid" id="d-caps"></div>
      </div>

      <!-- Company Info -->
      <div class="detail-section">
        <div class="detail-label">Company Information</div>
        <div class="info-grid" id="d-info"></div>
      </div>

      <!-- Geos -->
      <div class="detail-section">
        <div class="detail-label">Geographic Coverage</div>
        <div id="d-geos" style="display:flex;flex-wrap:wrap;gap:6px"></div>
      </div>

      <!-- Contact -->
      <div class="detail-section">
        <div class="detail-label">Contact</div>
        <div class="info-grid" id="d-contact"></div>
      </div>

      <!-- Actions -->
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:8px">
        <button onclick="requestIntro()" class="btn btn-green" id="d-intro-btn">🐙 Request Introduction via Pievra</button>
        <a id="d-web-link" href="#" target="_blank" class="btn btn-dark">Visit Website →</a>
        <a id="d-li-link" href="#" target="_blank" class="btn btn-outline">LinkedIn</a>
      </div>
    </div>
  </div>
</div>

<script>
var PARTNERS = [
  // Directory is open for applications, approved partners appear here
];

var CAT_LABELS = {buyer:'Buyer Agents',sales:'Sales Agents',creative:'Creative Agents',signals:'Signals Agents',data:'Data Providers',consulting:'Consulting',retail:'Retail Media'};
var _currentCat = 'all';
var _currentPartner = null;

// Auth check
var _tok = localStorage.getItem('pievra_token') || '';
(function(){
  if(!_tok) return;
  fetch('/auth/me',{credentials:'include',headers:{'Authorization':'Bearer '+_tok}})
  .then(function(r){return r.ok?r.json():null;})
  .then(function(u){
    if(!u) return;
    document.getElementById('nav-guest').style.display='none';
    document.getElementById('nav-user').style.display='inline';
  }).catch(function(){});
})();

function filterP(cat, btn){
  _currentCat = cat;
  document.querySelectorAll('.pf-btn').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  renderAll();
}

function renderAll(){
  var q = (document.getElementById('p-search').value || '').toLowerCase();
  var list = PARTNERS.filter(function(p){
    var catOk = _currentCat === 'all' || p.cat === _currentCat;
    var searchOk = !q || p.name.toLowerCase().indexOf(q) !== -1 || p.desc.toLowerCase().indexOf(q) !== -1 || (p.capabilities||[]).join(' ').toLowerCase().indexOf(q) !== -1;
    return catOk && searchOk;
  });
  var grid = document.getElementById('p-grid');
  var empty = document.getElementById('p-empty');
  if(!list.length){ grid.innerHTML=''; empty.style.display='block'; return; }
  empty.style.display='none';
  document.getElementById('stat-total').textContent = list.length;

  grid.innerHTML = list.map(function(p){
    var protos = p.protocols.map(function(pr){ return '<span class="proto p-'+pr+'">'+pr+'</span>'; }).join(' ');
    var geoPreview = p.geos.slice(0,3).map(function(g){ return '<span class="geo-tag">'+g+'</span>'; }).join(' ') + (p.geos.length > 3 ? ' <span class="geo-tag">+' + (p.geos.length - 3) + '</span>' : '');
    return '<div class="card" onclick="openDetail('+p.id+')">'
      +'<div class="tier tier-'+p.tier+'">'+p.tier+' Partner</div>'
      +'<div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">'
      +'<div class="card-icon">'+p.icon+'</div>'
      +'<div><div style="font-family:Manrope;font-weight:700;font-size:15px;color:var(--ink)">'+p.name+'</div>'
      +'<div style="font-size:12px;color:var(--muted)">'+CAT_LABELS[p.cat]+' · '+p.hq+'</div></div>'
      +'</div>'
      +'<div style="font-size:13px;color:var(--soft);line-height:1.6;margin-bottom:14px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">'+p.desc+'</div>'
      +'<div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px">'+protos+'</div>'
      +'<div style="display:flex;flex-wrap:wrap;gap:4px">'+geoPreview+'</div>'
      +'</div>';
  }).join('');
}

function openDetail(id){
  var p = PARTNERS.find(function(x){ return x.id === id; });
  if(!p) return;
  _currentPartner = p;

  document.getElementById('d-icon').textContent = p.icon;
  document.getElementById('d-name').textContent = p.name;
  document.getElementById('d-cat').textContent = CAT_LABELS[p.cat] + ' · ' + p.hq + ' · Founded ' + p.founded + ' · ' + p.employees + ' employees';
  document.getElementById('d-desc').textContent = p.desc;
  document.getElementById('d-tier').innerHTML = '<span class="tier tier-'+p.tier+'">'+p.tier+' Partner</span>';

  // Protocols
  document.getElementById('d-protos').innerHTML = p.protocols.map(function(pr){ return '<span class="proto p-'+pr+'">'+pr+'</span>'; }).join(' ');

  // Capabilities
  document.getElementById('d-caps').innerHTML = (p.capabilities||[]).map(function(c){
    return '<div class="cap-item"><span>✓</span> '+c+'</div>';
  }).join('');

  // Company info
  document.getElementById('d-info').innerHTML =
    '<div class="info-item"><label>Headquarters</label><span>'+p.hq+'</span></div>'
    +'<div class="info-item"><label>Founded</label><span>'+p.founded+'</span></div>'
    +'<div class="info-item"><label>Company Size</label><span>'+p.employees+' employees</span></div>'
    +'<div class="info-item"><label>Tier</label><span>'+p.tier+' Partner</span></div>';

  // Geos
  document.getElementById('d-geos').innerHTML = p.geos.map(function(g){ return '<span class="geo-tag">'+g+'</span>'; }).join(' ');

  // Contact
  document.getElementById('d-contact').innerHTML =
    '<div class="info-item"><label>Contact</label><span>'+p.contact_name+' - '+p.contact_role+'</span></div>'
    +'<div class="info-item"><label>Email</label><a href="mailto:'+p.contact_email+'">'+p.contact_email+'</a></div>';

  // Links
  document.getElementById('d-web-link').href = p.url;
  document.getElementById('d-li-link').href = p.linkedin;

  document.getElementById('detail-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeDetail(){
  document.getElementById('detail-overlay').classList.remove('open');
  document.body.style.overflow = '';
  _currentPartner = null;
}

function requestIntro(){
  if(!_tok){
    window.location.href = '/signup';
    return;
  }
  if(!_currentPartner) return;
  var p = _currentPartner;
  var btn = document.getElementById('d-intro-btn');
  btn.textContent = 'Sending...'; btn.disabled = true;

  // Send introduction request via the campaign API
  fetch('/api/campaigns/export-email', {
    method: 'POST', credentials: 'include',
    headers: {'Content-Type':'application/json','Authorization':'Bearer '+_tok},
    body: JSON.stringify({
      email: p.contact_email,
      campaign_ids: [],
      intro_request: true,
      partner_name: p.name,
      message: 'Introduction request via Pievra Partner Directory'
    })
  })
  .then(function(){ showIntroSuccess(p); })
  .catch(function(){ showIntroSuccess(p); });

  function showIntroSuccess(p){
    btn.innerHTML = '🐙 Request Introduction via Pievra'; btn.disabled = false;
    closeDetail();
    var toast = document.createElement('div');
    toast.className = 'toast';
    toast.innerHTML = '<span style="font-size:22px">🐙</span><div><div>Introduction requested with '+p.name+'</div><div style="font-size:12px;color:#00c4a7;margin-top:2px">The Pievra team will connect you within 24 hours</div></div>';
    document.body.appendChild(toast);
    setTimeout(function(){ toast.remove(); }, 5000);
  }
}

// Keyboard
document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeDetail(); });

// Init
renderAll();

// ── PARTNER APPLICATION FORM ─────────────────────────────────────────────────
function submitPartnerForm(e){
  e.preventDefault();
  var err = document.getElementById('partner-err');
  var btn = document.getElementById('pf-submit');
  err.style.display = 'none';

  var company = document.getElementById('pf-company').value.trim();
  var name = document.getElementById('pf-name').value.trim();
  var email = document.getElementById('pf-email').value.trim();
  var url = document.getElementById('pf-url').value.trim();
  var cat = document.getElementById('pf-cat').value;
  var desc = document.getElementById('pf-desc').value.trim();
  var agree = document.getElementById('pf-agree').checked;
  var protos = Array.from(document.querySelectorAll('input[name="pf-proto"]:checked')).map(function(c){ return c.value; });

  if(!company || !name || !email || !cat || !desc){
    err.textContent = 'Please fill in all required fields.';
    err.style.display = 'block';
    return;
  }
  if(!agree){
    err.textContent = 'Please accept the Terms of Service and Privacy Policy.';
    err.style.display = 'block';
    return;
  }

  btn.textContent = 'Submitting...'; btn.disabled = true;

  fetch('/api/request-demo', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({
      name: name,
      email: email,
      company: company,
      company_type: 'Partner Application - ' + cat,
      budget: protos.join(', ') || 'Not specified',
      needs: 'PARTNER APPLICATION\n\nCategory: ' + cat + '\nProtocols: ' + (protos.join(', ') || 'Not specified') + '\nWebsite: ' + (url || 'Not provided') + '\n\nDescription:\n' + desc
    })
  })
  .then(function(r){ return r.json(); })
  .then(function(d){
    document.getElementById('partner-form').style.display = 'none';
    document.getElementById('partner-success').style.display = 'block';
  })
  .catch(function(){
    document.getElementById('partner-form').style.display = 'none';
    document.getElementById('partner-success').style.display = 'block';
  })
  .finally(function(){
    btn.textContent = 'Apply to become a Partner \u2192'; btn.disabled = false;
  });
}
</script>
</body></html>
