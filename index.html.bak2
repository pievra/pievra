</script>

<script>
// Toggle button groups
function toggleBtn(el, group) {
  const parent = el.closest('.btn-grid, .btn-grid-5, .btn-grid-3, .form-step');
  if (parent) {
    parent.querySelectorAll('.toggle-btn[onclick*="'+group+'"]').forEach(b => b.classList.remove('active'));
  }
  el.classList.add('active');
}

// Modal
function openModal() {
  document.getElementById('gateModal').classList.add('active');
  gtag && gtag('event', 'modal_open', { event_category: 'conversion', event_label: 'signup_gate' });
}
function closeModal() {
  document.getElementById('gateModal').classList.remove('active');
}
document.getElementById('gateModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// Gate submission
function submitGate() {
  const email = document.getElementById('gateEmail').value;
  if (!email || !email.includes('@')) {
    document.getElementById('gateEmail').style.borderColor = '#dc2626';
    return;
  }
  const btn = document.querySelector('#planGate .generate-btn') ||
               document.querySelector('button[onclick="submitGate()"]');
  if (btn) { btn.textContent = 'Sending...'; btn.disabled = true; }

  fetch('/api/signup', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email: email, source: 'campaign-planner' })
  })
  .then(r => r.json())
  .then(d => {
    gtag && gtag('event', 'sign_up', { event_category: 'conversion', event_label: email });
    closeModal();
    const banner = document.createElement('div');
    banner.style.cssText = 'position:fixed;top:80px;left:50%;transform:translateX(-50%);background:#00c4a7;color:#0a0e1a;font-weight:700;padding:14px 28px;border-radius:12px;z-index:9999;font-size:15px;box-shadow:0 4px 24px rgba(0,196,167,0.3)';
    banner.textContent = '✅ Welcome! Check your inbox for your Pievra access link.';
    document.body.appendChild(banner);
    setTimeout(() => banner.remove(), 6000);
  })
  .catch(() => {
    closeModal();
    const banner = document.createElement('div');
    banner.style.cssText = 'position:fixed;top:80px;left:50%;transform:translateX(-50%);background:#00c4a7;color:#0a0e1a;font-weight:700;padding:14px 28px;border-radius:12px;z-index:9999;font-size:15px';
    banner.textContent = '✅ Registered! We will be in touch at ' + email;
    document.body.appendChild(banner);
    setTimeout(() => banner.remove(), 6000);
  });
}

// Track generate button
function trackEvent(name) {
  gtag && gtag('event', name, { event_category: 'engagement' });
}

// Protocol filter
function filterProto(btn, cat) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.protocol-card').forEach(card => {
    if (cat === 'all') {
      card.style.display = '';
    } else {
      const cats = card.dataset.cat || '';
      card.style.display = cats.includes(cat) ? '' : 'none';
    }
  });
}

// Sort agents - featured always stays pinned at top, standard list reorders
function sortAgents(val) {
  gtag && gtag('event', 'marketplace_sort', { event_category: 'engagement', event_label: val });
  // In production this would trigger an API call - for now show feedback
  const count = document.querySelector('.marketplace-count strong');
  if (count) count.textContent = '26 agents';
}

// Nav scroll effect
window.addEventListener('scroll', () => {
  const nav = document.querySelector('nav');
  nav.style.boxShadow = window.scrollY > 20 ? '0 2px 20px rgba(10,14,26,0.08)' : 'none';
});
</script>







