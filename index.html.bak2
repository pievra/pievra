<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Pievra",
  "url": "https://pievra.com",
  "description": "Protocol-neutral orchestration platform for programmatic AI campaigns across AdCP, UCP, ARTF, MCP and A2A.",
  "applicationCategory": "BusinessApplication",
