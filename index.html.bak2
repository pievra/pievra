<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-pill">
      <span class="dot"></span>
      Protocol-neutral - Open core - All five protocols
    </div>
    <h1>One campaign. <span class="accent">Five protocols.</span> Zero lock-in.</h1>
    <p class="hero-sub">Pievra orchestrates programmatic campaigns across AdCP, MCP, UCP, ARTF and A2A simultaneously. Free planning simulator, agent marketplace and protocol learning hub,master the stack before it goes mainstream.</p>
    <div class="hero-actions">
      <a href="#planner" class="btn-teal">🗺 Plan a Campaign (Free)</a>
      <a href="#learn" class="btn-outline">📚 Learn Protocols</a>
      <a href="https://github.com/pievra" target="_blank" class="btn-dark">⬡ View Source</a>
    </div>

    <div class="code-block">
      <pre><span class="cm">// Orchestrate across every protocol from one call</span>
<span class="kw">const</span> campaign = <span class="kw">new</span> <span class="fn">PievraSession</span>({
  protocols: [<span class="str">'AdCP'</span>, <span class="str">'MCP'</span>, <span class="str">'A2A'</span>, <span class="str">'UCP'</span>, <span class="str">'ARTF'</span>],
  budget: <span class="str">50000</span>,
  objective: <span class="str">'ROAS > 2.8'</span>,
});

<span class="kw">const</span> result = <span class="kw">await</span> campaign.<span class="fn">execute</span>();
<span class="cm">// → 8 agents activated across 3 protocols.</span></pre>
    </div>

    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">5</div><div class="stat-label">Protocols</div></div>
      <div class="stat-cell"><div class="stat-num">3</div><div class="stat-label">Open Repos</div></div>
      <div class="stat-cell"><div class="stat-num">Free</div><div class="stat-label">Early Access</div></div>
      <div class="stat-cell"><div class="stat-num">MIT</div><div class="stat-label">Licensed</div></div>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div class="trust-bar">
  <div class="trust-bar-inner">
