<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Pievra - Run AI Agent Campaigns Across Every Programmatic Protocol</title>
<meta name="description" content="Pievra connects media buyers, publishers and data providers through one platform. Plan, auction and execute AI-powered campaigns across AdCP, MCP, UCP, ARTF and A2A simultaneously."/>
<meta name="keywords" content="AI agent orchestration, programmatic advertising, AdCP, MCP, UCP, ARTF, A2A, agentic advertising, protocol orchestration, media buying AI"/>
<meta property="og:title" content="Pievra - Run AI Agent Campaigns Across Every Programmatic Protocol"/>
<meta property="og:description" content="One platform to plan, auction and execute AI-powered ad campaigns across all five agentic advertising protocols. For agencies, publishers and data providers."/>
<meta property="og:url" content="https://pievra.com"/>
<meta property="og:type" content="website"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="Pievra - Run AI Agent Campaigns Across Every Protocol"/>
<link rel="canonical" href="https://pievra.com"/>

<!-- GA4 Analytics - consent-gated (GDPR/CNIL compliant) -->
<script src="/static/consent.js"></script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
:root {
  --ink: #0a0e1a;
  --ink-soft: #3d4460;
  --ink-muted: #7a829e;
  --surface: #ffffff;
  --surface-2: #f4f5f9;
  --surface-3: #ebedf5;
  --teal: #00c4a7;
  --teal-dark: #009e86;
  --teal-light: #e0faf6;
  --coral: #ff5e3a;
  --navy: #0a0e1a;
  --blue: #2563eb;
  --border: #e2e4ed;
  --radius: 12px;
  --radius-lg: 20px;
  --shadow: 0 4px 24px rgba(10,14,26,0.08);
  --shadow-lg: 0 12px 48px rgba(10,14,26,0.14);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Inter', sans-serif;
  background: var(--surface);
  color: var(--ink);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

h1,h2,h3,h4,h5 { font-family: 'Manrope', sans-serif; line-height: 1.15; }

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  height: 64px;
}
.nav-inner {
  max-width: 1200px; margin: 0 auto; padding: 0 24px;
  height: 64px; display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
  display: flex; align-items: center; gap: 10px; text-decoration: none;
}
.logo-mark {
  width: 36px; height: 36px; background: var(--ink);
  border-radius: 10px; display: flex; align-items: center; justify-content: center;
  font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 18px; color: var(--teal);
  letter-spacing: -1px;
}
.logo-text { font-family: 'Manrope', sans-serif; font-weight: 700; font-size: 20px; color: var(--ink); }
.logo-badge {
  font-size: 10px; font-weight: 600; color: var(--teal-dark);
  background: var(--teal-light); border: 1px solid var(--teal);
  padding: 2px 8px; border-radius: 20px; letter-spacing: 0.5px;
}
.nav-links { display: flex; align-items: center; gap: 32px; }
.nav-links a {
  font-size: 14px; font-weight: 500; color: var(--ink-soft);
  text-decoration: none; transition: color 0.2s;
}
.nav-links a:hover { color: var(--ink); }
.nav-cta { display: flex; align-items: center; gap: 10px; }
.btn-ghost {
  padding: 8px 16px; font-size: 14px; font-weight: 500;
  color: var(--ink-soft); background: none; border: none; cursor: pointer;
  border-radius: 8px; transition: background 0.2s; font-family: 'Inter', sans-serif;
}
.btn-ghost:hover { background: var(--surface-2); }
.btn-primary {
  padding: 8px 20px; font-size: 14px; font-weight: 600;
  color: white; background: var(--ink); border: none; cursor: pointer;
  border-radius: 8px; transition: all 0.2s; font-family: 'Inter', sans-serif;
}
.btn-primary:hover { background: #1a2035; transform: translateY(-1px); }

/* ── HERO ── */
.hero {
  padding: 140px 24px 80px;
  background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(0,196,167,0.10) 0%, transparent 70%);
}
.hero-inner { max-width: 1200px; margin: 0 auto; text-align: center; }
.hero-pill {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 16px; border-radius: 20px;
  background: var(--surface-2); border: 1px solid var(--border);
  font-size: 13px; font-weight: 500; color: var(--ink-soft); margin-bottom: 32px;
}
.hero-pill .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--teal); animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.6;transform:scale(1.3)} }

.hero h1 {
  font-size: clamp(42px, 6vw, 80px); font-weight: 800;
  color: var(--ink); letter-spacing: -2px; margin-bottom: 24px;
}
.hero h1 .accent { color: var(--teal); }
.hero-sub {
  font-size: 18px; color: var(--ink-soft); max-width: 600px;
  margin: 0 auto 40px; font-weight: 400; line-height: 1.7;
}
.hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 64px; }
.btn-teal {
  padding: 14px 28px; background: var(--teal); color: white;
  font-family: 'Inter', sans-serif; font-weight: 600; font-size: 15px;
  border: none; border-radius: 10px; cursor: pointer; transition: all 0.2s; text-decoration: none;
  display: inline-flex; align-items: center; gap: 8px;
}
.btn-teal:hover { background: var(--teal-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,196,167,0.3); }
.btn-outline {
  padding: 14px 28px; background: transparent; color: var(--ink);
  font-family: 'Inter', sans-serif; font-weight: 600; font-size: 15px;
  border: 2px solid var(--border); border-radius: 10px; cursor: pointer; transition: all 0.2s; text-decoration: none;
  display: inline-flex; align-items: center; gap: 8px;
}
.btn-outline:hover { border-color: var(--ink); transform: translateY(-2px); }
.btn-dark {
  padding: 14px 28px; background: var(--ink); color: white;
  font-family: 'Inter', sans-serif; font-weight: 600; font-size: 15px;
  border: none; border-radius: 10px; cursor: pointer; transition: all 0.2s; text-decoration: none;
  display: inline-flex; align-items: center; gap: 8px;
}
.btn-dark:hover { background: #1a2035; transform: translateY(-2px); }

/* Code block */
.code-block {
  background: var(--ink); border-radius: var(--radius-lg);
  padding: 28px 32px; max-width: 640px; margin: 0 auto 56px;
  text-align: left; border: 1px solid #1e2540;
}
.code-block pre { font-family: 'JetBrains Mono', monospace; font-size: 13px; line-height: 1.8; color: #a8b0cc; overflow-x: auto; }
.code-block .kw { color: var(--teal); }
.code-block .str { color: #ffd580; }
.code-block .fn { color: #82aaff; }
.code-block .cm { color: #4a5270; font-style: italic; }

/* Stats */
.stats-row {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1px; background: var(--border);
  border: 1px solid var(--border); border-radius: var(--radius-lg);
  overflow: hidden; max-width: 800px; margin: 0 auto;
}
.stat-cell {
  background: white; padding: 28px 20px; text-align: center;
}
.stat-num { font-family: 'Manrope', sans-serif; font-size: 32px; font-weight: 800; color: var(--teal); margin-bottom: 4px; }
.stat-label { font-size: 13px; color: var(--ink-muted); font-weight: 500; }

/* Trust bar */
.trust-bar {
  background: var(--surface-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
  padding: 20px 24px;
}
.trust-bar-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: center; gap: 40px; flex-wrap: wrap; }
.trust-label { font-size: 11px; font-weight: 700; letter-spacing: 1.5px; color: var(--ink-muted); text-transform: uppercase; }
.trust-items { display: flex; align-items: center; gap: 32px; flex-wrap: wrap; }
.trust-item { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 600; color: var(--ink-muted); }
.trust-badge {
  width: 26px; height: 26px; border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 9px; font-weight: 900; color: white; letter-spacing: 0;
}

/* ── WHO IT'S FOR ── */
.section { padding: 96px 24px; }
.section-inner { max-width: 1200px; margin: 0 auto; }
.section-tag { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--teal); margin-bottom: 12px; }
.section-title { font-size: clamp(28px, 4vw, 46px); font-weight: 800; color: var(--ink); letter-spacing: -1.5px; margin-bottom: 16px; }
.section-sub { font-size: 17px; color: var(--ink-soft); max-width: 560px; line-height: 1.7; margin-bottom: 56px; }

.for-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.for-card {
  border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 32px; background: white; transition: all 0.25s;
  position: relative; overflow: hidden;
}
.for-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--teal); opacity: 0; transition: opacity 0.2s;
}
.for-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
.for-card:hover::before { opacity: 1; }
.for-icon { font-size: 36px; margin-bottom: 20px; display: block; }
.for-role { font-family: 'Manrope', sans-serif; font-size: 20px; font-weight: 700; color: var(--ink); margin-bottom: 12px; }
.for-desc { font-size: 14px; color: var(--ink-soft); line-height: 1.7; margin-bottom: 20px; }
.for-kpi {
  background: var(--teal-light); border: 1px solid var(--teal);
  border-radius: 8px; padding: 10px 14px;
  font-size: 13px; font-weight: 600; color: var(--teal-dark);
}
.for-kpi span { color: var(--ink-muted); font-weight: 400; }

/* How it works */
.how-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; position: relative; }
.how-steps::before {
  content: ''; position: absolute; top: 28px; left: 15%; right: 15%; height: 1px;
  background: linear-gradient(90deg, transparent, var(--teal), transparent);
}
.how-step { text-align: center; position: relative; }
.step-num {
  width: 56px; height: 56px; border-radius: 50%;
  background: var(--ink); color: var(--teal);
  font-family: 'Manrope', sans-serif; font-size: 22px; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20px; position: relative; z-index: 1;
}
.step-title { font-family: 'Manrope', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 10px; }
.step-desc { font-size: 14px; color: var(--ink-soft); line-height: 1.6; }

/* ── WHY PIEVRA ── */
.why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
.why-copy h2 { font-size: clamp(28px, 4vw, 44px); font-weight: 800; letter-spacing: -1.5px; margin-bottom: 20px; }
.why-copy p { font-size: 16px; color: var(--ink-soft); line-height: 1.8; margin-bottom: 28px; }
.prebid-box {
  background: var(--surface-2); border-left: 3px solid var(--teal);
  padding: 20px 24px; border-radius: 0 10px 10px 0;
}
.prebid-box strong { font-size: 13px; font-weight: 700; color: var(--ink); display: block; margin-bottom: 6px; }
.prebid-box p { font-size: 14px; color: var(--ink-soft); margin: 0; }
.moat-cards { display: grid; gap: 14px; }
.moat-card {
  background: white; border: 1px solid var(--border); border-radius: var(--radius);
  padding: 20px; display: flex; align-items: flex-start; gap: 16px; transition: box-shadow 0.2s;
}
.moat-card:hover { box-shadow: var(--shadow); }
.moat-tag {
  font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; white-space: nowrap;
}
.moat-tag.hard { background: #fef2f2; color: #b91c1c; }
.moat-tag.grow { background: var(--teal-light); color: var(--teal-dark); }
.moat-info h4 { font-family: 'Manrope', sans-serif; font-size: 15px; font-weight: 700; margin-bottom: 4px; }
.moat-info p { font-size: 13px; color: var(--ink-soft); line-height: 1.5; }

/* ── CAMPAIGN PLANNER ── */
#planner { background: var(--surface-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.planner-form {
  background: white; border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 40px; box-shadow: var(--shadow);
}
.form-step { margin-bottom: 36px; }
.step-label {
  font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
  color: var(--ink-muted); margin-bottom: 16px; padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.form-col { display: flex; flex-direction: column; gap: 6px; }
label { font-size: 13px; font-weight: 600; color: var(--ink); }
label .hint { font-weight: 400; color: var(--ink-muted); }
input[type=text], input[type=email], select, textarea {
  width: 100%; padding: 11px 14px; border: 1.5px solid var(--border);
  border-radius: 8px; font-size: 14px; font-family: 'Inter', sans-serif;
  color: var(--ink); background: white; transition: border-color 0.2s;
  outline: none;
}
input:focus, select:focus, textarea:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(0,196,167,0.12); }
textarea { resize: vertical; min-height: 80px; }
.btn-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; }
.btn-grid-5 { display: grid; grid-template-columns: repeat(5,1fr); gap: 8px; }
.btn-grid-3 { display: flex; gap: 8px; }
.toggle-btn {
  padding: 10px 8px; border: 1.5px solid var(--border); border-radius: 8px;
  background: white; font-size: 13px; font-family: 'Inter', sans-serif;
  font-weight: 600; cursor: pointer; transition: all 0.18s; text-align: left;
  color: var(--ink-soft);
}
.toggle-btn.active { background: var(--ink); color: white; border-color: var(--ink); }
.toggle-btn .sub { display: block; font-size: 11px; font-weight: 400; opacity: 0.7; margin-top: 2px; }
.interests { display: flex; flex-wrap: wrap; gap: 8px; }
.interest-tag {
  padding: 6px 14px; border: 1.5px solid var(--border); border-radius: 20px;
  font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s;
  background: white; color: var(--ink-soft); font-family: 'Inter', sans-serif;
}
.interest-tag.active { background: var(--ink); color: white; border-color: var(--ink); }
.env-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; }
.env-btn {
  padding: 10px 12px; border: 1.5px solid var(--border); border-radius: 8px;
  background: white; font-size: 13px; font-family: 'Inter', sans-serif;
  font-weight: 500; cursor: pointer; transition: all 0.18s; text-align: left;
  color: var(--ink-soft);
}
.env-btn.active { background: var(--teal-light); border-color: var(--teal); color: var(--teal-dark); }

/* Gate overlay */
.planner-gate {
  position: relative;
}
.gate-overlay {
  position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 30%, rgba(244,245,249,0.97) 65%);
  border-radius: var(--radius-lg); display: flex; align-items: flex-end; justify-content: center;
  padding-bottom: 48px; z-index: 10;
}
.gate-box {
  background: white; border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 32px 40px; text-align: center; max-width: 440px;
  box-shadow: var(--shadow-lg);
}
.gate-box h3 { font-family: 'Manrope', sans-serif; font-size: 22px; font-weight: 700; margin-bottom: 8px; }
.gate-box p { font-size: 14px; color: var(--ink-soft); margin-bottom: 24px; }
.gate-input-row { display: flex; gap: 10px; margin-bottom: 12px; }
.gate-input-row input { flex: 1; }
.gate-note { font-size: 12px; color: var(--ink-muted); }

.generate-btn {
  width: 100%; padding: 16px; background: var(--ink); color: white;
  font-family: 'Manrope', sans-serif; font-weight: 700; font-size: 16px;
  border: none; border-radius: 10px; cursor: pointer; transition: all 0.2s; margin-top: 8px;
}
.generate-btn:hover { background: #1a2035; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(10,14,26,0.2); }

/* ── PROTOCOLS ── */
.protocols-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 20px; }
.protocol-card {
  background: white; border: 1px solid var(--border); border-radius: var(--radius-lg);
  overflow: hidden; transition: all 0.2s;
}
.protocol-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-2px); }
.protocol-head { padding: 24px; border-bottom: 1px solid var(--border); }
.protocol-title-row { display: flex; align-items: center; gap: 14px; margin-bottom: 12px; }
.protocol-icon { font-size: 28px; }
.protocol-name { font-family: 'Manrope', sans-serif; font-size: 18px; font-weight: 700; }
.protocol-ver { font-size: 12px; color: var(--ink-muted); }
.badge-live { background: #dcfce7; color: #166534; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 20px; }
.badge-beta { background: #fef9c3; color: #854d0e; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 20px; }
.protocol-desc { font-size: 14px; color: var(--ink-soft); line-height: 1.6; margin-bottom: 12px; }
.protocol-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.ptag { background: var(--surface-2); font-size: 11px; padding: 3px 10px; border-radius: 20px; color: var(--ink-soft); font-weight: 500; }
.protocol-steward { font-size: 12px; color: var(--ink-muted); margin-top: 10px; }
.protocol-foot {
  padding: 14px 24px; background: var(--surface-2);
  display: flex; align-items: center; justify-content: space-between;
  font-size: 13px; font-weight: 600; color: var(--ink-soft); cursor: pointer;
}
.protocol-foot:hover { color: var(--ink); }

/* Filter bar */
.filter-bar { display: flex; gap: 10px; margin-bottom: 40px; flex-wrap: wrap; }
.filter-btn {
  padding: 8px 20px; border-radius: 8px; border: 1.5px solid var(--border);
  background: white; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.15s;
  font-family: 'Inter', sans-serif; color: var(--ink-soft);
}
.filter-btn.active { background: var(--ink); color: white; border-color: var(--ink); }

/* ── MARKETPLACE ── */
.marketplace-section { background: var(--surface-2); border-top: 1px solid var(--border); }
.marketplace-preview { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-bottom: 40px; }
.agent-card {
  background: white; border: 1px solid var(--border); border-radius: var(--radius);
  padding: 20px; transition: all 0.2s;
}
.agent-card:hover { box-shadow: var(--shadow); border-color: var(--teal); }
.agent-head { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 12px; }
.agent-name { font-family: 'Manrope', sans-serif; font-size: 15px; font-weight: 700; }
.agent-score { font-size: 20px; font-weight: 800; font-family: 'Manrope', sans-serif; color: var(--teal); }
.agent-desc { font-size: 13px; color: var(--ink-soft); margin-bottom: 14px; line-height: 1.5; }
.agent-meta { display: flex; gap: 8px; flex-wrap: wrap; }
.agent-tag { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; background: var(--teal-light); color: var(--teal-dark); }

/* List your agent */
.list-agent-section {
  background: var(--ink); color: white;
  padding: 80px 24px;
}
.list-agent-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
.list-agent-copy h2 { font-size: clamp(28px, 3.5vw, 44px); font-weight: 800; color: white; margin-bottom: 16px; letter-spacing: -1.5px; }
.list-agent-copy p { color: #8892b0; font-size: 16px; line-height: 1.8; margin-bottom: 32px; }
.list-steps { display: flex; flex-direction: column; gap: 28px; }
.list-step { display: flex; gap: 20px; }
.step-circle {
  width: 44px; height: 44px; border-radius: 50%; background: rgba(0,196,167,0.15);
  color: var(--teal); font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 18px;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.list-step h4 { font-family: 'Manrope', sans-serif; font-size: 16px; font-weight: 700; color: white; margin-bottom: 4px; }
.list-step p { font-size: 14px; color: #8892b0; }

/* ── PRICING ── */
.pricing-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; max-width: 1000px; margin: 0 auto; }
.price-card {
  border: 1.5px solid var(--border); border-radius: var(--radius-lg);
  padding: 36px; background: white; transition: all 0.2s; position: relative;
}
.price-card.featured {
  border-color: var(--teal); background: var(--ink);
  transform: scale(1.04);
  box-shadow: 0 20px 60px rgba(0,196,167,0.2);
}
.price-popular {
  position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
  background: var(--teal); color: white; font-size: 11px; font-weight: 700;
  padding: 4px 14px; border-radius: 20px; white-space: nowrap;
}
.price-name { font-family: 'Manrope', sans-serif; font-size: 22px; font-weight: 700; margin-bottom: 6px; }
.price-desc { font-size: 14px; color: var(--ink-muted); margin-bottom: 28px; }
.featured .price-desc { color: #8892b0; }
.price-amount { margin-bottom: 28px; }
.price-amount .num { font-family: 'Manrope', sans-serif; font-size: 48px; font-weight: 800; letter-spacing: -2px; }
.price-amount .per { font-size: 16px; color: var(--ink-muted); margin-left: 4px; }
.featured .price-amount .per { color: #8892b0; }
.price-roi {
  background: var(--teal-light); border: 1px solid var(--teal);
  border-radius: 8px; padding: 10px 14px; margin-bottom: 24px;
  font-size: 13px; font-weight: 600; color: var(--teal-dark);
}
.featured .price-roi { background: rgba(0,196,167,0.15); color: var(--teal); }
.price-cta {
  width: 100%; padding: 14px; border-radius: 10px;
  font-family: 'Manrope', sans-serif; font-weight: 700; font-size: 15px;
  cursor: pointer; transition: all 0.2s; border: none; margin-bottom: 28px;
}
.price-cta.light { background: var(--surface-2); color: var(--ink); }
.price-cta.light:hover { background: var(--surface-3); }
.price-cta.teal { background: var(--teal); color: white; }
.price-cta.teal:hover { background: var(--teal-dark); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,196,167,0.3); }
.price-features { list-style: none; display: flex; flex-direction: column; gap: 12px; }
.price-features li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; }
.check { color: var(--teal); font-size: 16px; flex-shrink: 0; margin-top: 1px; }
.featured .price-features li { color: #ccd6f6; }

/* Transaction note */
.txn-note {
  background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius);
  padding: 20px 28px; text-align: center; margin-top: 40px; max-width: 700px; margin-left: auto; margin-right: auto;
}
.txn-note p { font-size: 14px; color: var(--ink-soft); }
.txn-note strong { color: var(--ink); }

/* ── COMMUNITY ── */
.community-section { background: var(--ink); color: white; }
.repos-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-bottom: 56px; }
.repo-card {
  background: #111827; border: 1px solid #1e2540; border-radius: var(--radius);
  padding: 24px; transition: all 0.2s; text-decoration: none;
}
.repo-card:hover { border-color: var(--teal); transform: translateY(-2px); }
.repo-card h3 { font-family: 'Manrope', sans-serif; font-size: 16px; font-weight: 700; color: white; margin-bottom: 8px; }
.repo-card p { font-size: 13px; color: #8892b0; line-height: 1.5; margin-bottom: 16px; }
.repo-stats { display: flex; gap: 16px; font-size: 12px; color: #4a5270; }
.repo-stats span { display: flex; align-items: center; gap: 4px; }

/* Agent leaderboard section */
.leaderboard-teaser {
  background: #111827; border: 1px solid #1e2540; border-radius: var(--radius-lg);
  padding: 32px; margin-top: 32px;
}
.leaderboard-teaser h3 { font-family: 'Manrope', sans-serif; font-size: 20px; font-weight: 700; color: white; margin-bottom: 8px; }
.leaderboard-teaser p { font-size: 14px; color: #8892b0; margin-bottom: 20px; }
.leaderboard-row {
  display: grid; grid-template-columns: 40px 1fr 80px 80px 80px;
  gap: 16px; align-items: center; padding: 12px 0; border-bottom: 1px solid #1e2540;
  font-size: 13px;
}
.leaderboard-row.head { color: #4a5270; font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }
.rank { font-family: 'Manrope', sans-serif; font-weight: 800; color: var(--teal); }
.agent-n { color: white; font-weight: 600; }
.metric { color: #8892b0; text-align: right; }
.metric.good { color: var(--teal); font-weight: 700; }

/* ── CTA BANNER ── */
.cta-banner {
  background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(0,196,167,0.08) 0%, transparent 70%),
              var(--ink);
  border-top: 1px solid #1e2540; border-bottom: 1px solid #1e2540;
  padding: 96px 24px; text-align: center;
}
.cta-banner h2 { font-size: clamp(28px, 4vw, 52px); font-weight: 800; color: white; letter-spacing: -2px; margin-bottom: 20px; }
.cta-banner p { font-size: 18px; color: #8892b0; max-width: 500px; margin: 0 auto 40px; }

/* ── FOOTER ── */
footer {
  background: #060810; color: #4a5270;
  border-top: 1px solid #0e1220; padding: 64px 24px 40px;
}
.footer-inner { max-width: 1200px; margin: 0 auto; }
.footer-top { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
.footer-brand p { font-size: 13px; color: #4a5270; line-height: 1.7; margin-top: 12px; max-width: 220px; }
.footer-col h4 { font-size: 13px; font-weight: 700; color: #8892b0; margin-bottom: 16px; letter-spacing: 0.5px; }
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.footer-col ul li a { font-size: 13px; color: #4a5270; text-decoration: none; transition: color 0.2s; }
.footer-col ul li a:hover { color: var(--teal); }
.footer-bottom {
  border-top: 1px solid #0e1220; padding-top: 28px;
  display: flex; justify-content: space-between; align-items: center;
}
.footer-bottom p { font-size: 13px; }
.octopus-tag { color: var(--teal); font-style: italic; }

/* ── MODAL for gate ── */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(10,14,26,0.7); z-index: 1000;
  display: flex; align-items: center; justify-content: center; padding: 24px;
  backdrop-filter: blur(4px);
  opacity: 0; pointer-events: none; transition: opacity 0.25s;
}
.modal-overlay.active { opacity: 1; pointer-events: all; }
.modal-box {
  background: white; border-radius: var(--radius-lg); padding: 48px;
  max-width: 480px; width: 100%; box-shadow: var(--shadow-lg);
  transform: translateY(20px); transition: transform 0.25s;
}
.modal-overlay.active .modal-box { transform: translateY(0); }
.modal-box h2 { font-family: 'Manrope', sans-serif; font-size: 26px; font-weight: 800; margin-bottom: 8px; }
.modal-box p { font-size: 15px; color: var(--ink-soft); margin-bottom: 28px; line-height: 1.7; }
.modal-box input { margin-bottom: 12px; }
.modal-close { position: absolute; top: 20px; right: 20px; background: none; border: none; font-size: 24px; cursor: pointer; color: var(--ink-muted); }

/* ── FEATURED / PREMIUM AGENT PLACEMENTS ── */
.featured-banner {
  background: linear-gradient(135deg, #0a0e1a 0%, #0f1829 100%);
  border: 1.5px solid var(--teal);
  border-radius: var(--radius-lg);
  padding: 20px 24px;
  margin-bottom: 28px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 16px;
}
.featured-banner-label {
  display: flex; align-items: center; gap: 10px;
  font-size: 12px; font-weight: 700; color: var(--teal);
  letter-spacing: 1.5px; text-transform: uppercase;
}
.featured-banner-label::before {
  content: '★'; font-size: 14px;
}
.featured-banner p {
  font-size: 13px; color: #8892b0; margin: 0;
}
.featured-banner a {
  font-size: 13px; font-weight: 600; color: var(--teal);
  text-decoration: none; white-space: nowrap; border: 1px solid var(--teal);
  padding: 6px 16px; border-radius: 6px; transition: all 0.2s;
}
.featured-banner a:hover { background: var(--teal); color: white; }

.agent-card.premium {
  border: 1.5px solid var(--teal);
  background: linear-gradient(135deg, #ffffff 0%, #f0fdf9 100%);
  position: relative;
  box-shadow: 0 4px 20px rgba(0,196,167,0.12);
}
.agent-card.premium::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--teal), #00e5c4);
  border-radius: var(--radius) var(--radius) 0 0;
}
.premium-badge {
  display: inline-flex; align-items: center; gap: 5px;
  background: var(--ink); color: var(--teal);
  font-size: 10px; font-weight: 700; letter-spacing: 1px;
  text-transform: uppercase; padding: 3px 10px; border-radius: 20px;
  margin-bottom: 10px;
}
.premium-badge::before { content: '★'; font-size: 10px; }

/* ── NEW PROTOCOL BADGE ── */
.badge-new {
  background: linear-gradient(135deg, #7c3aed, #a855f7);
  color: white; font-size: 10px; font-weight: 800;
  padding: 2px 8px; border-radius: 20px;
  letter-spacing: 0.5px; text-transform: uppercase;
  animation: shimmer 2.5s ease-in-out infinite;
}
@keyframes shimmer {
  0%,100% { opacity: 1; }
  50% { opacity: 0.75; }
}

/* SEO section hidden from display, visible to crawlers */
.seo-text { position: absolute; left: -9999px; }

/* Marketplace sort bar */.marketplace-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20px; flex-wrap: wrap; gap: 12px;
}
.marketplace-sort {
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; color: var(--ink-muted);
}
.marketplace-sort select {
  padding: 6px 12px; border: 1.5px solid var(--border); border-radius: 8px;
  font-size: 13px; font-family: 'Inter', sans-serif; color: var(--ink);
  background: white; cursor: pointer; width: auto;
}
.marketplace-count {
  font-size: 13px; color: var(--ink-muted);
}
.marketplace-count strong { color: var(--ink); }

/* Responsive */
@media (max-width: 900px) {
  .for-cards, .how-steps, .why-grid, .protocols-grid,
  .marketplace-preview, .pricing-grid, .repos-grid,
  .list-agent-inner, .footer-top { grid-template-columns: 1fr; }

  .price-card.featured { transform: none; }
  .nav-links { display: none; }
  .stats-row { grid-template-columns: repeat(2,1fr); }
  .how-steps::before { display: none; }
}
</style>
<script src="/static/pievra_widgets.js"></script>
</head>
