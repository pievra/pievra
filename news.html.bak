          <div class="pr-title">Agentic Audiences <span class="badge-new" style="font-size:9px;padding:1px 7px">NEW</span></div>
          <div class="pr-sub s-beta">● Open source · IAB Tech Lab · Nov 2025</div>
        </div>
      </div>
      <div class="proto-row" onclick="filterArticles(null,'artf')">
        <div class="pr-icon" style="background:#fce7f3">🎨</div>
        <div>
          <div class="pr-title">ARTF v1.0 <span class="badge-new" style="font-size:9px;padding:1px 7px">NEW</span></div>
          <div class="pr-sub s-rc">● Public comment · IAB Tech Lab · Nov 2025</div>
        </div>
      </div>
      <div class="proto-row" onclick="filterArticles(null,'a2a')">
        <div class="pr-icon" style="background:#ede9fe">🤝</div>
        <div>
          <div class="pr-title">A2A <span style="font-size:9px;background:#ede9fe;color:#5b21b6;padding:1px 7px;border-radius:10px;font-weight:700">v0.3</span></div>
          <div class="pr-sub s-live">● Live · Linux Foundation · Apr 2025</div>
        </div>
      </div>
    </div>
  </div>

  <div class="nl-card">
    <h3>📬 Protocol Intelligence Weekly</h3>
    <p>Every Tuesday - protocol updates, integration guides, benchmarks. 2,400+ subscribers. Free.</p>
    <input class="nl-input" type="email" id="nl-email" placeholder="Your work email"/>
    <button class="btn-nl" onclick="subNewsletter()">Subscribe Free →</button>
    <p style="font-size:10px;color:#4a5270;margin-top:6px;text-align:center">Unsubscribe anytime · No spam</p>
  </div>

  <div class="tl-card">
    <div class="sb-head" style="padding:14px 16px"><h3>2025–2026 Timeline</h3></div>
    <div class="tl-item"><div class="tl-dot"></div><div><div class="tl-date">Nov 2024</div><div class="tl-text">Anthropic launches MCP</div></div></div>
    <div class="tl-item"><div class="tl-dot"></div><div><div class="tl-date">Mar 26 2025</div><div class="tl-text">MCP major update · OpenAI adopts</div></div></div>
    <div class="tl-item"><div class="tl-dot"></div><div><div class="tl-date">Apr 9 2025</div><div class="tl-text">Google launches A2A - 50+ partners</div></div></div>
    <div class="tl-item"><div class="tl-dot"></div><div><div class="tl-date">Jun 2025</div><div class="tl-text">A2A & MCP donated to Linux Foundation</div></div></div>
    <div class="tl-item"><div class="tl-dot"></div><div><div class="tl-date">Jun 18 2025</div><div class="tl-text">MCP spec update - OAuth 2.1</div></div></div>
    <div class="tl-item"><div class="tl-dot"></div><div><div class="tl-date">Jul 31 2025</div><div class="tl-text">A2A v0.3 - gRPC + signed Agent Cards</div></div></div>
    <div class="tl-item"><div class="tl-dot"></div><div><div class="tl-date">Oct 15 2025</div><div class="tl-text">AdCP v2.0 launched - 20+ companies</div></div></div>
    <div class="tl-item"><div class="tl-dot"></div><div><div class="tl-date">Nov 3 2025</div><div class="tl-text">LiveRamp donates UCP to IAB Tech Lab</div></div></div>
    <div class="tl-item"><div class="tl-dot"></div><div><div class="tl-date">Nov 13 2025</div><div class="tl-text">ARTF v1.0 for public comment</div></div></div>
    <div class="tl-item"><div class="tl-dot"></div><div><div class="tl-date">Nov 25 2025</div><div class="tl-text">MCP spec 2025-11-25 - async execution</div></div></div>
    <div class="tl-item"><div class="tl-dot"></div><div><div class="tl-date">Dec 2025</div><div class="tl-text">MCP → Linux Foundation AAIF</div></div></div>
    <div class="tl-item"><div class="tl-dot" style="background:#7c3aed"></div><div><div class="tl-date" style="color:#7c3aed">Feb 26 2026</div><div class="tl-text">IAB Tech Lab names initiative AAMP</div></div></div>
    <div class="tl-item"><div class="tl-dot" style="background:#4a5270"></div><div><div class="tl-date" style="color:#4a5270">2026 roadmap</div><div class="tl-text">ARTF finalised · AAMP Agent Registry · AdCP v3.0</div></div></div>
  </div>
</aside>
</div>

<footer>
  <p>© 2025 Pievra · <a href="/">Home</a> · <a href="/news">News</a> · <a href="/terms">Terms</a> · <a href="/privacy">Privacy & GDPR</a></p>
  <p style="margin-top:6px;font-size:11px;color:#2a2f45">All protocol information sourced from official specifications, verified press releases, and primary sources. Last updated: March 2026.</p>
</footer>

<script>
const protos = ['adcp','mcp','ucp','artf','a2a'];
let loggedIn = false, user = null;
const counts = {};
protos.forEach(p => counts[p] = 0);

function openModal() { document.getElementById('signupModal').classList.add('active'); }
function closeModal() { document.getElementById('signupModal').classList.remove('active'); }
document.getElementById('signupModal').addEventListener('click', e => { if (e.target.id === 'signupModal') closeModal(); });

function submitSignup() {
  const e = document.getElementById('mEmail').value;
  const n = document.getElementById('mName').value.trim();
  if (!e || !e.includes('@') || !n) { alert('Please enter your name and a valid work email.'); return; }
  login(n, e); closeModal();
}
function doLogin() {
  const n = prompt('Enter your name to sign in:');
  if (n && n.trim()) login(n.trim(), 'user@example.com');
}
function login(name, email) {
  loggedIn = true;
  user = { name, email, initials: name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2) };
  protos.forEach(p => unlockComments(p, true));
}

function unlockComments(p, silent) {
  if (!loggedIn) { if (!silent) openModal(); return; }
  const g = document.getElementById('gate-'+p);
  const f = document.getElementById('form-'+p);
  if (g) g.style.display = 'none';
  if (f) f.classList.add('active');
}

function upChar(p) {
  const ta = document.getElementById('ta-'+p);
  const ch = document.getElementById('ch-'+p);
  if (ta && ch) ch.textContent = ta.value.length + ' / 500';
}

function postComment(p) {
  if (!loggedIn) { openModal(); return; }
  const ta = document.getElementById('ta-'+p);
  if (!ta || !ta.value.trim()) return;
  const text = ta.value.trim().slice(0, 500);
  const list = document.getElementById('list-'+p);
  const empty = list.querySelector('.empty-c');
  if (empty) empty.remove();
  const cols = ['#0a0e1a','#065f46','#1d4ed8','#9d174d','#5b21b6','#7c3aed','#0369a1','#9a3412'];
  const col = cols[Math.floor(Math.random()*cols.length)];
  const now = new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'}) + ' today';
  const el = document.createElement('div');
  el.className = 'comment';
  el.innerHTML = `<div class="c-av" style="background:${col}">${xss(user.initials)}</div><div class="c-bubble"><div class="c-meta"><span class="c-name">${xss(user.name)}</span><span class="c-role">Pievra Community</span><span class="c-time">${now}</span></div><div class="c-text">${xss(text)}</div><div class="c-actions"><button class="c-btn" onclick="like(this)">👍 0</button></div></div>`;
  list.appendChild(el);
  ta.value = ''; upChar(p);
  counts[p]++;
  const cnt = document.getElementById('cnt-'+p);
  if (cnt) cnt.textContent = counts[p] + ' comment' + (counts[p]!==1?'s':'');
  gtag && gtag('event','comment_posted',{event_category:'community',event_label:p});
}

function like(btn) {
  if (!loggedIn) { openModal(); return; }
  const m = btn.textContent.match(/\d+/);
  if (m) btn.textContent = '👍 '+(parseInt(m[0])+1);
}

function xss(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function toggleArticle(btn, id) {
  const b = document.getElementById(id);
  const open = b.classList.contains('open');
  b.classList.toggle('open', !open);
  btn.classList.toggle('open', !open);
  btn.innerHTML = open ? 'Read full analysis <span class="arr">›</span>' : 'Collapse <span class="arr" style="transform:rotate(90deg);display:inline-block">›</span>';
  if (!open) gtag && gtag('event','article_expand',{event_category:'engagement',event_label:id});
}

function filterArticles(btn, proto) {
  if (btn) { document.querySelectorAll('.nf').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); }
  document.querySelectorAll('.article-card').forEach(c => { c.style.display=(proto==='all'||c.dataset.proto===proto)?'':'none'; });
}

function subNewsletter() {
  const i = document.getElementById('nl-email');
  if (!i||!i.value||!i.value.includes('@')) { if(i) i.style.outline='2px solid #ef4444'; return; }
  i.style.outline='2px solid #22c55e';
  document.querySelector('.btn-nl').textContent='✓ Subscribed!';
  gtag && gtag('event','newsletter_subscribe',{event_category:'conversion'});
}
</script>
</body>
</html>
