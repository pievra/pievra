<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Protocol Intelligence - Pievra News</title>
<meta name="description" content="In-depth analysis of every AI agent protocol shaping programmatic advertising in 2025 - AdCP, MCP, UCP/Agentic Audiences, ARTF and A2A. Real launch dates, correct versions, verified facts."/>
<link rel="canonical" href="https://pievra.com/news"/>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<!-- GA4 Analytics - consent-gated (GDPR/CNIL compliant) -->
<script src="/static/consent.js"></script>
<style>
:root{--ink:#0a0e1a;--ink-soft:#3d4460;--ink-muted:#7a829e;--surface:#ffffff;--surface-2:#f4f5f9;--teal:#00c4a7;--teal-dark:#009e86;--teal-light:#e0faf6;--border:#e2e4ed;--radius:12px;--radius-lg:20px;--shadow:0 4px 24px rgba(10,14,26,0.07);--shadow-lg:0 12px 48px rgba(10,14,26,0.13)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--surface);color:var(--ink);line-height:1.7;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4,h5{font-family:'Manrope',sans-serif;line-height:1.2}
nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,0.95);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);height:64px;display:flex;align-items:center;padding:0 32px;justify-content:space-between}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.logo-mark{width:34px;height:34px;background:var(--ink);border-radius:9px;display:flex;align-items:center;justify-content:center;font-family:'Manrope',sans-serif;font-weight:800;font-size:17px;color:var(--teal)}
.logo-text{font-family:'Manrope',sans-serif;font-weight:700;font-size:19px;color:var(--ink)}
.nav-links{display:flex;align-items:center;gap:28px}
.nav-links a{font-size:14px;font-weight:500;color:var(--ink-soft);text-decoration:none;transition:color .2s}
.nav-links a:hover,.nav-links a.active{color:var(--teal)}
.nav-right{display:flex;align-items:center;gap:10px}
.btn-ghost{padding:7px 16px;font-size:13px;font-weight:500;color:var(--ink-soft);background:none;border:1px solid var(--border);cursor:pointer;border-radius:7px;font-family:'Inter',sans-serif;transition:background .2s}
.btn-ghost:hover{background:var(--surface-2)}
.btn-primary{padding:7px 18px;font-size:13px;font-weight:600;color:white;background:var(--ink);border:none;cursor:pointer;border-radius:7px;font-family:'Inter',sans-serif;transition:all .2s}
.btn-primary:hover{background:#1a2035}
.news-hero{background:var(--ink);padding:80px 32px 64px;text-align:center}
.section-tag{font-size:11px;font-weight:700;letter-spacing:2px;color:var(--teal);text-transform:uppercase;margin-bottom:16px}
.news-hero h1{font-size:clamp(36px,5vw,60px);font-weight:800;color:white;letter-spacing:-2px;margin-bottom:16px}
.news-hero p{font-size:17px;color:#8892b0;max-width:600px;margin:0 auto 32px;line-height:1.7}
.news-filters{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.nf{padding:8px 18px;border-radius:8px;border:1.5px solid rgba(255,255,255,0.15);background:transparent;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;font-family:'Inter',sans-serif;color:#8892b0}
.nf.active,.nf:hover{background:var(--teal);color:white;border-color:var(--teal)}
.news-layout{max-width:1200px;margin:0 auto;padding:64px 32px;display:grid;grid-template-columns:1fr 300px;gap:56px;align-items:start}
.article-card{border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;background:white;margin-bottom:32px;transition:box-shadow .2s}
.article-card:hover{box-shadow:var(--shadow-lg)}
.article-header{padding:32px 32px 24px}
.meta-row{display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap}
.pb{font-size:11px;font-weight:700;padding:3px 12px;border-radius:20px;letter-spacing:.5px;text-transform:uppercase}
.pb-adcp{background:#dbeafe;color:#1d4ed8}
.pb-mcp{background:#d1fae5;color:#065f46}
.pb-ucp{background:#fef3c7;color:#92400e}
.pb-artf{background:#fce7f3;color:#9d174d}
.pb-a2a{background:#ede9fe;color:#5b21b6}
.badge-new{background:linear-gradient(135deg,#7c3aed,#a855f7);color:white;font-size:10px;font-weight:800;padding:3px 10px;border-radius:20px;letter-spacing:.5px;animation:shim 2.5s ease-in-out infinite}
@keyframes shim{0%,100%{opacity:1}50%{opacity:.75}}
.art-date{font-size:12px;color:var(--ink-muted)}
.article-title{font-size:21px;font-weight:800;color:var(--ink);letter-spacing:-.5px;margin-bottom:10px}
.article-excerpt{font-size:15px;color:var(--ink-soft);line-height:1.7;margin-bottom:12px}
.source-line{font-size:12px;color:var(--ink-muted);margin-bottom:18px}
.source-line a{color:var(--teal);text-decoration:none}
.source-line a:hover{text-decoration:underline}
.expand-btn{display:flex;align-items:center;gap:8px;font-size:14px;font-weight:600;color:var(--teal);background:none;border:none;cursor:pointer;font-family:'Inter',sans-serif;padding:0;transition:gap .2s}
.expand-btn:hover{gap:12px}
.expand-btn .arr{transition:transform .25s;display:inline-block}
.expand-btn.open .arr{transform:rotate(90deg)}
.article-body{display:none;padding:0 32px 32px;border-top:1px solid var(--border)}
.article-body.open{display:block}
.article-body h3{font-size:17px;font-weight:700;color:var(--ink);margin:28px 0 10px}
.article-body h3:first-child{margin-top:28px}
.article-body p{font-size:15px;color:var(--ink-soft);margin-bottom:14px;line-height:1.8}
.article-body ul,.article-body ol{margin:0 0 16px 22px}
.article-body li{font-size:15px;color:var(--ink-soft);margin-bottom:7px;line-height:1.6}
.article-body strong{color:var(--ink);font-weight:600}
.article-body a{color:var(--teal);text-decoration:none}
.article-body a:hover{text-decoration:underline}
.article-body code{font-family:'JetBrains Mono',monospace;background:var(--surface-2);padding:2px 7px;border-radius:4px;font-size:13px;color:var(--teal-dark)}
.fact-box{background:var(--surface-2);border-left:3px solid var(--teal);border-radius:0 var(--radius) var(--radius) 0;padding:14px 18px;margin:0 0 20px}
.fact-box p{margin:0;font-size:13px;color:var(--ink-soft);line-height:1.7}
.fact-box strong{color:var(--ink)}
.pc{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:18px 0}
.pros{background:#f0fdf4;border:1px solid #86efac;border-radius:var(--radius);padding:16px 18px}
.cons{background:#fef2f2;border:1px solid #fca5a5;border-radius:var(--radius);padding:16px 18px}
.pros h4{font-family:'Manrope',sans-serif;font-size:13px;font-weight:700;color:#15803d;margin-bottom:8px}
.cons h4{font-family:'Manrope',sans-serif;font-size:13px;font-weight:700;color:#b91c1c;margin-bottom:8px}
.pros li,.cons li{font-size:13px;color:var(--ink-soft);margin-bottom:5px}
.use-box{background:var(--surface-2);border-radius:var(--radius);padding:14px 18px;margin:14px 0}
.use-box h4{font-family:'Manrope',sans-serif;font-size:13px;font-weight:700;color:var(--ink);margin-bottom:8px}
/* Comments */
.comments-section{border-top:1px solid var(--border);padding:24px 32px;background:var(--surface-2)}
.comments-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.comments-header h4{font-family:'Manrope',sans-serif;font-size:15px;font-weight:700;color:var(--ink)}
.c-count{font-size:12px;color:var(--ink-muted);background:white;border:1px solid var(--border);padding:2px 10px;border-radius:20px}
.empty-c{text-align:center;padding:24px 16px;background:white;border:1px solid var(--border);border-radius:var(--radius);margin-bottom:16px}
.empty-c .ei{font-size:28px;margin-bottom:8px}
.empty-c h5{font-family:'Manrope',sans-serif;font-size:14px;font-weight:700;color:var(--ink);margin-bottom:4px}
.empty-c p{font-size:13px;color:var(--ink-muted);margin:0}
.comment{display:flex;gap:12px;margin-bottom:16px}
.c-av{width:34px;height:34px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;color:white;font-family:'Manrope',sans-serif}
.c-bubble{flex:1;background:white;border:1px solid var(--border);border-radius:10px;padding:10px 14px}
.c-meta{display:flex;align-items:center;gap:8px;margin-bottom:5px;flex-wrap:wrap}
.c-name{font-size:13px;font-weight:700;color:var(--ink)}
.c-role{font-size:11px;color:var(--ink-muted);background:var(--surface-2);padding:1px 8px;border-radius:20px}
.c-time{font-size:11px;color:var(--ink-muted);margin-left:auto}
.c-text{font-size:14px;color:var(--ink-soft);line-height:1.6}
.c-actions{display:flex;gap:10px;margin-top:6px}
.c-btn{font-size:12px;color:var(--ink-muted);background:none;border:none;cursor:pointer;font-family:'Inter',sans-serif;padding:2px 0;transition:color .15s}
.c-btn:hover{color:var(--teal)}
.c-gate{background:white;border:1.5px dashed var(--border);border-radius:var(--radius);padding:20px;text-align:center}
.c-gate h4{font-family:'Manrope',sans-serif;font-size:15px;font-weight:700;margin-bottom:6px}
.c-gate p{font-size:13px;color:var(--ink-soft);margin-bottom:14px}
.c-gate .btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.c-form{display:none;margin-top:14px}
.c-form.active{display:block}
.c-form textarea{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:'Inter',sans-serif;color:var(--ink);resize:vertical;min-height:76px;margin-bottom:8px;transition:border-color .2s;outline:none;background:white}
.c-form textarea:focus{border-color:var(--teal);box-shadow:0 0 0 3px rgba(0,196,167,.1)}
.c-form-footer{display:flex;align-items:center;justify-content:space-between}
.c-char{font-size:12px;color:var(--ink-muted)}
.btn-post{padding:8px 20px;background:var(--teal);color:white;font-family:'Manrope',sans-serif;font-weight:700;font-size:14px;border:none;border-radius:8px;cursor:pointer;transition:all .2s}
.btn-post:hover{background:var(--teal-dark);transform:translateY(-1px)}
/* Sidebar */
.news-sidebar{position:sticky;top:88px}
.sb-card{border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;margin-bottom:20px}
.sb-head{padding:16px 18px;background:var(--ink)}
.sb-head h3{font-family:'Manrope',sans-serif;font-size:14px;font-weight:700;color:white}
.sb-head p{font-size:11px;color:#8892b0;margin-top:2px}
.sb-body{padding:10px 14px;background:white}
.proto-row{display:flex;gap:10px;align-items:center;padding:9px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:all .15s}
.proto-row:last-child{border-bottom:none}
.proto-row:hover .pr-title{color:var(--teal)}
.pr-icon{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.pr-title{font-size:12px;font-weight:600;color:var(--ink);margin-bottom:1px;display:flex;align-items:center;gap:5px;flex-wrap:wrap}
.pr-sub{font-size:10px;color:var(--ink-muted)}
.s-live{color:#16a34a}
.s-beta{color:#d97706}
.s-rc{color:#9333ea}
.nl-card{background:var(--ink);border-radius:var(--radius-lg);padding:20px;margin-bottom:20px}
.nl-card h3{font-family:'Manrope',sans-serif;font-size:15px;font-weight:700;color:white;margin-bottom:6px}
.nl-card p{font-size:12px;color:#8892b0;margin-bottom:14px;line-height:1.6}
.nl-input{width:100%;padding:9px 12px;border-radius:7px;border:none;font-family:'Inter',sans-serif;font-size:13px;margin-bottom:8px;outline:none}
.btn-nl{width:100%;padding:9px;background:var(--teal);color:white;font-family:'Manrope',sans-serif;font-weight:700;font-size:13px;border:none;border-radius:7px;cursor:pointer;transition:background .2s}
.btn-nl:hover{background:var(--teal-dark)}
.tl-card{border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden}
.tl-item{display:flex;gap:10px;padding:10px 14px;border-bottom:1px solid var(--border);align-items:flex-start}
.tl-item:last-child{border-bottom:none}
.tl-dot{width:7px;height:7px;border-radius:50%;background:var(--teal);flex-shrink:0;margin-top:5px}
.tl-date{font-size:10px;font-weight:700;color:var(--teal);margin-bottom:1px}
.tl-text{font-size:11px;color:var(--ink-soft);line-height:1.4}
/* Modal */
.modal-overlay{position:fixed;inset:0;background:rgba(10,14,26,.7);z-index:1000;display:flex;align-items:center;justify-content:center;padding:24px;backdrop-filter:blur(4px);opacity:0;pointer-events:none;transition:opacity .25s}
.modal-overlay.active{opacity:1;pointer-events:all}
.modal-box{background:white;border-radius:var(--radius-lg);padding:48px;max-width:440px;width:100%;box-shadow:var(--shadow-lg);transform:translateY(20px);transition:transform .25s;position:relative}
.modal-overlay.active .modal-box{transform:translateY(0)}
.modal-close{position:absolute;top:16px;right:18px;background:none;border:none;font-size:24px;cursor:pointer;color:var(--ink-muted)}
.modal-box h2{font-family:'Manrope',sans-serif;font-size:24px;font-weight:800;margin-bottom:6px}
.modal-box p{font-size:14px;color:var(--ink-soft);margin-bottom:20px;line-height:1.7}
.modal-box input{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Inter',sans-serif;margin-bottom:10px;outline:none;transition:border-color .2s}
.modal-box input:focus{border-color:var(--teal)}
.btn-ms{width:100%;padding:13px;background:var(--ink);color:white;font-family:'Manrope',sans-serif;font-weight:700;font-size:14px;border:none;border-radius:9px;cursor:pointer;transition:all .2s}
.btn-ms:hover{background:#1a2035}
footer{background:#060810;color:#4a5270;border-top:1px solid #0e1220;padding:36px 32px;text-align:center}
footer p{font-size:13px}
footer a{color:var(--teal);text-decoration:none;margin:0 8px}
@media(max-width:900px){.news-layout{grid-template-columns:1fr}.news-sidebar{position:static}.pc{grid-template-columns:1fr}.nav-links{display:none}}
</style>
</head>
<body>

