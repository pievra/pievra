<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8">
<meta name="version" content="1774269168"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Dashboard - Pievra</title><meta name="robots" content="noindex"><link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"><style>*{box-sizing:border-box;margin:0;padding:0}:root{--ink:#18181B;--ink-soft:#52525B;--ink-muted:#71717A;--accent:#F97316;--accent-hover:#EA580C;--accent-light:#FFF7ED;--accent-border:#FDBA74;--surface:#FEFDFB;--surface-2:#F9F8F6;--surface-card:#FFFFFF;--border:#E4E4E7;--border-strong:#D4D4D8;--teal:#F97316;--teal-d:#EA580C;--teal-l:#FFF7ED;--surf:#F9F8F6;--muted:#71717A;--soft:#52525B}body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--surface);min-height:100vh;display:flex;flex-direction:column}nav{background:var(--surface);height:64px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;position:sticky;top:0;z-index:100;border-bottom:1px solid var(--border)}.logo{display:flex;align-items:center;gap:10px;text-decoration:none}.lm{display:none}.ln{font-family:'Instrument Serif',serif;font-style:italic;font-size:24px;color:var(--ink)}.nr{display:flex;align-items:center;gap:14px}.ptag{font-size:12px;font-weight:600;padding:4px 10px;border-radius:20px;border:1px solid var(--border);color:var(--ink-muted)}.ptag.pro{border-color:var(--accent);color:var(--accent)}.av{width:32px;height:32px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:white;cursor:pointer}.nwrap{position:relative}.dd{position:absolute;right:0;top:40px;background:#fff;border:1px solid var(--border);border-radius:12px;padding:8px;min-width:190px;box-shadow:0 8px 32px rgba(10,14,26,.12);display:none;z-index:200}.dd.open{display:block}.ddi{display:block;padding:8px 12px;font-size:13px;color:var(--soft);border-radius:8px;text-decoration:none;cursor:pointer;background:none;border:none;width:100%;text-align:left;font-family:'Plus Jakarta Sans',sans-serif}.ddi:hover{background:var(--surf);color:var(--ink)}.ddi.red{color:#dc2626}.ddi.red:hover{background:#fef2f2}.sep{height:1px;background:var(--border);margin:4px 0}.shell{display:flex;flex:1}.sb{width:220px;background:#fff;border-right:1px solid var(--border);padding:16px 10px;display:flex;flex-direction:column;gap:2px;min-height:calc(100vh - 60px)}.sb-sec{font-size:10px;font-weight:700;color:var(--muted);letter-spacing:.08em;padding:12px 10px 4px;text-transform:uppercase}.sb-btn{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;font-size:14px;color:var(--soft);cursor:pointer;background:none;border:none;width:100%;font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none}.sb-btn:hover{background:var(--surf);color:var(--ink)}.sb-btn.on{background:var(--accent-light);color:var(--accent-hover);font-weight:600}.main{flex:1;padding:28px;max-width:100%}.pnl{display:none}.pnl.on{display:block}.ptitle{font-family:'Instrument Serif',serif;font-weight:400;font-size:26px;color:var(--ink);margin-bottom:4px}.psub{font-size:14px;color:var(--muted);margin-bottom:24px}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px}.stat{background:#fff;border:1px solid var(--border);border-radius:14px;padding:20px}.sv{font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:28px;color:var(--ink)}.sv.t{color:var(--accent)}.sl{font-size:12px;color:var(--muted);margin-top:4px}.card{background:#fff;border:1px solid var(--border);border-radius:14px;padding:22px;margin-bottom:14px}.ct{font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:15px;color:var(--ink);margin-bottom:14px;display:flex;align-items:center;justify-content:space-between}.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}.acts{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:22px}.act{background:#fff;border:1px solid var(--border);border-radius:14px;padding:18px;text-align:center;text-decoration:none;display:block;transition:all .15s}.act:hover{border-color:var(--accent);transform:translateY(-2px)}.ai{font-size:26px;margin-bottom:6px}.at{font-weight:600;font-size:14px;color:var(--ink);margin-bottom:2px}.ad{font-size:12px;color:var(--muted)}.pr{display:flex;align-items:center;gap:12px;padding:11px 14px;background:var(--surf);border-radius:10px;margin-bottom:6px}.pd{width:10px;height:10px;border-radius:50%;flex-shrink:0}.pn{font-weight:600;font-size:14px;color:var(--ink);flex:1}.pv{font-size:12px;color:var(--muted)}.pb{font-size:11px;font-weight:700;padding:3px 8px;border-radius:20px}.live{background:#dcfce7;color:#166534}.draft{background:#fef9c3;color:#713f12}.ug{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.uc{background:#fff;border:2px solid var(--border);border-radius:14px;padding:22px;text-align:center;position:relative}.uc.cur{border-color:var(--accent);background:var(--accent-light)}.uc.feat{border-color:var(--ink)}.ubg{position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:var(--ink);color:#fff;font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;white-space:nowrap}.un{font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:15px;color:var(--ink);margin-bottom:4px}.up{font-size:24px;font-weight:700;color:var(--ink);margin-bottom:4px}.up span{font-size:12px;font-weight:400;color:var(--muted)}.ud{font-size:12px;color:var(--muted);margin-bottom:14px;line-height:1.5}.ufl{list-style:none;text-align:left;margin-bottom:14px;font-size:13px;color:var(--soft)}.ufl li{padding:3px 0;display:flex;gap:6px}.ufl li::before{content:"✓";color:var(--accent);font-weight:700}.fl{display:block;font-size:13px;font-weight:500;color:var(--soft);margin-bottom:4px}.fi{width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:10px;font-size:14px;color:var(--ink);background:var(--surf);outline:none;font-family:'Plus Jakarta Sans',sans-serif}.fi:focus{border-color:var(--accent);background:#fff}.fi[readonly]{opacity:.6;cursor:not-allowed}.fr{margin-bottom:14px}.btn{padding:10px 20px;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;transition:all .15s}.bi{background:var(--ink);color:#fff}.bi:hover{background:#1a2030}.bt{background:var(--accent);color:white}.bt:hover{background:var(--accent-hover)}.bo{background:none;border:1px solid var(--border);color:var(--soft)}.bo:hover{border-color:var(--ink);color:var(--ink)}.br{background:#fef2f2;color:#dc2626;border:1px solid #fecaca}.br:hover{background:#dc2626;color:#fff}.bs{padding:7px 14px;font-size:13px}.alrt{padding:11px 15px;border-radius:10px;font-size:13px;margin-bottom:14px;display:none}.aok{background:#f0fdf4;border:1px solid #bbf7d0;color:#166534}.aer{background:#fef2f2;border:1px solid #fecaca;color:#991b1b}#load{position:fixed;inset:0;background:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:999}.spin{width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:sp .7s linear infinite;margin-bottom:14px}.ssm{display:inline-block;width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:sp .6s linear infinite;vertical-align:middle;margin-right:4px}@keyframes sp{to{transform:rotate(360deg)}}.empty{text-align:center;padding:44px 20px;color:var(--muted)}.ei{font-size:38px;margin-bottom:10px}.et{font-size:15px;font-weight:600;color:var(--ink);margin-bottom:5px}.eb{font-size:13px;line-height:1.6}.moverlay{display:none;position:fixed;inset:0;background:rgba(10,14,26,.5);z-index:500;align-items:center;justify-content:center}.moverlay.open{display:flex}.mbox{background:#fff;border-radius:16px;padding:30px;max-width:360px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.2)}@media(max-width:900px){.sb{display:none}.stats{grid-template-columns:repeat(2,1fr)}.acts{grid-template-columns:1fr 1fr}.ug{grid-template-columns:1fr}.g2{grid-template-columns:1fr}}</style><script src="/static/pievra_widgets.js">
window.activateCampaign = function(id, campaignSn, flightSn, budget) {
  var tok = localStorage.getItem('pievra_token') || '';
  fetch('/api/campaign/'+id+'/serials', {
    method:'POST', credentials:'include',
    headers:{'Content-Type':'application/json','Authorization':'Bearer '+tok},
    body: JSON.stringify({country:'France', flight_start: new Date().toISOString().substring(0,10)})
  }).then(function(r){return r.json();}).then(function(d){
    PievraConsent.show(id, d.campaign_sn || campaignSn || '', d.flight_sn || flightSn || '', budget, function(){
      window.location.reload();
    });
  });
}

</script>
<script src="/static/campaign_manager.js"></script>

<script>
// Bridge function for CampaignManager to use dashboard's authFetch
window.cmFetch = function(url, callback) {
  var tok = localStorage.getItem('pievra_token') || '';
  var xhr = new XMLHttpRequest();
  xhr.open('GET', url, true);
  xhr.setRequestHeader('Authorization', 'Bearer ' + tok);
  xhr.onload = function() {
    if (xhr.status === 200) {
      try { callback(null, JSON.parse(xhr.responseText)); }
      catch(e) { callback(e, null); }
    } else {
      callback(new Error('HTTP ' + xhr.status), null);
    }
  };
  xhr.onerror = function() { callback(new Error('Network error'), null); };
  xhr.send();
};
</script>
</head><body>
<div id="load"><div class="spin"></div><p style="color:var(--muted);font-size:14px">Loading your dashboard...</p></div>
<nav>
  <a href="/" class="logo"><span class="ln">pievra<span style="color:#F97316">.</span></span></a>
  <div class="nr">
    <div class="ptag" id="ntag">Community</div>
    <div class="nwrap">
      <div class="av" id="av" onclick="toggleDD()">?</div>
      <div class="dd" id="ddd">
        <div style="padding:8px 12px 10px;border-bottom:1px solid var(--border);margin-bottom:4px">
          <div style="font-size:13px;font-weight:600;color:var(--ink)" id="dde">-</div>
          <div style="font-size:12px;color:var(--muted)" id="ddp">Community plan</div>
        </div>
        <button class="ddi" onclick="go('overview')">&#x1F4CA; Overview</button>
        <button class="ddi" onclick="go('settings')">&#x2699;&#xFE0F; Settings</button>
        <div class="sep"></div>
        <a class="ddi" href="/">&#x2190; pievra.com</a>
        <div class="sep"></div>
        <button class="ddi red" onclick="doLogout()">Sign out</button>
      </div>
    </div>
  </div>
</nav>
<div class="shell">
  <aside class="sb">
    <button id="snc" onclick="go('planner')" style="display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:11px 12px;margin-bottom:12px;background:#F97316;color:white;border:none;border-radius:10px;font-size:14px;font-weight:700;font-family:'Plus Jakarta Sans',sans-serif;cursor:pointer;transition:background .15s" onmouseover="this.style.background='#EA580C'" onmouseout="this.style.background='#F97316'">+ New Campaign</button>
    <div class="sb-sec">Main</div>
    <button class="sb-btn on" id="sov" onclick="go('overview')">&#x1F4CA; Overview</button>
    <button class="sb-btn" id="spln" onclick="go('planner')">&#x1F4CB; Campaign Planner</button>
    <button class="sb-btn" id="sobm" onclick="go('manager')">&#x1F4CA; Manager</button>
    <button class="sb-btn" id="soc" onclick="go('campaigns')">&#x1F5FA; Campaigns</button>
    <button class="sb-btn" id="spr" onclick="go('protocols')">&#x26A1; Protocols</button>
    <button class="sb-btn" id="sag" onclick="go('agents')">&#x1F916; Agents</button>
    <div class="sb-sec">Account</div>
    <button class="sb-btn" id="spl" onclick="go('learn')">&#x1F4D6; Knowledge</button>
    <button class="sb-btn" id="sst" onclick="go('settings')">&#x2699;&#xFE0F; Settings</button>
    <button class="sb-btn" id="sse" onclick="go('security')">&#x1F512; Security</button>
  </aside>
  <main class="main">
    <!-- OVERVIEW -->
    <div class="pnl on" id="pov">
      <div class="ptitle" id="greet">Dashboard</div>
      <div class="psub" id="osub">Welcome to Pievra</div>
      <div class="stats">
        <div class="stat"><div class="sv t" id="stat-campaigns">0</div><div class="sl">Campaigns</div></div>
        <div class="stat"><div class="sv">0</div><div class="sl">Active agents</div></div>
        <div class="stat"><div class="sv t">5</div><div class="sl">Live protocols</div></div>
        <div class="stat"><div class="sv">$0</div><div class="sl">GMV transacted</div></div>
      </div>
      <div class="acts">
        <a class="act" href="#" onclick="go('planner');return false;"><div class="ai">&#x1F5FA;</div><div class="at">Plan a campaign</div><div class="ad">Cross-protocol builder</div></a>
        <a class="act" href="/#marketplace"><div class="ai">&#x1F916;</div><div class="at">List your agent</div><div class="ad">Add to marketplace</div></a>
        <a class="act" href="/newsletter"><div class="ai">&#x1F4EC;</div><div class="at">Protocol briefing</div><div class="ad">Weekly newsletter</div></a>
      </div>
      <div class="g2">
        <div class="card">
     <div class="ct">Your plan</div>
     <div id="plbadge" style="display:inline-flex;align-items:center;gap:8px;padding:10px 16px;border-radius:12px;background:#dcfce7;border:1px solid #bbf7d0;font-size:14px;font-weight:600;color:#166534">&#x2705; Free - All Features</div>
     <div style="margin-top:12px;font-size:13px;color:var(--muted);line-height:1.7" id="plfeats">Unlimited agents - All protocols - Campaign planner - PDF export - Analytics</div>
   </div>
        <div class="card">
          <div class="ct">Account</div>
          <div style="display:flex;flex-direction:column;gap:9px">
            <div style="display:flex;justify-content:space-between;font-size:13px"><span style="color:var(--muted)">Email</span><span style="color:var(--ink);font-weight:500" id="aemail">-</span></div>
            <div style="display:flex;justify-content:space-between;font-size:13px"><span style="color:var(--muted)">Member since</span><span style="color:var(--ink)" id="asince">-</span></div>
            <div style="display:flex;justify-content:space-between;font-size:13px"><span style="color:var(--muted)">Last sign in</span><span style="color:var(--ink)" id="alast">-</span></div>
            <div style="display:flex;justify-content:space-between;font-size:13px"><span style="color:var(--muted)">Status</span><span style="color:#166534;font-weight:600">✓ Verified</span></div>
          </div>
        </div>
      </div>
    </div>
    <!-- CAMPAIGNS -->
    <div class="pnl" id="pca">
      <div class="ptitle">Campaigns</div>
      <div class="psub">Your active and draft campaigns</div>
      <div id="camp-alert" class="alrt"></div>
      <div style="display:flex;gap:0;border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:20px;width:fit-content">
        <button id="tab-active" onclick="showCampTab('active')" style="padding:9px 20px;background:var(--ink);color:white;border:none;font-size:13px;font-weight:600;cursor:pointer">Active</button>
        <button id="tab-draft" onclick="showCampTab('draft')" style="padding:9px 20px;background:none;border:none;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer">Drafts</button>
      </div>
      <div id="camp-active-list"></div>
      <div id="camp-draft-list" style="display:none"></div>
      <div style="margin-top:16px">
        <a href="#" onclick="go('planner');return false;" style="display:inline-flex;align-items:center;gap:8px;background:var(--ink);color:white;font-weight:600;font-size:14px;padding:11px 20px;border-radius:10px;text-decoration:none">+ New Campaign</a>
      </div>
    </div>
    <!-- EDIT MODAL -->
    <div class="moverlay" id="editmod">
      <div class="mbox" style="max-width:580px;width:95%;max-height:90vh;overflow-y:auto">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
          <h3 style="font-family:Manrope;font-weight:800;font-size:17px;color:var(--ink)">Edit Campaign</h3>
          <button onclick="document.getElementById('editmod').classList.remove('open')" style="background:none;border:none;font-size:22px;cursor:pointer;color:var(--muted)">&#x00D7;</button>
        </div>
        <input type="hidden" id="edit-id"/>
        <div class="fr"><label class="fl">Brand / Advertiser</label><input class="fi" id="edit-brand" type="text"/></div>
        <div class="fr"><label class="fl">Campaign Name</label><input class="fi" id="edit-name" type="text"/></div>
        <div class="fr"><label class="fl">Description</label><textarea class="fi" id="edit-desc" rows="3" style="resize:vertical"></textarea></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
          <div><label class="fl">Budget (USD)</label><input class="fi" id="edit-budget" type="text"/></div>
          <div><label class="fl">KPI Target</label><input class="fi" id="edit-kpi" type="text"/></div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
          <div><label class="fl">Objective</label>
            <select class="fi" id="edit-obj"><option>Awareness</option><option>Consideration</option><option>Conversion</option><option>Retention</option></select>
          </div>
          <div><label class="fl">Buying Model</label>
            <select class="fi" id="edit-buy"><option>CPM</option><option>CPC</option><option>CPA</option><option>CPL</option><option>CPCV</option></select>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
          <div><label class="fl">Status</label>
            <select class="fi" id="edit-status"><option value="active">Active</option><option value="draft">Draft</option><option value="paused">Paused</option></select>
          </div>
          <div><label class="fl">&nbsp;</label>
            <button class="btn br" style="width:100%" onclick="confirmDeleteCamp()">Delete</button>
          </div>
        </div>
        <div style="display:flex;gap:10px;margin-top:4px">
          <button class="btn bo" style="flex:1" onclick="document.getElementById('editmod').classList.remove('open')">Cancel</button>
          <button class="btn bi" style="flex:1" onclick="saveEdit()">Save Changes</button>
        </div>
      </div>
    </div>
    <!-- PROTOCOLS -->
    <div class="pnl" id="ppr">
      <div class="ptitle">Live Protocols</div><div class="psub">All five agentic advertising standards - verified March 2026</div>
      <div class="card">
        <div class="pr"><div class="pd" style="background:#F97316"></div><div class="pn">AdCP</div><div class="pv">v2.5.1 · AgenticAdvertising.org</div><div class="pb live">LIVE</div></div>
        <div class="pr"><div class="pd" style="background:#7c3aed"></div><div class="pn">MCP</div><div class="pv">Spec 2025-11-25 · Linux Foundation</div><div class="pb live">LIVE</div></div>
        <div class="pr"><div class="pd" style="background:#3b82f6"></div><div class="pn">UCP / AAMP</div><div class="pv">v1.0 public · IAB Tech Lab</div><div class="pb live">LIVE</div></div>
        <div class="pr"><div class="pd" style="background:#f59e0b"></div><div class="pn">ARTF</div><div class="pv">v1.0 draft · IAB Tech Lab</div><div class="pb draft">DRAFT</div></div>
        <div class="pr"><div class="pd" style="background:#009e86"></div><div class="pn">A2A</div><div class="pv">v1.0.0 · Linux Foundation</div><div class="pb live">LIVE</div></div>
        <div style="margin-top:14px;padding-top:12px;border-top:1px solid var(--border);font-size:12px;color:var(--muted)">Updated every Tuesday · <a href="/news" style="color:var(--teal);text-decoration:none">Protocol Briefing &#x2192;</a></div>
      </div>
    </div>
    <!-- AGENTS -->
    <div class="pnl" id="pag">
      <div class="ptitle">Agents</div><div class="psub">Agents you have listed in the Pievra Marketplace</div>
      <div class="card"><div class="empty"><div class="ei">&#x1F916;</div><div class="et">No agents listed</div><div class="eb">List your DSP or SSP agent. Receive standardised bid requests across all buying protocols simultaneously.</div>
      <a href="/#marketplace" style="display:inline-block;margin-top:14px;padding:10px 20px;background:var(--ink);color:#fff;border-radius:10px;text-decoration:none;font-weight:600;font-size:14px">List your agent &#x2192;</a></div></div>
    </div>
    <!-- PLAN -->
    <div class="pnl" id="ppl">
      <div class="ptitle">Knowledge Hub</div><div class="psub">Learn about AI advertising protocols</div>
      <div class="alrt" id="apl"></div>
      <div class="g2">
     <div class="card">
       <div class="ct">Protocol Guides</div>
       <div style="font-size:13px;color:var(--soft);line-height:1.7">
         <p style="margin-bottom:12px"><strong>AdCP</strong> - Ad Context Protocol for campaign negotiation. Agents negotiate deals using natural language briefs.</p>
         <p style="margin-bottom:12px"><strong>MCP</strong> - Model Context Protocol for tool orchestration. Universal adapter for inventory, audience and brand safety data.</p>
         <p style="margin-bottom:12px"><strong>UCP</strong> - Unified Context Protocol for privacy-safe audience activation using embeddings.</p>
         <p style="margin-bottom:12px"><strong>ARTF</strong> - Agentic Real-Time Framework extending OpenRTB for sub-100ms AI auctions.</p>
         <p><strong>A2A</strong> - Agent-to-Agent protocol for real-time collaboration between optimiser, reporter and pacing agents.</p>
       </div>
     </div>
     <div class="card">
       <div class="ct">Recommended Reading</div>
       <div style="font-size:13px;color:var(--soft);line-height:1.7">
         <p style="margin-bottom:10px">&#x1F4D6; <a href="https://adcontextprotocol.org" target="_blank" style="color:var(--teal-d);text-decoration:underline">AdCP Specification</a> - PubMatic, Scope3, Yahoo</p>
         <p style="margin-bottom:10px">&#x1F4D6; <a href="https://modelcontextprotocol.io" target="_blank" style="color:var(--teal-d);text-decoration:underline">MCP Documentation</a> - Anthropic</p>
         <p style="margin-bottom:10px">&#x1F4D6; <a href="https://iabtechlab.com" target="_blank" style="color:var(--teal-d);text-decoration:underline">IAB Tech Lab Standards</a> - UCP, ARTF specs</p>
         <p style="margin-bottom:10px">&#x1F4D6; <a href="https://google.github.io/A2A/" target="_blank" style="color:var(--teal-d);text-decoration:underline">A2A Protocol</a> - Google / Linux Foundation</p>
         <p style="margin-bottom:10px">&#x1F4D6; <a href="/newsletter" style="color:var(--teal-d);text-decoration:underline">Protocol Intelligence Weekly</a> - Pievra newsletter</p>
       </div>
     </div>
   </div>
   <div class="card" style="margin-top:14px">
     <div class="ct">Tips for Getting Started</div>
     <div style="font-size:13px;color:var(--soft);line-height:1.7">
       <p style="margin-bottom:8px"><strong>1. Plan a campaign</strong> - Use the Campaign Planner to create a simulated cross-protocol media plan with real market benchmarks.</p>
       <p style="margin-bottom:8px"><strong>2. Explore the marketplace</strong> - Browse AI agents by protocol, category and performance score.</p>
       <p style="margin-bottom:8px"><strong>3. Download your PDF</strong> - Generate a professional media plan document to share with your team.</p>
       <p><strong>4. Subscribe to the newsletter</strong> - Get weekly protocol updates, agent benchmarks and integration guides.</p>
     </div>
   </div>
    </div>
    <!-- SETTINGS -->
    <div class="pnl" id="pst">
      <div class="ptitle">Settings</div><div class="psub">Manage your profile and data</div>
      <div class="alrt" id="ast"></div>
      <div class="card"><div class="ct">Profile</div>
        <div class="fr"><label class="fl">Email</label><input class="fi" id="sem" type="email" readonly></div>
        <div class="fr"><label class="fl">Plan</label><input class="fi" id="spl" type="text" readonly></div>
        <div class="fr"><label class="fl">Member since</label><input class="fi" id="ssi" type="text" readonly></div>
      </div>
      <div class="card"><div class="ct">Change password</div>
        <div class="fr"><label class="fl">New password</label><input class="fi" id="sp1" type="password" placeholder="Minimum 8 characters"></div>
        <div class="fr"><label class="fl">Confirm</label><input class="fi" id="sp2" type="password" placeholder="Repeat new password"></div>
        <button class="btn bi" onclick="changePw()">Update password</button>
      </div>
      <div class="card"><div class="ct">GDPR &amp; your data</div>
        <p style="font-size:13px;color:var(--muted);line-height:1.7;margin-bottom:14px">Under GDPR you have the right to access, rectify and erase your personal data. Pievra stores only your email and consent records. Your data is never sold.</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <button class="btn bo bs" onclick="exportData()">Export my data</button>
          <button class="btn br bs" onclick="document.getElementById('delmod').classList.add('open')">Delete my account</button>
        </div>
      </div>
    </div>
    <!-- SECURITY -->
    <div class="pnl" id="pse">
      <div class="ptitle">Security</div><div class="psub">Sessions and recovery</div>
      <div class="alrt" id="ase"></div>
      <div class="card"><div class="ct">Active session</div>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:11px 14px;background:var(--surf);border-radius:10px">
          <div><div style="font-size:14px;font-weight:600;color:var(--ink)">Current session</div><div style="font-size:12px;color:var(--muted)">30-day JWT · This device</div></div>
          <div style="display:flex;align-items:center;gap:5px;font-size:12px;color:#166534;font-weight:600"><span style="width:7px;height:7px;background:#22c55e;border-radius:50%;display:inline-block"></span>Active</div>
        </div>
        <button class="btn bo bs" style="margin-top:10px" onclick="doLogout()">Sign out</button>
      </div>
      <div class="card"><div class="ct">Recovery codes</div>
        <p style="font-size:13px;color:var(--muted);line-height:1.7">8 recovery codes were generated at account creation. Each can be used once if you lose password and email access. Store in a password manager or print them.</p>
        <p style="font-size:13px;color:var(--muted);margin-top:10px">For new codes contact <a href="mailto:legal@pievra.com" style="color:var(--teal)">legal@pievra.com</a>.</p>
      </div>
      <div class="card"><div class="ct">Password security</div>
        <p style="font-size:13px;color:var(--muted);margin-bottom:12px">Pievra uses bcrypt hashing. Your password is never stored in plain text.</p>
        <button class="btn bo bs" onclick="go('settings')">Change password &#x2192;</button>
      </div>
    </div>
<div id="sec-manager" class="pnl" style="padding:0">

  <!-- Toolbar -->
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px">
    <div>
      <div style="font-family:Manrope,sans-serif;font-weight:800;font-size:18px;color:var(--ink)">Campaign Manager</div>

      <div style="font-size:13px;color:var(--muted)" id="cm-count">Loading...</div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button onclick="CampaignManager.exportCSV()" style="display:flex;align-items:center;gap:5px;border:1px solid var(--border);background:white;color:var(--soft);font-size:12px;font-weight:600;padding:7px 12px;border-radius:8px;cursor:pointer">📄 CSV</button>
      <button onclick="CampaignManager.exportXLSX()" style="display:flex;align-items:center;gap:5px;border:1px solid var(--border);background:white;color:var(--soft);font-size:12px;font-weight:600;padding:7px 12px;border-radius:8px;cursor:pointer">📊 Excel</button>
      <button onclick="CampaignManager.exportEmail()" style="display:flex;align-items:center;gap:5px;border:1px solid var(--border);background:white;color:var(--soft);font-size:12px;font-weight:600;padding:7px 12px;border-radius:8px;cursor:pointer">📧 Email</button>
      <button onclick="CampaignManager.load()" style="border:none;background:var(--teal);color:var(--ink);font-size:12px;font-weight:700;padding:7px 12px;border-radius:8px;cursor:pointer">↻ Refresh</button>
    </div>
  </div>

  <!-- Filters -->
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;background:white;border:1px solid var(--border);border-radius:12px;padding:14px">
    <input id="cm-search" type="text" placeholder="🔍 Search campaigns, brands, SNs..." oninput="CampaignManager.setFilter('search',this.value)"
      style="flex:1;min-width:200px;padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink)">
    <select onchange="CampaignManager.setFilter('status',this.value)"
      style="padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);background:white;cursor:pointer">
      <option value="all">All Status</option>
      <option value="active">Active</option>
      <option value="paused">Paused</option>
      <option value="draft">Draft</option>
      <option value="archived">Archived</option>
    </select>
    <select onchange="CampaignManager.setFilter('objective',this.value)"
      style="padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);background:white;cursor:pointer">
      <option value="all">All Objectives</option>
      <option value="Awareness">Awareness</option>
      <option value="Consideration">Consideration</option>
      <option value="Conversion">Conversion</option>
      <option value="Retention">Retention</option>
    </select>
    <select id="cm-filter-advertiser" onchange="CampaignManager.setFilter('advertiser',this.value)"
      style="padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);background:white;cursor:pointer">
      <option value="all">All Advertisers</option>
    </select>
  </div>

  <!-- Bulk action bar -->
  <div id="cm-bulk-bar" style="display:none;align-items:center;gap:10px;flex-wrap:wrap;background:#18181B;border-radius:10px;padding:12px 16px;margin-bottom:12px">
    <span id="cm-bulk-count" style="font-size:13px;font-weight:700;color:white"></span>
    <div style="display:flex;gap:6px;flex-wrap:wrap">
      <button onclick="CampaignManager.bulkStatus('active')" style="border:none;background:#dcfce7;color:#166534;font-size:12px;font-weight:700;padding:6px 12px;border-radius:8px;cursor:pointer">▶ Set Active</button>
      <button onclick="CampaignManager.bulkStatus('paused')" style="border:none;background:#dbeafe;color:#1e40af;font-size:12px;font-weight:700;padding:6px 12px;border-radius:8px;cursor:pointer">⏸ Pause</button>
      <button onclick="CampaignManager.bulkStatus('archived')" style="border:none;background:#f3f4f6;color:#6b7280;font-size:12px;font-weight:700;padding:6px 12px;border-radius:8px;cursor:pointer">📦 Archive</button>
      <button onclick="CampaignManager.exportCSV()" style="border:none;background:rgba(255,255,255,.1);color:white;font-size:12px;font-weight:700;padding:6px 12px;border-radius:8px;cursor:pointer">📄 Export Selected</button>
    </div>
    <button onclick="CampaignManager.selectAll(false)" style="margin-left:auto;border:none;background:none;color:rgba(255,255,255,.5);font-size:12px;cursor:pointer">✕ Clear</button>
  </div>

  <!-- Table -->
  <div style="background:white;border:1px solid var(--border);border-radius:14px;overflow:hidden;overflow-x:auto">
    <table style="width:100%;border-collapse:collapse;font-size:13px;min-width:1100px">
      <thead>
        <tr style="background:var(--ink)">
          <th style="padding:12px;width:32px"><input type="checkbox" id="cm-select-all" onchange="CampaignManager.selectAll(this.checked)" style="width:14px;height:14px;accent-color:#F97316"></th>
          <th data-sort="customer_sn" onclick="CampaignManager.sortBy('customer_sn')" style="padding:12px 10px;text-align:left;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;cursor:pointer;white-space:nowrap">Customer<span class="sort-arrow"> ↕</span></th>
          <th data-sort="brand" onclick="CampaignManager.sortBy('brand')" style="padding:12px 10px;text-align:left;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;cursor:pointer;white-space:nowrap">Brand / Advertiser<span class="sort-arrow"> ↕</span></th>
          <th data-sort="campaign_name" onclick="CampaignManager.sortBy('campaign_name')" style="padding:12px 10px;text-align:left;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;cursor:pointer;white-space:nowrap">Campaign<span class="sort-arrow"> ↕</span></th>
          <th style="padding:12px 10px;text-align:left;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;white-space:nowrap">Flight SN</th>
          <th data-sort="status" onclick="CampaignManager.sortBy('status')" style="padding:12px 10px;text-align:left;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;cursor:pointer;white-space:nowrap">Status<span class="sort-arrow"> ↕</span></th>
          <th data-sort="objective" onclick="CampaignManager.sortBy('objective')" style="padding:12px 10px;text-align:left;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;cursor:pointer;white-space:nowrap">Objective<span class="sort-arrow"> ↕</span></th>
          <th data-sort="budget" onclick="CampaignManager.sortBy('budget')" style="padding:12px 10px;text-align:right;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;cursor:pointer;white-space:nowrap">Budget<span class="sort-arrow"> ↕</span></th>
          <th style="padding:12px 10px;text-align:right;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;white-space:nowrap">CPM</th>
          <th style="padding:12px 10px;text-align:right;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;white-space:nowrap">Impressions</th>
          <th style="padding:12px 10px;text-align:right;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;white-space:nowrap">ROAS</th>
          <th data-sort="flight_start" onclick="CampaignManager.sortBy('flight_start')" style="padding:12px 10px;text-align:left;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;cursor:pointer;white-space:nowrap">Start<span class="sort-arrow"> ↕</span></th>
          <th data-sort="flight_end" onclick="CampaignManager.sortBy('flight_end')" style="padding:12px 10px;text-align:left;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.06em;cursor:pointer;white-space:nowrap">End<span class="sort-arrow"> ↕</span></th>
          <th style="padding:12px 10px;text-align:left;font-size:11px;font-weight:700;color:rgba(255,255,255,.6);white-space:nowrap">Actions</th>
        </tr>
      </thead>
      <tbody id="cm-table-body">
        <tr><td colspan="14" style="text-align:center;padding:48px;color:var(--muted)">Loading...</td></tr>
      </tbody>
    </table>
  </div>

</div>

    <div class="pnl" id="ppln">
      <div class="ptitle">Campaign Planner</div>
      <div class="psub">Define your campaign brief or describe it to the AI assistant</div>

      <div id="dp-sandbox-msg" style="display:none"></div>
      <div id="dp-pro-msg" style="display:none;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:12px;padding:18px 22px;margin-bottom:18px;align-items:center;gap:14px">
        <div style="font-size:22px">&#x2705;</div>
        <div>
          <div style="font-size:14px;color:#166534;line-height:1.6">All features are <b>free and unlimited</b>. Create campaigns, generate PDF media plans, explore the marketplace and learn about all five protocols.</div>
        </div>
      </div>

      <!-- AI Assistant -->
      <div id="dp-chat-mode" style="margin-bottom:24px;background:#18181B;border-radius:16px;padding:24px">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px">
          <div style="width:32px;height:32px;background:var(--teal);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px">&#x1F916;</div>
          <div>
            <div style="font-family:Manrope,sans-serif;font-weight:700;font-size:15px;color:white">AI Campaign Assistant</div>
            <div style="font-size:12px;color:#7a829e">Describe your campaign in plain language - the AI will fill the form or generate a plan directly</div>
          </div>
        </div>
        <div style="margin-bottom:14px">
          <div style="font-size:11px;color:#7a829e;margin-bottom:8px;letter-spacing:.05em">EXAMPLE BRIEFS - click to use:</div>
          <div style="display:flex;flex-wrap:wrap;gap:8px">
            <button onclick="document.getElementById('dp-chat-input').value=this.textContent.trim()" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.8);font-size:12px;padding:6px 12px;border-radius:20px;cursor:pointer;text-align:left">&#x1F6CD; Nike Air Max launch - Gen Z, Europe, CTV + Display, $80K, ROAS 3.0</button>
            <button onclick="document.getElementById('dp-chat-input').value=this.textContent.trim()" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.8);font-size:12px;padding:6px 12px;border-radius:20px;cursor:pointer;text-align:left">&#x1F3E6; B2B SaaS lead gen - Finance decision-makers, US+UK, LinkedIn + Display, $25K CPL</button>
            <button onclick="document.getElementById('dp-chat-input').value=this.textContent.trim()" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.8);font-size:12px;padding:6px 12px;border-radius:20px;cursor:pointer;text-align:left">&#x1F697; Auto awareness - In-market buyers, Germany + France, CTV + DOOH, $120K CPM</button>
            <button onclick="document.getElementById('dp-chat-input').value=this.textContent.trim()" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.8);font-size:12px;padding:6px 12px;border-radius:20px;cursor:pointer;text-align:left">&#x2708; Travel retargeting - Luxury travellers, UAE + Singapore, Mobile + Native, $40K CPA</button>
          </div>
        </div>
        <div id="dp-chat-messages" style="min-height:60px;max-height:200px;overflow-y:auto;margin-bottom:12px"></div>
        <div style="display:flex;gap:10px">
          <textarea id="dp-chat-input" placeholder="e.g. Run an awareness campaign for Nike Air Max 2026 targeting Gen Z in France and Germany on CTV and Display, budget $80K, ROAS target 3.0..." style="flex:1;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:10px;color:white;font-size:14px;padding:12px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;resize:none;min-height:80px" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();dpSendChat();}"></textarea>
          <button onclick="dpSendChat()" id="dp-chat-send-btn" style="background:#F97316;border:none;color:white;font-weight:700;font-size:14px;padding:12px 20px;border-radius:10px;cursor:pointer;align-self:flex-end;white-space:nowrap">Generate &#x2192;</button>
        </div>
        <div style="font-size:11px;color:#7a829e;margin-top:8px">Press Enter to send · Shift+Enter for new line</div>
      </div>

      <!-- Campaign Brief Form -->
      <div id="dp-form" style="background:white;border:1px solid var(--border);border-radius:14px;padding:28px">
        <!-- Step 1 - Campaign Brief -->
        <div style="margin-bottom:28px">
          <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border)">1 - Campaign Brief</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">Advertiser / Brand <span style="color:#dc2626">*</span></label>
              <input type="text" id="dp-brand" placeholder="e.g. Nike, Samsung, L'Oréal..." style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);outline:none"/>
            </div>
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">Product / Campaign Name <span style="color:#dc2626">*</span></label>
              <input type="text" id="dp-name" placeholder="e.g. Air Max 2026 launch..." style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);outline:none"/>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:6px">
            <label style="font-size:13px;font-weight:600;color:var(--ink)">Campaign Description <span style="font-weight:400;color:var(--muted)">- goals, messaging, requirements</span> <span style="color:#dc2626">*</span></label>
            <textarea id="dp-desc" placeholder="e.g. Drive awareness for Air Max 2026 targeting Gen Z in major European cities. 30s hero video for CTV, companion display for web retargeting..." style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);outline:none;resize:vertical;min-height:80px"></textarea>
          </div>
        </div>

        <!-- Step 2 - Objective & Buying Model -->
        <div style="margin-bottom:28px">
          <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border)">2 - Objective &amp; Buying Model</div>
          <div style="margin-bottom:16px">
            <label style="font-size:13px;font-weight:600;color:var(--ink);display:block;margin-bottom:10px">Campaign Objective</label>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px" id="dp-obj-grid">
              <button class="dp-toggle active" onclick="dpToggle(this,'dp-obj-grid')" style="padding:10px 8px;border:1.5px solid var(--ink);border-radius:8px;background:var(--ink);font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;text-align:left;color:white">Awareness<span style="display:block;font-size:11px;font-weight:400;opacity:.7;margin-top:2px">Maximise reach</span></button>
              <button class="dp-toggle" onclick="dpToggle(this,'dp-obj-grid')" style="padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;text-align:left;color:var(--soft)">Consideration<span style="display:block;font-size:11px;font-weight:400;opacity:.7;margin-top:2px">Drive engagement</span></button>
              <button class="dp-toggle" onclick="dpToggle(this,'dp-obj-grid')" style="padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;text-align:left;color:var(--soft)">Conversion<span style="display:block;font-size:11px;font-weight:400;opacity:.7;margin-top:2px">Optimise sales</span></button>
              <button class="dp-toggle" onclick="dpToggle(this,'dp-obj-grid')" style="padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;text-align:left;color:var(--soft)">Retention<span style="display:block;font-size:11px;font-weight:400;opacity:.7;margin-top:2px">Re-engage users</span></button>
            </div>
          </div>
          <div style="margin-bottom:16px">
            <label style="font-size:13px;font-weight:600;color:var(--ink);display:block;margin-bottom:10px">Buying Model</label>
            <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px" id="dp-buy-grid">
              <button class="dp-toggle active" onclick="dpToggle(this,'dp-buy-grid')" style="padding:10px 8px;border:1.5px solid var(--ink);border-radius:8px;background:var(--ink);font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;text-align:left;color:white">CPM<span style="display:block;font-size:11px;font-weight:400;opacity:.7;margin-top:2px">per 1,000 impr.</span></button>
              <button class="dp-toggle" onclick="dpToggle(this,'dp-buy-grid')" style="padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;text-align:left;color:var(--soft)">CPC<span style="display:block;font-size:11px;font-weight:400;opacity:.7;margin-top:2px">per click</span></button>
              <button class="dp-toggle" onclick="dpToggle(this,'dp-buy-grid')" style="padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;text-align:left;color:var(--soft)">CPA<span style="display:block;font-size:11px;font-weight:400;opacity:.7;margin-top:2px">per acquisition</span></button>
              <button class="dp-toggle" onclick="dpToggle(this,'dp-buy-grid')" style="padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;text-align:left;color:var(--soft)">CPL<span style="display:block;font-size:11px;font-weight:400;opacity:.7;margin-top:2px">per lead</span></button>
              <button class="dp-toggle" onclick="dpToggle(this,'dp-buy-grid')" style="padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;text-align:left;color:var(--soft)">CPCV<span style="display:block;font-size:11px;font-weight:400;opacity:.7;margin-top:2px">per completed view</span></button>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">Budget (USD)</label>
              <input type="text" id="dp-budget" value="50000" style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);outline:none"/>
            </div>
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">KPI Target <span style="font-weight:400;color:var(--muted)">- auto-suggested</span></label>
              <input type="text" id="dp-kpi" value="ROAS > 2.5" style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);outline:none"/>
            </div>
          </div>
        </div>

        <!-- Step 3 - Audience -->
        <div style="margin-bottom:28px">
          <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border)">3 - Audience Targeting</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">Age Range</label>
              <select id="dp-age" style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);outline:none;background:white"><option>All Ages</option><option>13-17</option><option>18-24</option><option>25-34</option><option>35-44</option><option>45-54</option><option>55-64</option><option>65+</option></select>
            </div>
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">Gender</label>
              <div style="display:flex;gap:8px" id="dp-gen-grid">
                <button class="dp-toggle active" onclick="dpToggle(this,'dp-gen-grid')" style="flex:1;padding:10px 8px;border:1.5px solid var(--ink);border-radius:8px;background:var(--ink);font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;color:white">All</button>
                <button class="dp-toggle" onclick="dpToggle(this,'dp-gen-grid')" style="flex:1;padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;color:var(--soft)">Male</button>
                <button class="dp-toggle" onclick="dpToggle(this,'dp-gen-grid')" style="flex:1;padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;color:var(--soft)">Female</button>
              </div>
            </div>
          </div>
          <label style="font-size:13px;font-weight:600;color:var(--ink);display:block;margin-bottom:10px">Interests &amp; Affinities</label>
          <div style="display:flex;flex-wrap:wrap;gap:8px" id="dp-interests">
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Technology</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Fashion</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Sports</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Gaming</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Travel</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Food &amp; Drink</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Health &amp; Fitness</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Finance</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Automotive</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Entertainment</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Luxury</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">B2B / Business</button>
            <button onclick="this.classList.toggle('active');dpStyleInterest(this)" style="padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:white;color:var(--soft);font-family:'Plus Jakarta Sans',sans-serif,sans-serif">Sustainability</button>
          </div>
        </div>

        <!-- Step 4 - Geo -->
        <div style="margin-bottom:28px">
          <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border)">4 - Geo Targeting</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">Country / Region <span style="color:var(--muted);font-size:12px;font-weight:400">(Ctrl/Cmd for multiple)</span></label>
              <select id="dp-country" multiple size="5" style="height:120px;padding:6px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);outline:none">
                <option value="United States">United States</option><option value="United Kingdom">United Kingdom</option><option value="France">France</option><option value="Germany">Germany</option><option value="Netherlands">Netherlands</option><option value="Belgium">Belgium</option><option value="Spain">Spain</option><option value="Italy">Italy</option><option value="Canada">Canada</option><option value="Australia">Australia</option><option value="UAE">UAE</option><option value="Saudi Arabia">Saudi Arabia</option><option value="Singapore">Singapore</option><option value="Japan">Japan</option><option value="Brazil">Brazil</option><option value="Mexico">Mexico</option><option value="India">India</option><option value="South Africa">South Africa</option>
              </select>
            </div>
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">City <span style="font-weight:400;color:var(--muted)">- optional, for hyperlocal</span></label>
              <input type="text" id="dp-city" placeholder="e.g. Paris, Dubai, London..." style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);outline:none"/>
            </div>
          </div>
        </div>

        <!-- Step 5 - Environments -->
        <div style="margin-bottom:28px">
          <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border)">5 - Target Environments</div>
          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px" id="dp-env-grid">
            <button onclick="this.classList.toggle('active');dpStyleEnv(this)" class="active" style="padding:10px 12px;border:1.5px solid var(--teal);border-radius:8px;background:var(--teal-l);font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:500;cursor:pointer;text-align:left;color:var(--teal-d)">&#x1F5A5; Web Display</button>
            <button onclick="this.classList.toggle('active');dpStyleEnv(this)" style="padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:500;cursor:pointer;text-align:left;color:var(--soft)">&#x1F4F1; Mobile App</button>
            <button onclick="this.classList.toggle('active');dpStyleEnv(this)" style="padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:500;cursor:pointer;text-align:left;color:var(--soft)">&#x1F4FA; CTV / Streaming</button>
            <button onclick="this.classList.toggle('active');dpStyleEnv(this)" style="padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:500;cursor:pointer;text-align:left;color:var(--soft)">&#x1F3D9; DOOH</button>
            <button onclick="this.classList.toggle('active');dpStyleEnv(this)" style="padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:500;cursor:pointer;text-align:left;color:var(--soft)">&#x1F3A7; Digital Audio</button>
            <button onclick="this.classList.toggle('active');dpStyleEnv(this)" style="padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:500;cursor:pointer;text-align:left;color:var(--soft)">&#x1F4AC; Social</button>
            <button onclick="this.classList.toggle('active');dpStyleEnv(this)" style="padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:500;cursor:pointer;text-align:left;color:var(--soft)">&#x1F4F0; Native</button>
            <button onclick="this.classList.toggle('active');dpStyleEnv(this)" style="padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:500;cursor:pointer;text-align:left;color:var(--soft)">&#x25B6; Online Video</button>
          </div>
        </div>

        <!-- Step 6 - Flight & Brand Safety -->
        <div style="margin-bottom:28px">
          <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border)">6 - Flight &amp; Brand Safety</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">Flight Start</label>
              <input type="date" id="dp-start" style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);outline:none"/>
            </div>
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">Flight End</label>
              <input type="date" id="dp-end" style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);outline:none"/>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">Frequency Cap (per user)</label>
              <input type="text" id="dp-freq" value="5" style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;color:var(--ink);outline:none"/>
            </div>
            <div style="display:flex;flex-direction:column;gap:6px">
              <label style="font-size:13px;font-weight:600;color:var(--ink)">Brand Safety</label>
              <div style="display:flex;gap:8px" id="dp-bs-grid">
                <button class="dp-toggle" onclick="dpToggle(this,'dp-bs-grid')" style="flex:1;padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;color:var(--soft)">Light</button>
                <button class="dp-toggle active" onclick="dpToggle(this,'dp-bs-grid')" style="flex:1;padding:10px 8px;border:1.5px solid var(--ink);border-radius:8px;background:var(--ink);font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;color:white">Standard</button>
                <button class="dp-toggle" onclick="dpToggle(this,'dp-bs-grid')" style="flex:1;padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;background:white;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif,sans-serif;font-weight:600;cursor:pointer;color:var(--soft)">Strict</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Deployed Agents -->
        <div id="dp-agents-section" style="display:none;margin-bottom:28px">
          <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
            <span>Agent Stack</span>
            <a href="/marketplace" style="font-size:11px;font-weight:600;color:#F97316;text-decoration:none;text-transform:none;letter-spacing:0">+ Add agents from Marketplace</a>
          </div>
          <div id="dp-agents-list"></div>
        </div>

        <div id="dp-error-banner"></div>
        <button id="dp-gen-btn" onclick="dpGenerate()" style="width:100%;padding:16px;background:var(--ink);color:white;font-family:Manrope,sans-serif;font-weight:800;font-size:16px;border:none;border-radius:12px;cursor:pointer;transition:opacity .15s">&#x1F419; Generate Campaign Plan</button>
        <div id="dp-result"></div>
      </div>
    </div>

  </main>
</div>
<!-- DELETE MODAL -->
<div class="moverlay" id="delmod">
  <div class="mbox">
    <div style="font-size:30px;margin-bottom:10px">&#x26A0;&#xFE0F;</div>
    <h3 style="font-family:Manrope;font-weight:800;font-size:17px;color:var(--ink);margin-bottom:8px">Delete account?</h3>
    <p style="font-size:13px;color:var(--muted);line-height:1.7;margin-bottom:18px">Permanently deletes your account and all data. Cannot be undone.</p>
    <div style="display:flex;gap:10px">
      <button class="btn bo" style="flex:1" onclick="document.getElementById('delmod').classList.remove('open')">Cancel</button>
      <button class="btn br" style="flex:1" onclick="delAccount()">Delete</button>
    </div>
  </div>
</div>
<script>
var U=null;
var _allCampaigns=[];
var fmt=function(d){return d?new Date(d).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}):'--';};
var greet=function(){var h=new Date().getHours();return h<12?'Good morning':h<18?'Good afternoon':'Good evening';};

function authFetch(url,opts){
  var tok=localStorage.getItem('pievra_token')||'';
  opts=opts||{};
  opts.credentials='include';
  if(tok){opts.headers=opts.headers||{};opts.headers['Authorization']='Bearer '+tok;}
  return fetch(url,opts);
}

function init(){
  authFetch('/auth/me').then(function(r){
    if(!r.ok){localStorage.removeItem('pievra_token');localStorage.removeItem('pievra_user');window.location='/signin';return null;}
    return r.json();
  }).then(function(u){
    if(!u)return;
    U=u;render(U);
    document.getElementById('load').style.display='none';
    loadCampaigns();
    if(new URLSearchParams(location.search).get('welcome')){
      al('st','Welcome! Your account is verified.','ok');
      history.replaceState({},'','/dashboard');
    }
  }).catch(function(){window.location='/signin';});
}

function render(u){
  var ini=u.email[0].toUpperCase();
  document.getElementById('av').textContent=ini;
  document.getElementById('dde').textContent=u.email;
  var pc=u.plan.charAt(0).toUpperCase()+u.plan.slice(1);
  document.getElementById('ddp').textContent=pc+' plan';
  document.getElementById('ntag').textContent=pc;
  if(u.plan==='pro')document.getElementById('ntag').classList.add('pro');
  document.getElementById('greet').textContent=greet()+' ';
  document.getElementById('osub').textContent='Welcome back, '+u.email;
  document.getElementById('aemail').textContent=u.email;
  document.getElementById('asince').textContent=fmt(u.created_at);
  document.getElementById('alast').textContent=u.last_login?fmt(u.last_login):'First session';
  var pf={community:'Unlimited agents - All protocols - Campaign planner - PDF export - Analytics'};
  document.getElementById('plfeats').textContent=pf[u.plan]||'';
  document.getElementById('plbadge').textContent='Plan: '+pc;
  document.getElementById('sem').value=u.email;
  document.getElementById('spl').value=pc;
  document.getElementById('ssi').value=fmt(u.created_at);
  updCards(u.plan);
}

function updCards(plan){
  var plans=['community'];
  plans.forEach(function(p,i){
    var c=document.getElementById('uc'+i),b=document.getElementById('pb'+i);
    if(!c||!b)return;
    if(p===plan){c.classList.add('cur');b.textContent='Current plan';b.disabled=true;b.className='btn bo';}
    else{c.classList.remove('cur');if(b.disabled){b.disabled=false;if(p==='pro'){b.textContent='Coming Soon';b.className='btn bo';b.disabled=true;}else if(p==='community'){b.textContent='Get started';b.className='btn bo';}else{b.textContent='Contact sales';b.className='btn bi';}}}
  });
}

function go(id){
  document.querySelectorAll('.pnl').forEach(function(p){p.classList.remove('on');});
  document.querySelectorAll('.sb-btn').forEach(function(b){b.classList.remove('on');});
  var pm={overview:'pov',campaigns:'pca',protocols:'ppr',agents:'pag',plan:'ppl',learn:'ppl',settings:'pst',security:'pse',manager:'sec-manager',planner:'ppln'};
  var sm={overview:'sov',campaigns:'soc',planner:'spln',protocols:'spr',agents:'sag',plan:'spl',learn:'spl',settings:'sst',security:'sse'};
  var pel=document.getElementById(pm[id]);if(pel)pel.classList.add('on');
  var sel=document.getElementById(sm[id]);if(sel)sel.classList.add('on');
  document.getElementById('ddd').classList.remove('open');
  window.scrollTo(0,0);
  if(id==='campaigns')loadCampaigns();
  if(id==='manager'){var _t=localStorage.getItem('pievra_token')||'';CampaignManager.init(_t);}
  if(id==='planner'){
    var _plan=U?U.plan:'community';
    var _isPro=true;
    var _sb=document.getElementById('dp-sandbox-msg');
    var _pm=document.getElementById('dp-pro-msg');
    if(_sb) _sb.style.display=_isPro?'none':'block';
    if(_pm) _pm.style.display=_isPro?'flex':'none';
    dpLoadAgents();
  }
}

function toggleDD(){document.getElementById('ddd').classList.toggle('open');}
document.addEventListener('click',function(e){if(!e.target.closest('.nwrap'))document.getElementById('ddd').classList.remove('open');});

function doLogout(){
  authFetch('/auth/logout',{method:'POST'}).then(function(){
    localStorage.removeItem('pievra_user');localStorage.removeItem('pievra_token');
    window.location='/signin';
  });
}

function upgr(plan){ go('learn'); }

function salesContact(){ go('learn'); }

function changePw(){
  var p1=document.getElementById('sp1').value,p2=document.getElementById('sp2').value;
  if(p1.length<8){al('st','Password must be at least 8 characters.','er');return;}
  if(p1!==p2){al('st','Passwords do not match.','er');return;}
  authFetch('/auth/reset',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:U.email})})
  .then(function(){al('st','A reset link has been sent to '+U.email,'ok');document.getElementById('sp1').value='';document.getElementById('sp2').value='';})
  .catch(function(){al('st','Network error.','er');});
}

function exportData(){
  var d={email:U.email,plan:U.plan,member_since:U.created_at,last_login:U.last_login,exported_at:new Date().toISOString()};
  var a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([JSON.stringify(d,null,2)],{type:'application/json'}));
  a.download='pievra-data.json';a.click();
  al('st','Data downloaded.','ok');
}

function delAccount(){
  authFetch('/auth/account',{method:'DELETE'}).then(function(r){
    if(r.ok){localStorage.removeItem('pievra_user');localStorage.removeItem('pievra_token');window.location='/?deleted=1';}
  }).catch(function(){al('st','Error. Please try again.','er');});
}

function al(sec,msg,type){
  var m={ca:'camp-alert',pl:'apl',st:'ast',se:'ase'};
  var el=document.getElementById(m[sec]||'ast');if(!el)return;
  el.textContent=msg;el.className='alrt '+(type==='ok'?'aok':'aer');el.style.display='block';
  if(type==='ok')setTimeout(function(){el.style.display='none';},5000);
}

// CAMPAIGNS
function loadCampaigns(){
  authFetch('/api/campaigns')
  .then(function(r){return r.ok?r.json():null;})
  .then(function(d){
    if(!d)return;
    _allCampaigns=d.campaigns||[];
    var active=_allCampaigns.filter(function(c){return c.status==='active'||c.status==='paused';});
    var drafts=_allCampaigns.filter(function(c){return c.status==='draft';});
    renderList('camp-active-list',active,'active');
    renderList('camp-draft-list',drafts,'draft');
    var sc=document.getElementById('stat-campaigns');
    if(sc)sc.textContent=_allCampaigns.length;
  }).catch(function(){});
}

function showCampTab(tab){
  var btnA=document.getElementById('tab-active'),btnD=document.getElementById('tab-draft');
  var listA=document.getElementById('camp-active-list'),listD=document.getElementById('camp-draft-list');
  if(tab==='active'){
    if(btnA){btnA.style.background='var(--ink)';btnA.style.color='white';}
    if(btnD){btnD.style.background='none';btnD.style.color='var(--muted)';}
    if(listA)listA.style.display='block';if(listD)listD.style.display='none';
  } else {
    if(btnD){btnD.style.background='var(--ink)';btnD.style.color='white';}
    if(btnA){btnA.style.background='none';btnA.style.color='var(--muted)';}
    if(listD)listD.style.display='block';if(listA)listA.style.display='none';
  }
}

function renderList(cid,camps,type){
  var el=document.getElementById(cid);if(!el)return;
  if(!camps||!camps.length){
    el.innerHTML='<div style="text-align:center;padding:36px 20px;color:var(--muted)"><div style="font-size:32px;margin-bottom:10px">'+(type==='active'?'&#x1F5FA;':'&#x1F4CB;')+'</div><div style="font-size:15px;font-weight:600;color:var(--ink);margin-bottom:6px">No '+(type==='active'?'active':'draft')+' campaigns</div><a href="#" onclick="go(&#39;planner&#39;);return false;" style="display:inline-block;margin-top:12px;padding:10px 18px;background:var(--ink);color:#fff;border-radius:10px;text-decoration:none;font-weight:600;font-size:13px">+ New Campaign</a></div>';
    return;
  }
  el.innerHTML=camps.map(function(c){
    var p=c.plan_json||{},kpis=p.projected_kpis||{};
    var imp=kpis.estimated_impressions?parseInt(kpis.estimated_impressions).toLocaleString():'--';
    var cpm=kpis.estimated_cpm?'$'+kpis.estimated_cpm:'--';
    var roas=kpis.estimated_roas?kpis.estimated_roas+'x':'--';
    var sc={'active':'#166534','draft':'#713f12','paused':'#1e40af'}[c.status]||'#3d4460';
    var sb={'active':'#dcfce7','draft':'#fef9c3','paused':'#dbeafe'}[c.status]||'#f4f5f9';
    return '<div style="background:#fff;border:1px solid var(--border);border-radius:14px;padding:20px;margin-bottom:12px">'
      +'<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px">'
      +'<div><div style="font-family:Manrope,sans-serif;font-weight:700;font-size:15px;color:var(--ink)">'+(c.brand||'Untitled')+' - '+(c.campaign_name||'Campaign')+'</div>'
      +'<div style="font-size:12px;color:var(--muted);margin-top:3px">'+c.objective+' - '+c.buying_model+' - $'+c.budget+' - '+fmt(c.created_at)+'</div></div>'
      +'<div style="display:flex;align-items:center;gap:8px">'
      +'<span style="font-size:11px;font-weight:700;color:'+sc+';background:'+sb+';padding:3px 10px;border-radius:20px">'+c.status.toUpperCase()+'</span>'
      +'<button onclick="window.activateCampaign('+c.id+',(c.campaign_sn||\'\'),(c.flight_sn||\'\'),(c.budget||0))" style="background:#F97316;color:white;border:none;font-size:12px;font-weight:700;padding:5px 12px;border-radius:8px;cursor:pointer;margin-right:6px">&#x1F680; Activate</button>'
      +'<button onclick="openEdit('+c.id+')" style="background:none;border:1px solid var(--border);color:var(--soft);font-size:12px;font-weight:600;padding:5px 12px;border-radius:8px;cursor:pointer">Edit</button>'
      +'</div></div>'
      +(kpis.estimated_impressions?'<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px">'
        +'<div style="background:var(--surf);border-radius:8px;padding:10px;text-align:center"><div style="font-weight:700;font-size:15px;color:#F97316">'+imp+'</div><div style="font-size:11px;color:var(--muted)">Impressions</div></div>'
        +'<div style="background:var(--surf);border-radius:8px;padding:10px;text-align:center"><div style="font-weight:700;font-size:15px;color:var(--ink)">'+cpm+'</div><div style="font-size:11px;color:var(--muted)">CPM</div></div>'
        +'<div style="background:var(--surf);border-radius:8px;padding:10px;text-align:center"><div style="font-weight:700;font-size:15px;color:var(--ink)">'+roas+'</div><div style="font-size:11px;color:var(--muted)">ROAS</div></div>'
        +'</div>':'')
      +'</div>';
  }).join('');
}

function openEdit(id){
  var c=_allCampaigns.find(function(x){return x.id===id;});if(!c)return;
  document.getElementById('edit-id').value=id;
  document.getElementById('edit-brand').value=c.brand||'';
  document.getElementById('edit-name').value=c.campaign_name||'';
  document.getElementById('edit-desc').value=c.description||'';
  document.getElementById('edit-budget').value=c.budget||'50000';
  document.getElementById('edit-kpi').value=c.kpi||'';
  document.getElementById('edit-obj').value=c.objective||'Awareness';
  document.getElementById('edit-buy').value=c.buying_model||'CPM';
  document.getElementById('edit-status').value=c.status||'active';
  document.getElementById('editmod').classList.add('open');
}

function saveEdit(){
  var id=document.getElementById('edit-id').value;if(!id)return;
  var data={brand:document.getElementById('edit-brand').value,campaign_name:document.getElementById('edit-name').value,description:document.getElementById('edit-desc').value,budget:document.getElementById('edit-budget').value,kpi:document.getElementById('edit-kpi').value,objective:document.getElementById('edit-obj').value,buying_model:document.getElementById('edit-buy').value,status:document.getElementById('edit-status').value,protocols:['AdCP','MCP','ARTF']};
  authFetch('/api/campaign/'+id,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)})
  .then(function(){document.getElementById('editmod').classList.remove('open');loadCampaigns();al('ca','Campaign updated.','ok');})
  .catch(function(){alert('Error saving.');});
}

function confirmDeleteCamp(){
  if(!confirm('Delete this campaign?'))return;
  var id=document.getElementById('edit-id').value;
  authFetch('/api/campaign/'+id,{method:'DELETE'})
  .then(function(){document.getElementById('editmod').classList.remove('open');loadCampaigns();})
  .catch(function(){alert('Error.');});
}

init();

// ── DASHBOARD PLANNER ──────────────────────────────────────────────────


function dpToggle(btn,gridId){
  var grid=document.getElementById(gridId);
  if(!grid) return;
  grid.querySelectorAll('.dp-toggle').forEach(function(b){
    b.classList.remove('active');
    b.style.background='white';b.style.color='#3d4460';b.style.borderColor='#e2e4ed';
  });
  btn.classList.add('active');
  btn.style.background='#0a0e1a';btn.style.color='white';btn.style.borderColor='#0a0e1a';
}

function dpStyleInterest(btn){
  if(btn.classList.contains('active')){
    btn.style.background='#0a0e1a';btn.style.color='white';btn.style.borderColor='#0a0e1a';
  } else {
    btn.style.background='white';btn.style.color='#3d4460';btn.style.borderColor='#e2e4ed';
  }
}

function dpStyleEnv(btn){
  if(btn.classList.contains('active')){
    btn.style.background='#e0faf6';btn.style.color='#009e86';btn.style.borderColor='#F97316';
  } else {
    btn.style.background='white';btn.style.color='#3d4460';btn.style.borderColor='#e2e4ed';
  }
}

function dpGetActive(gridId){
  var el=document.querySelector('#'+gridId+' .dp-toggle.active');
  return el?el.childNodes[0].textContent.trim():null;
}

function dpCollectForm(){
  var countries=[];
  var cs=document.getElementById('dp-country');
  if(cs) Array.from(cs.selectedOptions).forEach(function(o){countries.push(o.value);});
  var envs=[];
  document.querySelectorAll('#dp-env-grid button.active').forEach(function(b){
    envs.push(b.textContent.trim().replace(/^[^\w]/,'').trim());
  });
  var interests=[];
  document.querySelectorAll('#dp-interests button.active').forEach(function(b){interests.push(b.textContent.trim());});
  return {
    brand:(document.getElementById('dp-brand')||{}).value||'',
    campaign_name:(document.getElementById('dp-name')||{}).value||'',
    description:(document.getElementById('dp-desc')||{}).value||'',
    budget:(document.getElementById('dp-budget')||{}).value||'50000',
    kpi:(document.getElementById('dp-kpi')||{}).value||'ROAS > 2.5',
    objective:dpGetActive('dp-obj-grid')||'Awareness',
    buying_model:dpGetActive('dp-buy-grid')||'CPM',
    age_range:(document.getElementById('dp-age')||{}).value||'All Ages',
    countries:countries,
    country:countries.join(', '),
    city:(document.getElementById('dp-city')||{}).value||'',
    flight_start:(document.getElementById('dp-start')||{}).value||'',
    flight_end:(document.getElementById('dp-end')||{}).value||'',
    brand_safety:dpGetActive('dp-bs-grid')||'Standard',
    environments:envs.length?envs:['Web Display'],
    audiences:interests,
    protocols:['AdCP','MCP','ARTF'],
    deployed_agents:JSON.parse(localStorage.getItem('pievra_deploy_agents')||'[]')
  };
}

function dpLoadAgents(){
  var agents=JSON.parse(localStorage.getItem('pievra_deploy_agents')||'[]');
  var section=document.getElementById('dp-agents-section');
  var list=document.getElementById('dp-agents-list');
  if(!section||!list) return;
  if(!agents.length){section.style.display='none';return;}
  section.style.display='block';
  var PROTO_CLS={AdCP:'#dbeafe',MCP:'#f3e8ff',UCP:'#dcfce7',ARTF:'#fef9c3',A2A:'#ffe4e6'};
  var PROTO_CLR={AdCP:'#1e40af',MCP:'#7e22ce',UCP:'#166534',ARTF:'#854d0e',A2A:'#be123c'};
  list.innerHTML=agents.map(function(a){
    var protos=a.protocols.map(function(p){return '<span style="font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px;background:'+(PROTO_CLS[p]||'#f4f5f9')+';color:'+(PROTO_CLR[p]||'#3d4460')+'">'+p+'</span>';}).join(' ');
    return '<div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:#f4f5f9;border-radius:10px;margin-bottom:8px">'
      +'<div style="display:flex;align-items:center;gap:10px">'
      +'<span style="font-size:20px">'+(a.icon||'🤖')+'</span>'
      +'<div><div style="font-weight:600;font-size:14px;color:#18181B">'+a.name+'</div>'
      +'<div style="font-size:12px;color:#7a829e">'+a.steward+' · Score: '+a.score+'</div></div>'
      +'</div>'
      +'<div style="display:flex;align-items:center;gap:8px">'
      +protos
      +' <button onclick="dpRemoveAgent('+a.id+')" style="border:none;background:none;color:#dc2626;font-size:16px;cursor:pointer;padding:4px" title="Remove">×</button>'
      +'</div></div>';
  }).join('');
}

function dpRemoveAgent(id){
  var agents=JSON.parse(localStorage.getItem('pievra_deploy_agents')||'[]');
  agents=agents.filter(function(a){return a.id!==id;});
  localStorage.setItem('pievra_deploy_agents',JSON.stringify(agents));
  dpLoadAgents();
}

function dpGenerate(){
  var brand=document.getElementById('dp-brand');
  var name=document.getElementById('dp-name');
  var desc=document.getElementById('dp-desc');
  var eb=document.getElementById('dp-error-banner');
  if(eb) eb.innerHTML='';
  [brand,name,desc].forEach(function(el){if(el){el.style.border='';el.style.background='';}});
  var errors=false;
  if(!brand||!brand.value.trim()){brand.style.border='2px solid #dc2626';brand.style.background='#fef2f2';errors=true;}
  if(!name||!name.value.trim()){name.style.border='2px solid #dc2626';name.style.background='#fef2f2';errors=true;}
  if(!desc||!desc.value.trim()){desc.style.border='2px solid #dc2626';desc.style.background='#fef2f2';errors=true;}
  if(errors){
    if(eb) eb.innerHTML='<div style="background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:12px 16px;border-radius:10px;font-size:14px;margin-bottom:12px;display:flex;align-items:center;gap:10px"><span style="font-size:18px">&#x26A0;</span><span>Please complete the required fields highlighted in red.</span></div>';
    return;
  }
  var btn=document.getElementById('dp-gen-btn');
  if(btn){btn.textContent='Generating...';btn.disabled=true;btn.style.opacity='0.85';}
  var tok=localStorage.getItem('pievra_token')||'';
  var data=dpCollectForm();
  data.status='paused';
  var hdrs={'Content-Type':'application/json'};
  if(tok) hdrs['Authorization']='Bearer '+tok;
  fetch('/api/campaign',{method:'POST',credentials:'include',headers:hdrs,body:JSON.stringify(data)})
  .then(function(r){return r.json();})
  .then(function(d){
    if(btn){btn.innerHTML='&#x1F419; Generate Campaign Plan';btn.disabled=false;btn.style.opacity='1';}
    if(d.plan){
      dpShowResult(d.plan,d.campaign_id);
    } else {
      var eb=document.getElementById('dp-error-banner');
      if(eb) eb.innerHTML='<div style="background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:12px 16px;border-radius:10px;font-size:14px;margin-bottom:12px">'+(d.error==='Not authenticated'?'Session expired. Redirecting...':'Error generating plan. Please try again.')+'</div>';
      if(d.error==='Not authenticated') setTimeout(function(){window.location='/signin';},2000);
    }
  })
  .catch(function(){
    if(btn){btn.innerHTML='&#x1F419; Generate Campaign Plan';btn.disabled=false;btn.style.opacity='1';}
    var eb=document.getElementById('dp-error-banner');
    if(eb) eb.innerHTML='<div style="background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:12px 16px;border-radius:10px;font-size:14px;margin-bottom:12px">Network error. Please try again.</div>';
  });
}

function dpShowResult(p,campaignId){
  var imp=parseInt(p.projected_kpis.estimated_impressions).toLocaleString();
  var el=document.getElementById('dp-result');
  if(!el) return;
  el.innerHTML=
    '<div style="background:#fff;border:2px solid #F97316;border-radius:16px;padding:28px;margin-top:20px">'
    +'<div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px">'
    +'<div style="display:flex;align-items:center;gap:12px">'
    +'<div style="width:40px;height:40px;background:#F97316;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px">&#x2705;</div>'
    +'<div><div style="font-family:Manrope,sans-serif;font-weight:800;font-size:18px;color:#18181B">'+(p.brand||'Campaign')+' Plan Ready</div>'
    +'<div style="font-size:13px;color:#7a829e">'+p.objective+' · '+p.buying_model+(campaignId?' · #'+campaignId:'')+'</div></div></div>'
    +'<div style="display:flex;align-items:center;gap:10px">'
    +'<span style="background:#dbeafe;color:#1e40af;font-size:12px;font-weight:700;padding:4px 12px;border-radius:20px">&#x23F8; PAUSED</span>'
    +'<button onclick="go(\'campaigns\')" class="btn bi" style="white-space:nowrap">View in Campaigns &#x2192;</button>'
    +'</div></div>'
    +'<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:18px">'
    +'<div style="background:#f4f5f9;border-radius:12px;padding:16px;text-align:center"><div style="font-family:Manrope,sans-serif;font-weight:800;font-size:22px;color:#F97316">'+imp+'</div><div style="font-size:12px;color:#7a829e;margin-top:3px">Impressions</div></div>'
    +'<div style="background:#f4f5f9;border-radius:12px;padding:16px;text-align:center"><div style="font-family:Manrope,sans-serif;font-weight:800;font-size:22px;color:#18181B">$'+p.projected_kpis.estimated_cpm+'</div><div style="font-size:12px;color:#7a829e;margin-top:3px">CPM</div></div>'
    +'<div style="background:#f4f5f9;border-radius:12px;padding:16px;text-align:center"><div style="font-family:Manrope,sans-serif;font-weight:800;font-size:22px;color:#18181B">'+p.projected_kpis.estimated_roas+'x</div><div style="font-size:12px;color:#7a829e;margin-top:3px">ROAS</div></div>'
    +'<div style="background:#f4f5f9;border-radius:12px;padding:16px;text-align:center"><div style="font-family:Manrope,sans-serif;font-weight:800;font-size:22px;color:#18181B">23%</div><div style="font-size:12px;color:#7a829e;margin-top:3px">CPM saving</div></div>'
    +'</div>'
    +'<div style="font-size:12px;font-weight:700;color:#18181B;letter-spacing:.06em;margin-bottom:10px">RECOMMENDED AGENTS</div>'
    +p.recommended_agents.map(function(a){
      return '<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:#f4f5f9;border-radius:10px;margin-bottom:6px">'
        +'<div><div style="font-size:14px;font-weight:600;color:#18181B">'+a.name+'</div>'
        +'<div style="font-size:12px;color:#7a829e">'+a.protocol+' · Floor $'+a.cpm_floor+'</div></div>'
        +'<span style="font-size:11px;font-weight:700;color:#166534;background:#dcfce7;padding:4px 9px;border-radius:20px">'+Math.round(a.viewability*100)+'% viewability</span>'
        +'</div>';
    }).join('')
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:14px">'
    +'<div style="padding:12px 14px;background:#e0faf6;border-radius:10px;font-size:13px;color:#F97316;font-weight:600">&#x26A1; '+p.arbitrage_saving+'</div>'
    +'<div style="padding:12px 14px;background:#f4f5f9;border-radius:10px;font-size:13px;color:#3d4460">'+p.flight_recommendation+'</div>'
    +'</div>'
    +'<div style="margin-top:14px;display:flex;gap:10px">'
    +'<button onclick="go(\'campaigns\')" class="btn bi" style="flex:1">View in Campaigns</button>'
    +'<button onclick="dpReset()" class="btn bo" style="flex:1">New Campaign</button>'
    +'</div></div>';
  el.scrollIntoView({behavior:'smooth',block:'start'});
  dpHighlightReadiness();
}

function dpReset(){
  var el=document.getElementById('dp-result');
  if(el) el.innerHTML='';
  ['dp-brand','dp-name','dp-desc'].forEach(function(id){var e=document.getElementById(id);if(e)e.value='';});
  document.getElementById('dp-budget').value='50000';
  document.getElementById('dp-kpi').value='ROAS > 2.5';
  // Clear readiness highlights
  document.querySelectorAll('.dp-step-status').forEach(function(s){s.remove();});
  document.querySelectorAll('.dp-step-box').forEach(function(b){b.style.border='';});
  var rl=document.getElementById('dp-readiness');if(rl) rl.remove();
}

function dpHighlightReadiness(){
  // Remove previous indicators
  document.querySelectorAll('.dp-step-status').forEach(function(s){s.remove();});
  document.querySelectorAll('.dp-step-box').forEach(function(b){b.style.border='';});
  var rl=document.getElementById('dp-readiness');if(rl) rl.remove();

  var brand=(document.getElementById('dp-brand')||{}).value||'';
  var name=(document.getElementById('dp-name')||{}).value||'';
  var desc=(document.getElementById('dp-desc')||{}).value||'';
  var budget=(document.getElementById('dp-budget')||{}).value||'';
  var start=(document.getElementById('dp-start')||{}).value||'';
  var end=(document.getElementById('dp-end')||{}).value||'';
  var cs=document.getElementById('dp-country');
  var countries=cs?Array.from(cs.selectedOptions).map(function(o){return o.value;}):[];
  var envs=document.querySelectorAll('#dp-env-grid button.active');

  var checks=[
    {label:'Advertiser / Brand',ok:!!brand.trim(),section:1,tip:'Required to identify the campaign'},
    {label:'Campaign Name',ok:!!name.trim(),section:1,tip:'Required to create the campaign'},
    {label:'Campaign Description',ok:!!desc.trim(),section:1,tip:'Describe goals and messaging'},
    {label:'Budget set',ok:!!budget.trim()&&parseFloat(budget)>0,section:2,tip:'Budget must be greater than $0'},
    {label:'Geo targeting selected',ok:countries.length>0,section:4,tip:'Select at least one country to target'},
    {label:'Environments selected',ok:envs.length>0,section:5,tip:'Choose where ads will be served'},
    {label:'Flight start date',ok:!!start,section:6,tip:'Set when the campaign should start delivering'},
    {label:'Flight end date',ok:!!end,section:6,tip:'Set when the campaign should stop delivering'},
  ];

  var ready=checks.filter(function(c){return c.ok;}).length;
  var total=checks.length;
  var allOk=ready===total;

  // Build readiness panel
  var panel=document.createElement('div');
  panel.id='dp-readiness';
  panel.style.cssText='background:white;border:1px solid #e2e4ed;border-radius:14px;padding:24px;margin-top:20px';
  var headerColor=allOk?'#166534':'#92400e';
  var headerBg=allOk?'#dcfce7':'#fef9c3';
  var headerBorder=allOk?'#bbf7d0':'#fde047';
  var headerIcon=allOk?'&#x2705;':'&#x26A0;';
  var headerText=allOk?'Campaign is ready to go live':'Complete these items before going live';
  panel.innerHTML=
    '<div style="background:'+headerBg+';border:1px solid '+headerBorder+';border-radius:10px;padding:14px 16px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between">'
    +'<div style="display:flex;align-items:center;gap:10px"><span style="font-size:18px">'+headerIcon+'</span><span style="font-size:14px;font-weight:700;color:'+headerColor+'">'+headerText+'</span></div>'
    +'<span style="font-size:13px;font-weight:600;color:'+headerColor+'">'+ready+'/'+total+' completed</span>'
    +'</div>'
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">'
    +checks.map(function(c){
      var icon=c.ok?'<span style="color:#166534;font-weight:700">&#x2713;</span>':'<span style="color:#dc2626;font-weight:700">&#x2717;</span>';
      var bg=c.ok?'#f0fdf4':'#fef2f2';
      var border=c.ok?'#bbf7d0':'#fecaca';
      var textColor=c.ok?'#166534':'#991b1b';
      return '<div style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:'+bg+';border:1px solid '+border+';border-radius:8px;cursor:'+(c.ok?'default':'pointer')+'" '+(c.ok?'':'onclick="dpScrollToSection('+c.section+')"')+'>'
        +icon
        +'<div><div style="font-size:13px;font-weight:600;color:'+textColor+'">'+c.label+'</div>'
        +(c.ok?'':'<div style="font-size:11px;color:#991b1b;margin-top:1px">'+c.tip+'</div>')
        +'</div></div>';
    }).join('')
    +'</div>';

  var result=document.getElementById('dp-result');
  if(result) result.appendChild(panel);

  // Highlight incomplete form sections
  var sectionMap={};
  checks.forEach(function(c){if(!c.ok){sectionMap[c.section]=true;}});
  var steps=document.querySelectorAll('#dp-form > div[style*="margin-bottom:28px"]');
  steps.forEach(function(step,i){
    var secNum=i+1;
    var stepLabel=step.querySelector('div[style*="letter-spacing"]');
    if(!stepLabel) return;
    // Remove old status
    var old=stepLabel.querySelector('.dp-step-status');if(old) old.remove();
    var badge=document.createElement('span');
    badge.className='dp-step-status';
    if(sectionMap[secNum]){
      badge.style.cssText='float:right;font-size:11px;font-weight:700;color:#dc2626;background:#fef2f2;border:1px solid #fecaca;padding:2px 8px;border-radius:6px';
      badge.textContent='Incomplete';
      step.style.border='2px solid #fecaca';
      step.style.borderRadius='12px';
      step.style.padding='16px';
      step.classList.add('dp-step-box');
    } else {
      badge.style.cssText='float:right;font-size:11px;font-weight:700;color:#166534;background:#dcfce7;border:1px solid #bbf7d0;padding:2px 8px;border-radius:6px';
      badge.textContent='Complete';
    }
    stepLabel.appendChild(badge);
  });
}

function dpScrollToSection(secNum){
  var steps=document.querySelectorAll('#dp-form > div[style*="margin-bottom:28px"]');
  var step=steps[secNum-1];
  if(step) step.scrollIntoView({behavior:'smooth',block:'center'});
}

function dpAddChatMsg(role,text){
  var msgs=document.getElementById('dp-chat-messages');
  if(!msgs) return;
  var d=document.createElement('div');
  d.style.cssText='margin-bottom:10px;display:flex;gap:8px;align-items:flex-start';
  var icon=role==='user'?'You':'AI';
  var bg=role==='user'?'rgba(255,255,255,.08)':'rgba(0,196,167,.12)';
  var color=role==='user'?'rgba(255,255,255,.9)':'#F97316';
  d.innerHTML='<span style="font-size:13px;font-weight:700;flex-shrink:0;color:'+color+'">'+icon+'</span>'
    +'<div style="background:'+bg+';border-radius:8px;padding:8px 12px;font-size:13px;color:'+color+';line-height:1.5;flex:1">'+text+'</div>';
  msgs.appendChild(d);
  msgs.scrollTop=msgs.scrollHeight;
}

function dpSendChat(){
  var inp=document.getElementById('dp-chat-input');
  var btn=document.getElementById('dp-chat-send-btn');
  if(!inp||!inp.value.trim()) return;
  var msg=inp.value.trim();
  var tok=localStorage.getItem('pievra_token')||'';
  dpAddChatMsg('user',msg);
  inp.value='';
  if(btn){btn.textContent='Thinking...';btn.disabled=true;}
  var hdrs={'Content-Type':'application/json'};
  if(tok) hdrs['Authorization']='Bearer '+tok;
  fetch('/api/campaign/parse',{method:'POST',credentials:'include',headers:hdrs,body:JSON.stringify({message:msg})})
  .then(function(r){return r.json();})
  .then(function(d){
    if(btn){btn.textContent='Generate \u2192';btn.disabled=false;}
    if(d.plan){
      dpAddChatMsg('assistant','Campaign plan generated!');
      dpShowResult(d.plan,d.campaign_id);
    } else if(d.parsed){
      dpFillFromParsed(d.parsed);
      dpAddChatMsg('assistant','Campaign form filled. Review and click Generate.');
      setTimeout(function(){var f=document.getElementById('dp-form');if(f)f.scrollIntoView({behavior:'smooth',block:'start'});},1000);
    } else {
      dpAddChatMsg('assistant','Processing your brief...');
      var hdrs2={'Content-Type':'application/json'};
      if(tok) hdrs2['Authorization']='Bearer '+tok;
      fetch('/api/campaign',{method:'POST',credentials:'include',headers:hdrs2,body:JSON.stringify({brand:'',campaign_name:'Chat Campaign',description:msg,objective:'Awareness',buying_model:'CPM',budget:'50000',status:'paused',protocols:['AdCP','MCP','ARTF']})})
      .then(function(r){return r.json();})
      .then(function(d2){if(d2.plan){dpShowResult(d2.plan,d2.campaign_id);}});
    }
  })
  .catch(function(){
    if(btn){btn.textContent='Generate \u2192';btn.disabled=false;}
    dpAddChatMsg('assistant','Network error. Please try again.');
  });
}

function dpFillFromParsed(p){
  if(p.brand) document.getElementById('dp-brand').value=p.brand;
  if(p.campaign_name) document.getElementById('dp-name').value=p.campaign_name;
  if(p.description) document.getElementById('dp-desc').value=p.description;
  if(p.budget) document.getElementById('dp-budget').value=p.budget;
  if(p.kpi) document.getElementById('dp-kpi').value=p.kpi;
}

</script>

</body></html>
