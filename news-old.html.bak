<script>
const protos = ['adcp','mcp','ucp','artf','a2a'];
let loggedIn = false, user = null;
const counts = {};
protos.forEach(p => counts[p] = 0);

function openModal() { document.getElementById('signupModal').classList.add('active'); }
function closeModal() { document.getElementById('signupModal').classList.remove('active'); }
document.getElementById('signupModal').addEventListener('click', e => { if (e.target.id === 'signupModal') closeModal(); });

function submitSignup() {
  const e = document.getElementById('mEmail').value;
  const n = document.getElementById('mName').value.trim();
  if (!e || !e.includes('@') || !n) { alert('Please enter your name and a valid work email.'); return; }
  login(n, e); closeModal();
}
function doLogin() {
  const n = prompt('Enter your name to sign in:');
  if (n && n.trim()) login(n.trim(), 'user@example.com');
}
function login(name, email) {
  loggedIn = true;
  user = { name, email, initials: name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2) };
  protos.forEach(p => unlockComments(p, true));
}

function unlockComments(p, silent) {
  if (!loggedIn) { if (!silent) openModal(); return; }
  const g = document.getElementById('gate-'+p);
  const f = document.getElementById('form-'+p);
  if (g) g.style.display = 'none';
  if (f) f.classList.add('active');
}

function upChar(p) {
  const ta = document.getElementById('ta-'+p);
  const ch = document.getElementById('ch-'+p);
  if (ta && ch) ch.textContent = ta.value.length + ' / 500';
}

function postComment(p) {
  if (!loggedIn) { openModal(); return; }
  const ta = document.getElementById('ta-'+p);
  if (!ta || !ta.value.trim()) return;
  const text = ta.value.trim().slice(0, 500);
  const list = document.getElementById('list-'+p);
  const empty = list.querySelector('.empty-c');
  if (empty) empty.remove();
  const cols = ['#18181B','#065f46','#1d4ed8','#9d174d','#5b21b6','#7c3aed','#0369a1','#9a3412'];
  const col = cols[Math.floor(Math.random()*cols.length)];
  const now = new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'}) + ' today';
  const el = document.createElement('div');
  el.className = 'comment';
  el.innerHTML = `<div class="c-av" style="background:${col}">${xss(user.initials)}</div><div class="c-bubble"><div class="c-meta"><span class="c-name">${xss(user.name)}</span><span class="c-role">Pievra Community</span><span class="c-time">${now}</span></div><div class="c-text">${xss(text)}</div><div class="c-actions"><button class="c-btn" onclick="like(this)">👍 0</button></div></div>`;
  list.appendChild(el);
  ta.value = ''; upChar(p);
  counts[p]++;
  const cnt = document.getElementById('cnt-'+p);
  if (cnt) cnt.textContent = counts[p] + ' comment' + (counts[p]!==1?'s':'');
  gtag && gtag('event','comment_posted',{event_category:'community',event_label:p});
}

function like(btn) {
  if (!loggedIn) { openModal(); return; }
  const m = btn.textContent.match(/\d+/);
  if (m) btn.textContent = '👍 '+(parseInt(m[0])+1);
}

function xss(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function toggleArticle(btn, id) {
  const b = document.getElementById(id);
  const open = b.classList.contains('open');
  b.classList.toggle('open', !open);
  btn.classList.toggle('open', !open);
  btn.innerHTML = open ? 'Read full analysis <span class="arr">›</span>' : 'Collapse <span class="arr" style="transform:rotate(90deg);display:inline-block">›</span>';
  if (!open) gtag && gtag('event','article_expand',{event_category:'engagement',event_label:id});
}

var currentNewsFilter = 'all';
function filterArticles(btn, proto) {
  currentNewsFilter = proto;
  if (btn) { document.querySelectorAll('.nf').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); }
  document.querySelectorAll('.article-card').forEach(c => { c.style.display=(proto==='all'||c.dataset.proto===proto)?'':'none'; });
  // Also filter and re-render external feed
  extPage = 0;
  var feed = document.getElementById('ext-feed');
  while (feed.firstChild) feed.removeChild(feed.firstChild);
  loadExtArticles();
}

function subNewsletter() {
  const i = document.getElementById('nl-email');
  if (!i||!i.value||!i.value.includes('@')) { if(i) i.style.outline='2px solid #ef4444'; return; }
  i.style.outline='2px solid #22c55e';
  document.querySelector('.btn-nl').textContent='✓ Subscribed!';
  gtag && gtag('event','newsletter_subscribe',{event_category:'conversion'});
}

