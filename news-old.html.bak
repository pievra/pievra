  {"title": "Verizon Casts Heated Rivalry&#8217;s Connor Storrie in Cabin Thriller Ad With a Twist Ending", "url": "https://www.adweek.com/creativity/verizon-casts-heated-rivalry-star-connor-storrie-in-cabin-thriller-ad/", "source": "Ad Age", "color": "#DC2626", "date": "Mar 31, 2026", "summary": "Heated Rivalry breakout star Connor Storrie fronts a Verizon horror-style ad directed by Nia DaCosta."},
  {"title": "Ray Media Advisory Wants To Fix Agency-Client Relationships Before They Break", "url": "https://www.adweek.com/agencies/ray-media-advisory-wants-to-fix-agency-client-relationships-before-they-break/", "source": "Ad Age", "color": "#DC2626", "date": "Mar 31, 2026", "summary": "New Partnership Accelerator proactively addresses tensions and pressures before things go south"}
];

var PROTO_KEYWORDS = {
  adcp: ['adcp','ad context protocol','agentic advertising standard'],
  mcp: ['mcp','model context protocol','anthropic mcp'],
  ucp: ['ucp','agentic audiences','user context protocol','liveramp'],
  artf: ['artf','agentic rtb','real-time bidding','openrtb'],
  a2a: ['a2a','agent2agent','agent-to-agent','google a2a']
};

var EXT_PER_PAGE = 12;
var extPage = 0;
var extLoading = false;

function filterExtArticles(articles) {
  if (currentNewsFilter === 'all') return articles;
  var kws = PROTO_KEYWORDS[currentNewsFilter] || [];
  return articles.filter(function(a) {
    var text = (a.title + ' ' + (a.summary || '')).toLowerCase();
    return kws.some(function(kw) { return text.indexOf(kw) !== -1; });
  });
}

function createExtCard(a) {
  var card = document.createElement('a');
  card.className = 'ext-card';
  card.href = a.url;
  card.target = '_blank';
  card.rel = 'noopener';

  var meta = document.createElement('div');
  meta.className = 'ext-meta';

  var source = document.createElement('span');
  source.className = 'ext-source';
  source.style.color = a.color || '#71717A';
  source.textContent = a.source;
  meta.appendChild(source);

  var date = document.createElement('span');
  date.className = 'ext-date';
  date.textContent = a.date || '';
  meta.appendChild(date);

  // Share buttons (stop propagation so card link doesn't fire)
  var shares = document.createElement('div');
  shares.className = 'share-btns';
  shares.style.marginLeft = 'auto';

  var liUrl = 'https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(a.url);
  var xUrl = 'https://twitter.com/intent/tweet?url=' + encodeURIComponent(a.url) + '&text=' + encodeURIComponent(a.title);

  var liBtn = document.createElement('a');
  liBtn.className = 'share-btn share-btn-li';
  liBtn.href = liUrl;
  liBtn.target = '_blank';
  liBtn.title = 'Share on LinkedIn';
  liBtn.onclick = function(e) { e.stopPropagation(); };
  liBtn.innerHTML = '<svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>';
  shares.appendChild(liBtn);

  var xBtn = document.createElement('a');
  xBtn.className = 'share-btn share-btn-x';
  xBtn.href = xUrl;
  xBtn.target = '_blank';
  xBtn.title = 'Share on X';
  xBtn.onclick = function(e) { e.stopPropagation(); };
  xBtn.innerHTML = '<svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>';
  shares.appendChild(xBtn);

  meta.appendChild(shares);
  card.appendChild(meta);

  var title = document.createElement('div');
  title.className = 'ext-title';
  title.textContent = a.title;
  card.appendChild(title);

  if (a.summary) {
    var summary = document.createElement('div');
    summary.className = 'ext-summary';
    summary.textContent = a.summary.length > 180 ? a.summary.slice(0, 180) + '...' : a.summary;
    card.appendChild(summary);
  }

  var foot = document.createElement('div');
  foot.className = 'ext-foot';
  var rm = document.createElement('span');
  rm.className = 'ext-readmore';
  rm.textContent = 'Read on ' + a.source + ' \u2192';
  foot.appendChild(rm);
  card.appendChild(foot);

  return card;
}

function loadExtArticles() {
  var filtered = filterExtArticles(INDUSTRY_NEWS);
  var start = extPage * EXT_PER_PAGE;
  var batch = filtered.slice(start, start + EXT_PER_PAGE);
  var feed = document.getElementById('ext-feed');
  var loader = document.getElementById('feed-loader');

  batch.forEach(function(a) {
    feed.appendChild(createExtCard(a));
  });

  extPage++;
  // Hide loader if no more articles
  if (start + EXT_PER_PAGE >= filtered.length) {
    loader.textContent = filtered.length === 0 ? 'No industry articles match this filter.' : 'You\'re all caught up.';
  } else {
    loader.textContent = 'Scroll for more...';
  }
  extLoading = false;
}

// Infinite scroll
window.addEventListener('scroll', function() {
  if (extLoading) return;
  var loader = document.getElementById('feed-loader');
  if (!loader) return;
  var rect = loader.getBoundingClientRect();
  if (rect.top < window.innerHeight + 200) {
    var filtered = filterExtArticles(INDUSTRY_NEWS);
    if (extPage * EXT_PER_PAGE < filtered.length) {
      extLoading = true;
      loadExtArticles();
    }
  }
});

// Initial load
loadExtArticles();
</script>
</body>
</html>
