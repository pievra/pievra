<script>
function handleSubscribe() {
  const email = document.getElementById('sub-email').value;
  const name = document.getElementById('sub-firstname').value;
  const consentNewsletter = document.getElementById('consent-newsletter').checked;
  const consentPrivacy = document.getElementById('consent-privacy').checked;

  // Validation
  if (!name.trim()) { alert('Please enter your first name.'); return; }
  if (!email || !email.includes('@')) { alert('Please enter a valid work email address.'); return; }
  if (!consentNewsletter) { alert('Newsletter consent is required to subscribe.'); return; }
  if (!consentPrivacy) { alert('You must accept the Privacy Policy to subscribe.'); return; }

  // Log consent (production: send to backend with timestamp)
  const consentRecord = {
    email,
    name: name.trim(),
    role: document.getElementById('sub-role').value,
    consent_newsletter: true,
    consent_privacy: true,
    consent_marketing: document.getElementById('consent-marketing').checked,
    timestamp: new Date().toISOString(),
    ip_collected: true,
    consent_id: 'c_' + Math.random().toString(36).substr(2,12),
    source: 'pievra.com/newsletter',
    gdpr_basis: 'consent_art6_1a'
  };
  console.log('GDPR consent record:', JSON.stringify(consentRecord));

  // GA4 event
  gtag && gtag('event', 'newsletter_subscribe', {
    event_category: 'conversion',
    event_label: consentRecord.role || 'unknown'
  });

  // Show success
  document.getElementById('subscribe-form').style.display = 'none';
  document.getElementById('success-state').style.display = 'block';

  // Production: POST to /api/newsletter/subscribe with consentRecord
}
</script>
</body>
