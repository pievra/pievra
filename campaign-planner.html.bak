<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Campaign Planner - Pievra</title>
<meta name="description" content="Plan and simulate a cross-protocol AI agent campaign. Define your advertiser, audience, buying model and environments. Pievra assembles a coherent agent stack and generates a downloadable media plan."/>
<link rel="canonical" href="https://pievra.com/campaign-planner"/>

<!-- GA4 Analytics - consent-gated (GDPR/CNIL compliant) -->
<script src="/static/consent.js"></script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
:root {
  --ink: #0a0e1a;
  --ink-soft: #3d4460;
  --ink-muted: #7a829e;
  --surface: #ffffff;
  --surface-2: #f4f5f9;
  --surface-3: #ebedf5;
  --teal: #00c4a7;
  --teal-dark: #009e86;
  --teal-light: #e0faf6;
  --coral: #ff5e3a;
  --navy: #0a0e1a;
  --blue: #2563eb;
  --border: #e2e4ed;
  --radius: 12px;
  --radius-lg: 20px;
  --shadow: 0 4px 24px rgba(10,14,26,0.08);
  --shadow-lg: 0 12px 48px rgba(10,14,26,0.14);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', sans-serif;
  background: var(--surface);
  color: var(--ink);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}
h1,h2,h3,h4,h5 { font-family: 'Manrope', sans-serif; line-height: 1.15; }

/* ── SECTIONS ── */
.section { padding: 96px 24px; }
.section-inner { max-width: 1200px; margin: 0 auto; }
.section-tag { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--teal); margin-bottom: 12px; }
.section-title { font-size: clamp(28px, 4vw, 46px); font-weight: 800; color: var(--ink); letter-spacing: -1.5px; margin-bottom: 16px; }
.section-sub { font-size: 17px; color: var(--ink-soft); max-width: 560px; line-height: 1.7; margin-bottom: 56px; }

/* ── BUTTONS ── */
.btn-teal {
  padding: 14px 28px; background: var(--teal); color: white;
  font-family: 'Inter', sans-serif; font-weight: 600; font-size: 15px;
  border: none; border-radius: 10px; cursor: pointer; transition: all 0.2s; text-decoration: none;
  display: inline-flex; align-items: center; gap: 8px;
}
.btn-teal:hover { background: var(--teal-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,196,167,0.3); }

/* ── CAMPAIGN PLANNER ── */
#planner { background: var(--surface-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.planner-form {
  background: white; border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 40px; box-shadow: var(--shadow);
}
.form-step { margin-bottom: 36px; }
.step-label {
  font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
  color: var(--ink-muted); margin-bottom: 16px; padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.form-col { display: flex; flex-direction: column; gap: 6px; }
label { font-size: 13px; font-weight: 600; color: var(--ink); }
label .hint { font-weight: 400; color: var(--ink-muted); }
input[type=text], input[type=email], select, textarea {
  width: 100%; padding: 11px 14px; border: 1.5px solid var(--border);
  border-radius: 8px; font-size: 14px; font-family: 'Inter', sans-serif;
  color: var(--ink); background: white; transition: border-color 0.2s;
  outline: none;
}
input:focus, select:focus, textarea:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(0,196,167,0.12); }
textarea { resize: vertical; min-height: 80px; }
.btn-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; }
.btn-grid-5 { display: grid; grid-template-columns: repeat(5,1fr); gap: 8px; }
.btn-grid-3 { display: flex; gap: 8px; }
.toggle-btn {
  padding: 10px 8px; border: 1.5px solid var(--border); border-radius: 8px;
  background: white; font-size: 13px; font-family: 'Inter', sans-serif;
  font-weight: 600; cursor: pointer; transition: all 0.18s; text-align: left;
  color: var(--ink-soft);
}
.toggle-btn.active { background: var(--ink); color: white; border-color: var(--ink); }
.toggle-btn .sub { display: block; font-size: 11px; font-weight: 400; opacity: 0.7; margin-top: 2px; }
.interests { display: flex; flex-wrap: wrap; gap: 8px; }
.interest-tag {
  padding: 6px 14px; border: 1.5px solid var(--border); border-radius: 20px;
  font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s;
  background: white; color: var(--ink-soft); font-family: 'Inter', sans-serif;
}
.interest-tag.active { background: var(--ink); color: white; border-color: var(--ink); }
.env-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; }
.env-btn {
  padding: 10px 12px; border: 1.5px solid var(--border); border-radius: 8px;
  background: white; font-size: 13px; font-family: 'Inter', sans-serif;
  font-weight: 500; cursor: pointer; transition: all 0.18s; text-align: left;
  color: var(--ink-soft);
}
.env-btn.active { background: var(--teal-light); border-color: var(--teal); color: var(--teal-dark); }

/* Gate overlay */
.planner-gate {
  position: relative;
}
.gate-overlay {
  position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 30%, rgba(244,245,249,0.97) 65%);
  border-radius: var(--radius-lg); display: flex; align-items: flex-end; justify-content: center;
  padding-bottom: 48px; z-index: 10;
}
.gate-box {
  background: white; border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 32px 40px; text-align: center; max-width: 440px;
  box-shadow: var(--shadow-lg);
}
.gate-box h3 { font-family: 'Manrope', sans-serif; font-size: 22px; font-weight: 700; margin-bottom: 8px; }
.gate-box p { font-size: 14px; color: var(--ink-soft); margin-bottom: 24px; }
.gate-input-row { display: flex; gap: 10px; margin-bottom: 12px; }
.gate-input-row input { flex: 1; }
.gate-note { font-size: 12px; color: var(--ink-muted); }

.generate-btn {
  width: 100%; padding: 16px; background: var(--ink); color: white;
  font-family: 'Manrope', sans-serif; font-weight: 700; font-size: 16px;
  border: none; border-radius: 10px; cursor: pointer; transition: all 0.2s; margin-top: 8px;
}
.generate-btn:hover { background: #1a2035; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(10,14,26,0.2); }

/* ── MODAL for gate ── */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(10,14,26,0.7); z-index: 1000;
  display: flex; align-items: center; justify-content: center; padding: 24px;
  backdrop-filter: blur(4px);
  opacity: 0; pointer-events: none; transition: opacity 0.25s;
}
.modal-overlay.active { opacity: 1; pointer-events: all; }
.modal-box {
  background: white; border-radius: var(--radius-lg); padding: 48px;
  max-width: 480px; width: 100%; box-shadow: var(--shadow-lg);
  transform: translateY(20px); transition: transform 0.25s;
}
.modal-overlay.active .modal-box { transform: translateY(0); }
.modal-box h2 { font-family: 'Manrope', sans-serif; font-size: 26px; font-weight: 800; margin-bottom: 8px; }
.modal-box p { font-size: 15px; color: var(--ink-soft); margin-bottom: 28px; line-height: 1.7; }
.modal-box input { margin-bottom: 12px; }
.modal-close { position: absolute; top: 20px; right: 20px; background: none; border: none; font-size: 24px; cursor: pointer; color: var(--ink-muted); }

/* ── FOOTER ── */
footer {
  background: #060810; color: #4a5270;
  border-top: 1px solid #0e1220; padding: 48px 24px 32px;
}
.footer-inner { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
.footer-brand { display: flex; align-items: center; gap: 10px; }
.footer-links { display: flex; gap: 24px; }
.footer-links a { font-size: 13px; color: #4a5270; text-decoration: none; transition: color 0.2s; }
.footer-links a:hover { color: var(--teal); }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .form-row { grid-template-columns: 1fr; }
  .btn-grid { grid-template-columns: repeat(2,1fr); }
  .btn-grid-5 { grid-template-columns: repeat(2,1fr); }
  .env-grid { grid-template-columns: repeat(2,1fr); }
  .planner-form { padding: 24px; }
  .footer-inner { flex-direction: column; gap: 20px; text-align: center; }
  .footer-links { flex-wrap: wrap; justify-content: center; }
}
</style>
<script src="/static/pievra_widgets.js"></script>
</head>
<body>

<!-- MODAL: Email Gate -->
<div class="modal-overlay" id="gateModal">
  <div class="modal-box" style="position:relative">
    <button class="modal-close" onclick="closeModal()">×</button>
    <div style="font-size:36px;margin-bottom:16px">🐙</div>
    <h2>Access your campaign plan</h2>
    <p>Create a free Pievra account to generate, save and activate your cross-protocol campaign plan.</p>
    <label>Your work email</label>
    <input type="email" id="gateEmail" placeholder="you@agency.com" style="margin-top:6px"/>
    <button class="btn-teal" onclick="window.location.href='/signup'" style="margin-top:4px;width:100%;padding:13px;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;background:#00c4a7;color:#0a0e1a">Create free account &#x2192;</button>
    <p style="font-size:12px;color:var(--ink-muted);margin-top:12px;text-align:center">Free forever. No credit card. Cancel anytime.</p>
  </div>
</div>

<!-- NAV -->
<nav style="background:#0a0e1a;height:60px;display:flex;align-items:center;justify-content:space-between;padding:0 40px;position:sticky;top:0;z-index:100">
  <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none">
    <div style="width:30px;height:30px;background:#00c4a7;border-radius:7px;display:flex;align-items:center;justify-content:center;font-family:Manrope,sans-serif;font-weight:800;font-size:14px;color:#0a0e1a">P</div>
    <div style="font-family:Manrope,sans-serif;font-weight:800;font-size:16px;color:#fff">pievra</div>
  </a>
  <div style="display:flex;gap:20px;align-items:center">
    <a href="/marketplace" style="color:rgba(255,255,255,.7);text-decoration:none;font-size:14px;font-weight:500">Marketplace</a>
    <a href="/partners" style="color:rgba(255,255,255,.7);text-decoration:none;font-size:14px;font-weight:500">Partners</a>
    <a href="/news" style="color:rgba(255,255,255,.7);text-decoration:none;font-size:14px;font-weight:500">News</a>
    <a href="/careers" style="color:rgba(255,255,255,.7);text-decoration:none;font-size:14px;font-weight:500">Careers</a>
    <a href="/signin" style="color:rgba(255,255,255,.6);text-decoration:none;font-size:13px;font-weight:500">Sign In</a>
    <a href="/signup" style="background:#00c4a7;color:#0a0e1a;font-weight:700;font-size:13px;padding:8px 16px;border-radius:8px;text-decoration:none">Sign Up Free</a>
  </div>
</nav>

<!-- HERO -->
<section style="background:#0a0e1a;padding:80px 24px 48px;text-align:center">
  <div style="max-width:800px;margin:0 auto">
    <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 16px;border-radius:20px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);font-size:13px;font-weight:500;color:rgba(255,255,255,0.6);margin-bottom:24px">
      <span style="width:7px;height:7px;border-radius:50%;background:#00c4a7;display:inline-block"></span> Free tool, no credit card
    </div>
    <h1 style="font-family:Manrope,sans-serif;font-size:clamp(32px,5vw,56px);font-weight:800;color:white;letter-spacing:-2px;margin-bottom:16px">Plan & simulate a cross-protocol campaign</h1>
    <p style="font-size:17px;color:#8892b0;max-width:600px;margin:0 auto 0;line-height:1.7">Define your advertiser, audience, buying model and environments. Pievra assembles a coherent agent stack connected via open protocols, projects KPIs, and generates a downloadable media plan.</p>
  </div>
</section>

<!-- CAMPAIGN PLANNER -->
<section class="section" id="planner" style="background:var(--surface-2);border-top:1px solid var(--border)">
  <div class="section-inner">

    <div class="planner-gate">
      <!-- LLM Chat Mode -->
      <div id="planner-chat-mode" style="display:none;margin-bottom:24px;background:#0a0e1a;border-radius:16px;padding:24px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:32px;height:32px;background:#00c4a7;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px">🤖</div>
            <div>
              <div style="font-family:Manrope,sans-serif;font-weight:700;font-size:15px;color:white">AI Campaign Assistant</div>
              <div style="font-size:12px;color:#7a829e">Describe your campaign in plain language</div>
            </div>
          </div>
          <button onclick="togglePlannerMode()" style="background:none;border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.7);font-size:12px;padding:6px 12px;border-radius:8px;cursor:pointer">Switch to Form</button>
        </div>

        <!-- Example prompts -->
        <div style="margin-bottom:14px">
          <div style="font-size:11px;color:#7a829e;margin-bottom:8px;letter-spacing:.05em">EXAMPLE BRIEFS - click to use:</div>
          <div style="display:flex;flex-wrap:wrap;gap:8px">
            <button class="chat-example" onclick="useChatExample(this)" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.8);font-size:12px;padding:6px 12px;border-radius:20px;cursor:pointer;text-align:left">🛍 Nike Air Max launch - Gen Z, Europe, CTV + Display, $80K, ROAS 3.0</button>
            <button class="chat-example" onclick="useChatExample(this)" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.8);font-size:12px;padding:6px 12px;border-radius:20px;cursor:pointer;text-align:left">🏦 B2B SaaS lead gen - Finance decision-makers, US+UK, LinkedIn + Display, $25K CPL</button>
            <button class="chat-example" onclick="useChatExample(this)" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.8);font-size:12px;padding:6px 12px;border-radius:20px;cursor:pointer;text-align:left">🚗 Auto awareness - In-market buyers, Germany + France, CTV + DOOH, $120K CPM</button>
            <button class="chat-example" onclick="useChatExample(this)" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.8);font-size:12px;padding:6px 12px;border-radius:20px;cursor:pointer;text-align:left">✈ Travel retargeting - Luxury travellers, UAE + Singapore, Mobile + Native, $40K CPA</button>
          </div>
        </div>

        <!-- Chat messages -->
        <div id="chat-messages" style="min-height:80px;max-height:200px;overflow-y:auto;margin-bottom:12px"></div>

        <!-- Chat input -->
        <div style="display:flex;gap:10px">
          <textarea id="chat-input" placeholder="e.g. Run an awareness campaign for Nike Air Max 2026 targeting Gen Z in France and Germany on CTV and Display, budget $80K, ROAS target 3.0..." style="flex:1;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:10px;color:white;font-size:14px;padding:12px;font-family:Inter,sans-serif;resize:none;min-height:80px" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendChat();}"></textarea>
          <button onclick="if(typeof sendChat==='function'){sendChat();}else{console.error('sendChat not defined');}" id="chat-send-btn" style="background:#00c4a7;border:none;color:#0a0e1a;font-weight:700;font-size:14px;padding:12px 20px;border-radius:10px;cursor:pointer;align-self:flex-end;white-space:nowrap">Generate &#x2192;</button>
        </div>
        <div style="font-size:11px;color:#7a829e;margin-top:8px">Press Enter to send · Shift+Enter for new line</div>
      </div>

      <!-- Mode toggle bar -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;padding:12px 16px;background:white;border:1px solid var(--border);border-radius:12px">
        <div style="font-size:14px;color:#3d4460">Fill in the form or use the AI assistant to set up your campaign</div>
        <div style="display:flex;gap:8px">
          <button id="btn-form-mode" onclick="setMode('form')" style="background:#0a0e1a;color:white;border:none;font-size:13px;font-weight:600;padding:7px 16px;border-radius:8px;cursor:pointer">📋 Form</button>
          <button id="btn-chat-mode" onclick="setMode('chat')" style="background:none;border:1px solid #e2e4ed;color:#3d4460;font-size:13px;font-weight:600;padding:7px 16px;border-radius:8px;cursor:pointer">🤖 AI Assistant</button>
        </div>
      </div>

      <div class="planner-form">
        <!-- Step 1 -->
        <div class="form-step">
          <div class="step-label">1 - Campaign Brief</div>
          <div class="form-row">
            <div class="form-col"><label for="pl-brand">Advertiser / Brand <span style="color:#dc2626">*</span></label><input type="text" id="pl-brand" placeholder="e.g. Nike, Samsung, L'Oréal..."/></div>
            <div class="form-col"><label for="pl-name">Product / Campaign Name <span style="color:#dc2626">*</span></label><input type="text" id="pl-name" placeholder="e.g. Air Max 2026 launch..."/></div>
          </div>
          <div class="form-col">
            <label for="pl-desc">Campaign Description <span class="hint">- goals, messaging, requirements</span> <span style="color:#dc2626">*</span></label>
            <textarea id="pl-desc" placeholder="e.g. Drive awareness for Air Max 2026 targeting Gen Z in major European cities. 30s hero video for CTV, companion display for web retargeting. Brand safety: premium publishers only..."></textarea>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="form-step">
          <div class="step-label">2 - Objective & Buying Model</div>
          <div style="margin-bottom:16px">
            <label style="margin-bottom:10px;display:block">Campaign Objective</label>
            <div class="btn-grid">
              <button class="toggle-btn active" onclick="toggleBtn(this,'obj')">Awareness<span class="sub">Maximise reach</span></button>
              <button class="toggle-btn" onclick="toggleBtn(this,'obj')">Consideration<span class="sub">Drive engagement</span></button>
              <button class="toggle-btn" onclick="toggleBtn(this,'obj')">Conversion<span class="sub">Optimise sales</span></button>
              <button class="toggle-btn" onclick="toggleBtn(this,'obj')">Retention<span class="sub">Re-engage users</span></button>
            </div>
          </div>
          <div style="margin-bottom:16px">
            <label style="margin-bottom:10px;display:block">Buying Model</label>
            <div class="btn-grid-5">
              <button class="toggle-btn active" onclick="toggleBtn(this,'buy')">CPM<span class="sub">per 1,000 impr.</span></button>
              <button class="toggle-btn" onclick="toggleBtn(this,'buy')">CPC<span class="sub">per click</span></button>
              <button class="toggle-btn" onclick="toggleBtn(this,'buy')">CPA<span class="sub">per acquisition</span></button>
              <button class="toggle-btn" onclick="toggleBtn(this,'buy')">CPL<span class="sub">per lead</span></button>
              <button class="toggle-btn" onclick="toggleBtn(this,'buy')">CPCV<span class="sub">per completed view</span></button>
            </div>
          </div>
          <div class="form-row">
            <div class="form-col"><label for="pl-budget">Budget (USD)</label><input type="text" id="pl-budget" value="50000"/></div>
            <div class="form-col"><label for="pl-kpi">KPI Target <span class="hint">- auto-suggested, edit freely</span></label><input type="text" id="pl-kpi" value="ROAS > 2.5"/></div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="form-step">
          <div class="step-label">3 - Audience Targeting</div>
          <div class="form-row" style="margin-bottom:16px">
            <div class="form-col">
              <label>Age Range</label>
              <select id="pl-age"><option>All Ages</option><option>13-17</option><option>18-24</option><option>25-34</option><option>35-44</option><option>45-54</option><option>55-64</option><option>65+</option></select>
            </div>
            <div class="form-col">
              <label>Gender</label>
              <div class="btn-grid-3">
                <button class="toggle-btn active" onclick="toggleBtn(this,'gen')" style="flex:1">All</button>
                <button class="toggle-btn" onclick="toggleBtn(this,'gen')" style="flex:1">Male</button>
                <button class="toggle-btn" onclick="toggleBtn(this,'gen')" style="flex:1">Female</button>
              </div>
            </div>
          </div>
          <label style="margin-bottom:10px;display:block">Interests & Affinities</label>
          <div class="interests">
            <button class="interest-tag" onclick="this.classList.toggle('active')">Technology</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">Fashion</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">Sports</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">Gaming</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">Travel</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">Food & Drink</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">Health & Fitness</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">Finance</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">Automotive</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">Entertainment</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">Luxury</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">B2B / Business</button>
            <button class="interest-tag" onclick="this.classList.toggle('active')">Sustainability</button>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="form-step">
          <div class="step-label">4 - Geo Targeting</div>
          <div class="form-row">
            <div class="form-col">
              <label for="pl-country">Country / Region <span style="color:#7a829e;font-size:12px">(hold Ctrl/Cmd to select multiple)</span></label>
              <select id="pl-country" multiple size="5" style="height:120px;padding:6px">
                <option value="United States">United States</option>
                <option value="United Kingdom">United Kingdom</option>
                <option value="France">France</option>
                <option value="Germany">Germany</option>
                <option value="Netherlands">Netherlands</option>
                <option value="Belgium">Belgium</option>
                <option value="Spain">Spain</option>
                <option value="Italy">Italy</option>
                <option value="Canada">Canada</option>
                <option value="Australia">Australia</option>
                <option value="UAE">UAE</option>
                <option value="Saudi Arabia">Saudi Arabia</option>
                <option value="Singapore">Singapore</option>
                <option value="Japan">Japan</option>
                <option value="Brazil">Brazil</option>
                <option value="Mexico">Mexico</option>
                <option value="India">India</option>
                <option value="South Africa">South Africa</option>
              </select>
            </div>
            <div class="form-col"><label for="pl-city">City <span class="hint">- optional, for hyperlocal</span></label><input type="text" id="pl-city" placeholder="e.g. Paris, Dubai, London..."/></div>
          </div>
        </div>

        <!-- Step 5 -->
        <div class="form-step">
          <div class="step-label">5 - Target Environments</div>
          <div class="env-grid">
            <button class="env-btn active" onclick="this.classList.toggle('active')">🖥 Web Display</button>
            <button class="env-btn" onclick="this.classList.toggle('active')">📱 Mobile App</button>
            <button class="env-btn" onclick="this.classList.toggle('active')">📺 CTV / Streaming</button>
            <button class="env-btn" onclick="this.classList.toggle('active')">🏙 DOOH</button>
            <button class="env-btn" onclick="this.classList.toggle('active')">🎧 Digital Audio</button>
            <button class="env-btn" onclick="this.classList.toggle('active')">💬 Social</button>
            <button class="env-btn" onclick="this.classList.toggle('active')">📰 Native</button>
            <button class="env-btn" onclick="this.classList.toggle('active')">▶ Online Video</button>
          </div>
        </div>

        <!-- Step 6 -->
        <div class="form-step" style="margin-bottom:24px">
          <div class="step-label">6 - Flight & Brand Safety</div>
          <div class="form-row">
            <div class="form-col"><label for="pl-start">Flight Start</label><input type="date" id="pl-start" style="padding:10px 14px"/></div>
            <div class="form-col"><label for="pl-end">Flight End</label><input type="date" id="pl-end" style="padding:10px 14px"/></div>
          </div>
          <div class="form-row">
            <div class="form-col"><label for="pl-freq">Frequency Cap (per user)</label><input type="text" id="pl-freq" value="5"/></div>
            <div class="form-col">
              <label>Brand Safety</label>
              <div class="btn-grid-3">
                <button class="toggle-btn" onclick="toggleBtn(this,'bs')" style="flex:1">Light</button>
                <button class="toggle-btn active" onclick="toggleBtn(this,'bs')" style="flex:1">Standard</button>
                <button class="toggle-btn" onclick="toggleBtn(this,'bs')" style="flex:1">Strict</button>
              </div>
            </div>
          </div>
        </div>

        <button class="generate-btn" onclick="pievraGen()">
          🐙 Generate Campaign Plan
        </button>
      </div>

      <!-- Gate overlay - shows over bottom of form -->
      <div class="gate-overlay" id="plannerGate" style="display:none">
        <div class="gate-box">
          <div style="font-size:32px;margin-bottom:12px">🐙</div>
          <h3>Your plan is ready</h3>
          <p>Create a free account to view, save and activate your cross-protocol campaign plan.</p>
          <div class="gate-input-row">
            <input type="email" placeholder="Work email address"/>
            <button class="btn-teal" onclick="pievraHandleGetPlan()">Get Plan &#x2192;</button>
          </div>
          <p class="gate-note">Free forever. No credit card required.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <div style="width:28px;height:28px;background:#00c4a7;border-radius:7px;display:flex;align-items:center;justify-content:center;font-family:Manrope,sans-serif;font-weight:800;font-size:13px;color:#0a0e1a">P</div>
      <span style="font-family:Manrope,sans-serif;font-weight:700;font-size:15px;color:#8892b0">pievra</span>
      <span style="font-size:12px;color:#4a5270;margin-left:8px">&copy; 2026</span>
    </div>
    <div class="footer-links">
      <a href="/">Home</a>
      <a href="/marketplace">Marketplace</a>
      <a href="/partners">Partners</a>
      <a href="/news">News</a>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
    </div>
  </div>
</footer>

<script>
// Toggle button groups
function toggleBtn(el, group) {
  const parent = el.closest('.btn-grid, .btn-grid-5, .btn-grid-3, .form-step');
  if (parent) {
    parent.querySelectorAll('.toggle-btn[onclick*="'+group+'"]').forEach(b => b.classList.remove('active'));
  }
  el.classList.add('active');
}

// Modal
function openModal() {
  document.getElementById('gateModal').classList.add('active');
  typeof gtag !== 'undefined' && gtag('event', 'modal_open', { event_category: 'conversion', event_label: 'signup_gate' });
}
function closeModal() {
  document.getElementById('gateModal').classList.remove('active');
}
document.getElementById('gateModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// Gate submission
function submitGate() {
  const email = document.getElementById('gateEmail').value;
  if (!email || !email.includes('@')) {
    document.getElementById('gateEmail').style.borderColor = '#dc2626';
    return;
  }
  const btn = document.querySelector('#planGate .generate-btn') ||
               document.querySelector('button[onclick="submitGate()"]');
  if (btn) { btn.textContent = 'Sending...'; btn.disabled = true; }

  fetch('/api/signup', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email: email, source: 'campaign-planner' })
  })
  .then(r => r.json())
  .then(d => {
    typeof gtag !== 'undefined' && gtag('event', 'sign_up', { event_category: 'conversion', event_label: email });
    closeModal();
    const banner = document.createElement('div');
    banner.style.cssText = 'position:fixed;top:80px;left:50%;transform:translateX(-50%);background:#00c4a7;color:#0a0e1a;font-weight:700;padding:14px 28px;border-radius:12px;z-index:9999;font-size:15px;box-shadow:0 4px 24px rgba(0,196,167,0.3)';
    banner.textContent = 'Welcome! Check your inbox for your Pievra access link.';
    document.body.appendChild(banner);
    setTimeout(() => banner.remove(), 6000);
  })
  .catch(() => {
    closeModal();
    const banner = document.createElement('div');
    banner.style.cssText = 'position:fixed;top:80px;left:50%;transform:translateX(-50%);background:#00c4a7;color:#0a0e1a;font-weight:700;padding:14px 28px;border-radius:12px;z-index:9999;font-size:15px';
    banner.textContent = 'Registered! We will be in touch at ' + email;
    document.body.appendChild(banner);
    setTimeout(() => banner.remove(), 6000);
  });
}

// Track events
function trackEvent(name) {
  typeof gtag !== 'undefined' && gtag('event', name, { event_category: 'engagement' });
}
</script>

<script src="/static/planner.js?v=1774223657"></script>
</body>
</html>
